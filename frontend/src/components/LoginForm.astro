---
---

<div class="auth-layout">
  <!-- LEFT PANEL -->
  <div class="auth-left">
    <div class="auth-left-inner">
      <div class="auth-brand">
        <span class="auth-brand-icon">📚</span>
        <span class="auth-brand-name">Librería</span>
      </div>
      <h2 class="auth-left-title">Tu mundo de libros, <em>en un solo lugar.</em></h2>
      <p class="auth-left-desc">Gestiona tu inventario, ventas y recomendaciones con un sistema inteligente y moderno.</p>
      <div class="auth-features">
        <div class="auth-feature"><span>✓</span> Catálogo con imágenes de portada</div>
        <div class="auth-feature"><span>✓</span> Sistema experto de recomendaciones</div>
        <div class="auth-feature"><span>✓</span> Control de inventario en tiempo real</div>
      </div>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="auth-right">
    <div class="login-card">
      <div class="login-header">
        <h1 class="login-title">Bienvenido</h1>
        <p class="login-subtitle">Ingresa tus credenciales para continuar</p>
      </div>

      <div id="errorAlert" class="auth-alert auth-alert-error" style="display:none"></div>

      <div class="form-group">
        <label class="form-label">Correo electrónico</label>
        <input type="email" id="email" class="form-input" placeholder="tu@email.com" autocomplete="email">
      </div>

      <div class="form-group">
        <label class="form-label">Contraseña</label>
        <div class="input-wrap">
          <input type="password" id="password" class="form-input" placeholder="••••••••" autocomplete="current-password">
          <button type="button" id="togglePwd" class="toggle-pwd">👁</button>
        </div>
      </div>

      <button id="loginBtn" class="btn btn-primary btn-full">
        <span id="loginBtnText">Iniciar sesión</span>
        <span id="loginBtnSpinner" class="spinner" style="display:none"></span>
      </button>

      <div class="auth-divider"><span>cuentas de demostración</span></div>

      <div class="demo-accounts">
        <button class="demo-btn" data-email="admin@libreria.com" data-pwd="admin123">
          <span class="demo-role admin-role">ADMIN</span>
          <span class="demo-email">admin@libreria.com</span>
        </button>
        <button class="demo-btn" data-email="empleado@libreria.com" data-pwd="empleado123">
          <span class="demo-role empleado-role">EMPLEADO</span>
          <span class="demo-email">empleado@libreria.com</span>
        </button>
        <button class="demo-btn" data-email="cliente@ejemplo.com" data-pwd="cliente123">
          <span class="demo-role cliente-role">CLIENTE</span>
          <span class="demo-email">cliente@ejemplo.com</span>
        </button>
      </div>

      <p class="auth-footer-link" style="margin-bottom:0.5rem">¿Olvidaste tu contraseña? <a href="/forgot-password">Recupérala aquí</a></p>
      <p class="auth-footer-link">¿No tienes cuenta? <a href="/register">Regístrate aquí</a></p>
      <a href="/catalogo" class="catalog-link-btn">
        <span class="catalog-link-icon">📖</span>
        Ver catálogo sin iniciar sesión
      </a>
    </div>
  </div>
</div>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';

  async function doLogin(email: string, password: string) {
    const btn = document.getElementById('loginBtn') as HTMLButtonElement;
    const txt = document.getElementById('loginBtnText')!;
    const spin = document.getElementById('loginBtnSpinner')!;
    const err = document.getElementById('errorAlert')!;

    btn.disabled = true;
    txt.textContent = 'Iniciando...';
    spin.style.display = 'inline-block';
    err.style.display = 'none';

    try {
      const res = await fetch(`${API_URL}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail || 'Credenciales incorrectas');

      localStorage.setItem('token', data.access_token);
      localStorage.setItem('user', JSON.stringify(data.user));
      const maxAge = 86400;
      document.cookie = `token=${data.access_token}; path=/; max-age=${maxAge}`;
      document.cookie = `user=${encodeURIComponent(JSON.stringify(data.user))}; path=/; max-age=${maxAge}`;

      const role = data.user.role_name;
      window.location.href = role === 'ADMIN' ? '/dashboard-admin' : role === 'EMPLEADO' ? '/dashboard-empleado' : '/catalogo';
    } catch(e: any) {
      err.textContent = e.message;
      err.style.display = 'block';
      btn.disabled = false;
      txt.textContent = 'Iniciar sesión';
      spin.style.display = 'none';
    }
  }

  document.getElementById('loginBtn')?.addEventListener('click', () => {
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    doLogin(email, password);
  });

  document.getElementById('email')?.addEventListener('keydown', (e: any) => { if (e.key === 'Enter') document.getElementById('loginBtn')?.click(); });
  document.getElementById('password')?.addEventListener('keydown', (e: any) => { if (e.key === 'Enter') document.getElementById('loginBtn')?.click(); });

  document.getElementById('togglePwd')?.addEventListener('click', () => {
    const inp = document.getElementById('password') as HTMLInputElement;
    inp.type = inp.type === 'password' ? 'text' : 'password';
  });

  document.querySelectorAll('.demo-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const email = (btn as HTMLElement).dataset.email!;
      const pwd = (btn as HTMLElement).dataset.pwd!;
      (document.getElementById('email') as HTMLInputElement).value = email;
      (document.getElementById('password') as HTMLInputElement).value = pwd;
      doLogin(email, pwd);
    });
  });

  // Mostrar aviso si la sesión expiró por inactividad
  (function checkExpiredSession() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('expired') !== '1') return;
    const reason = params.get('reason') || 'inactividad';
    const msgs: Record<string, string> = {
      inactividad: 'Tu sesión cerró automáticamente por inactividad.',
      manual: 'Has cerrado sesión correctamente.',
      otra_pestana: 'Tu sesión fue cerrada desde otra pestaña.',
    };
    const msg = msgs[reason] || msgs['inactividad'];
    const banner = document.createElement('div');
    banner.style.cssText = 'background:#fef3c7;border:1.5px solid #f59e0b;color:#92400e;padding:.75rem 1rem;border-radius:8px;font-size:.85rem;font-weight:600;margin-bottom:1.25rem;text-align:center;';
    banner.textContent = '⏱️ ' + msg;
    const err = document.getElementById('errorAlert');
    err?.parentNode?.insertBefore(banner, err);
    // Limpiar URL
    window.history.replaceState({}, '', '/login');
  })();
</script>

<style>
  .auth-layout { display: flex; min-height: 100vh; }
  .auth-left { flex: 1; background: linear-gradient(145deg, var(--navy) 0%, var(--blue-dark) 60%, #1e3a6e 100%); display: flex; align-items: center; justify-content: center; padding: 3rem; position: relative; overflow: hidden; }
  .auth-left::before { content: ''; position: absolute; width: 500px; height: 500px; border-radius: 50%; background: rgba(200,169,126,0.05); top: -150px; right: -150px; }
  .auth-left::after { content: ''; position: absolute; width: 300px; height: 300px; border-radius: 50%; background: rgba(37,99,235,0.1); bottom: -100px; left: -50px; }
  .auth-left-inner { position: relative; z-index: 2; max-width: 420px; }
  .auth-brand { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 3rem; }
  .auth-brand-icon { font-size: 2.5rem; }
  .auth-brand-name { font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; color: white; }
  .auth-left-title { font-family: var(--font-display); font-size: 2.25rem; font-weight: 700; color: white; line-height: 1.25; margin-bottom: 1rem; }
  .auth-left-title em { color: var(--beige); font-style: normal; }
  .auth-left-desc { color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 2rem; font-size: 1rem; }
  .auth-features { display: flex; flex-direction: column; gap: 0.75rem; }
  .auth-feature { display: flex; align-items: center; gap: 0.75rem; color: rgba(255,255,255,0.75); font-size: 0.9rem; }
  .auth-feature span { color: var(--beige); font-weight: 700; font-size: 1rem; }

  .auth-right { width: 480px; display: flex; align-items: center; justify-content: center; padding: 2rem; background: var(--gray-50); }
  .login-card { width: 100%; max-width: 400px; }
  .login-header { margin-bottom: 2rem; }
  .login-title { font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--navy); margin-bottom: 0.4rem; }
  .login-subtitle { color: var(--gray-400); font-size: 0.9rem; }

  .auth-alert { padding: 0.875rem 1rem; border-radius: var(--radius-sm); margin-bottom: 1.25rem; font-size: 0.875rem; }
  .auth-alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

  .input-wrap { position: relative; }
  .toggle-pwd { position: absolute; right: 0.875rem; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; font-size: 1rem; opacity: 0.5; }
  .toggle-pwd:hover { opacity: 1; }

  .btn-full { width: 100%; padding: 0.875rem; font-size: 1rem; margin-top: 0.5rem; }

  .auth-divider { text-align: center; margin: 1.5rem 0 1rem; position: relative; }
  .auth-divider::before { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: var(--gray-200); }
  .auth-divider span { position: relative; background: var(--gray-50); padding: 0 0.75rem; color: var(--gray-400); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; }

  .demo-accounts { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
  .demo-btn { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 1rem; background: white; border: 1.5px solid var(--gray-200); border-radius: var(--radius-sm); cursor: pointer; transition: all 0.2s; font-family: var(--font-body); text-align: left; }
  .demo-btn:hover { border-color: var(--blue-mid); background: var(--blue-ghost); }
  .demo-role { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; padding: 2px 8px; border-radius: 999px; flex-shrink: 0; }
  .admin-role { background: #fef3c7; color: #92400e; }
  .empleado-role { background: var(--blue-pale); color: var(--blue-mid); }
  .cliente-role { background: #dcfce7; color: #166534; }
  .demo-email { font-size: 0.8rem; color: var(--gray-600); }

  .auth-footer-link { text-align: center; font-size: 0.875rem; color: var(--gray-400); }
  .auth-footer-link a { color: var(--blue-mid); font-weight: 600; text-decoration: none; }
  .auth-footer-link a:hover { text-decoration: underline; }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: middle; }

  .catalog-link-btn { display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-top: 0.875rem; padding: 0.7rem 1rem; border: 1.5px dashed var(--gray-300); border-radius: var(--radius-sm); color: var(--gray-500); font-size: 0.85rem; text-decoration: none; transition: all 0.2s; background: white; }
  .catalog-link-btn:hover { border-color: var(--blue-mid); color: var(--blue-mid); background: var(--blue-ghost); }
  .catalog-link-icon { font-size: 1rem; }

  @media (max-width: 900px) { .auth-left { display: none; } .auth-right { width: 100%; } }
</style>