---
// Navbar lateral para dashboards

interface Props {
  userRole: string;
  userName: string;
}

const { userRole, userName } = Astro.props;

// Definir menús según el rol
const menuItems: Record<string, Array<{label: string, href: string, icon: string}>> = {
  ADMIN: [
    { label: 'Dashboard', href: '/dashboard-admin', icon: '📘' },
    { label: 'Inventario', href: '/inventario', icon: '📚' },
    { label: 'Ventas', href: '/ventas', icon: '💰' },
    { label: 'Compras', href: '/compras', icon: '📦' },
    { label: 'Empleados', href: '/empleados', icon: '👥' },
    { label: 'Estadísticas', href: '/sistema-experto', icon: '📊'},
    { label: 'Catálogo', href: '/catalogo', icon: '🏪' },
  ],
  EMPLEADO: [
    { label: 'Dashboard', href: '/dashboard-empleado', icon: '📊' },
    { label: 'Inventario', href: '/inventario', icon: '📚' },
    { label: 'Ventas', href: '/ventas', icon: '💰' },
    { label: 'Catálogo', href: '/catalogo', icon: '🏪' },
  ],
  CLIENTE: [
    { label: 'Catálogo', href: '/catalogo', icon: '🏪' },
    { label: 'Mis Compras', href: '/mis-compras', icon: '🛒' },
    { label: 'Recomendaciones', href: '/recomendaciones', icon: '⭐' },
  ],
};

const currentMenu = menuItems[userRole] || menuItems.CLIENTE;
const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <div class="sidebar-header">
    <h1>📚 Librería</h1>
    <p>Sistema de Gestión</p>
  </div>
  
  <nav class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-section-title">Menú Principal</div>
      {currentMenu.map(item => (
        <a 
          href={item.href} 
          class={`nav-link ${currentPath === item.href ? 'active' : ''}`}
        >
          <span>{item.icon}</span>
          <span>{item.label}</span>
        </a>
      ))}
    </div>
  </nav>
</aside>

<style>
  .sidebar {
    width: 260px;
    background: linear-gradient(to bottom, #1e3a8a, #6d28d9);
    color: white;
    position: fixed;
    height: 100vh;
    overflow-y: auto;
    z-index: 100;
    font-family: 'Segoe UI', sans-serif;
  }

  .sidebar-header {
    padding: 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    text-align: center;
  }

  .sidebar-header h1 {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.25rem;
  }

  .sidebar-header p {
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .sidebar-nav {
    padding: 1rem 0;
  }

  .nav-section-title {
    padding: 0.5rem 1.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    transition: background 0.3s, color 0.3s;
    border-left: 4px solid transparent;
  }

  .nav-link:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
    border-left: 4px solid #c084fc;
  }

  .nav-link.active {
    background: rgba(255,255,255,0.2);
    color: #fff;
    font-weight: bold;
    border-left: 4px solid #a78bfa;
  }

  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
    }
  }
</style>
