---
interface Props {
  userRole: string;
  userName: string;
}
const { userRole, userName } = Astro.props;

const menuItems: Record<string, Array<{label: string, href: string, icon: string}>> = {
  ADMIN: [
    { label: 'Dashboard', href: '/dashboard-admin', icon: '▦' },
    { label: 'Inventario', href: '/inventario', icon: '📚' },
    { label: 'Ventas', href: '/ventas', icon: '💰' },
    { label: 'Compras', href: '/compras', icon: '📦' },
    { label: 'Proveedores', href: '/proveedores', icon: '🏭' },
    { label: 'Empleados', href: '/empleados', icon: '👥' },
    { label: 'Sistema Experto', href: '/sistema-experto', icon: '🤖' },
    { label: 'Ver Catálogo', href: '/catalogo-admin', icon: '🏪' },
    { label: 'Auditoría', href: '/auditoria', icon: '📋' },
  ],
  EMPLEADO: [
    { label: 'Dashboard', href: '/dashboard-empleado', icon: '▦' },
    { label: 'Inventario', href: '/inventario', icon: '📚' },
    { label: 'Ventas', href: '/ventas', icon: '💰' },
    { label: 'Proveedores', href: '/proveedores', icon: '🏭' },
    { label: 'Ver Catálogo', href: '/catalogo-admin', icon: '🏪' },
  ],
  CLIENTE: [
    { label: 'Catálogo', href: '/catalogo', icon: '🏪' },
    { label: 'Mis Libros', href: '/mis-libros', icon: '📖' },
    { label: 'Mis Compras', href: '/mis-compras', icon: '💳' },
    { label: 'Recomendaciones', href: '/recomendaciones', icon: '⭐' },
  ],
};

const currentMenu = menuItems[userRole] || menuItems.CLIENTE;
const currentPath = Astro.url.pathname;
const initials = userName.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase();
---

<aside class="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-logo">
      <img src="/honduletras-logo-dark.svg" alt="HonduLetras" class="sidebar-logo-img">
    </div>
    <div class="sidebar-user">
      <div class="sidebar-user-name">{userName}</div>
      <div class="sidebar-user-role">
        <span class={`role-tag role-${userRole.toLowerCase()}`}>{userRole}</span>
      </div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-section-title">Menú principal</div>
      {currentMenu.map(item => (
        <a href={item.href} class={`nav-link ${currentPath === item.href ? 'active' : ''}`}>
          <span class="nav-icon">{item.icon}</span>
          <span>{item.label}</span>
          {item.href === '/carrito' && <span class="sidebar-cart-badge" id="sidebarCartBadge" style="display:none">0</span>}
        </a>
      ))}
    </div>
  </nav>

  <script is:inline>
    (function() {
      const badge = document.getElementById('sidebarCartBadge');
      if (!badge) return;
      function update() {
        try {
          const cart = JSON.parse(localStorage.getItem('libreria_cart') || '[]');
          const total = cart.reduce((s, i) => s + (i.qty || 1), 0);
          badge.textContent = total;
          badge.style.display = total > 0 ? 'inline-flex' : 'none';
        } catch {}
      }
      update();
      window.addEventListener('storage', update);
      window.addEventListener('focus', update);
    })();
  </script>

  <div class="sidebar-footer">
    <button id="logoutBtn" class="logout-btn">
      <span>🚪</span>
      <span>Cerrar sesión</span>
    </button>
  </div>
</aside>

<style>
  .sidebar { width: 260px; background: var(--navy); position: fixed; height: 100vh; overflow-y: auto; z-index: 100; display: flex; flex-direction: column; }
  .sidebar-header { padding: 1.5rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
  .sidebar-logo { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1.25rem; }
  .sidebar-logo-img { height: 42px; width: auto; display: block; }
  .sidebar-user { }
  .sidebar-user-name { font-size: 0.9rem; color: rgba(255,255,255,0.9); font-weight: 600; }
  .sidebar-user-role { margin-top: 4px; }
  .role-tag { display: inline-block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 2px 8px; border-radius: 999px; }
  .role-admin { background: rgba(200,169,126,0.25); color: var(--beige); }
  .role-empleado { background: rgba(59,130,246,0.25); color: #93c5fd; }
  .role-cliente { background: rgba(34,197,94,0.2); color: #86efac; }
  .sidebar-nav { flex: 1; padding: 1.25rem 0; }
  .nav-section-title { padding: 0 1.25rem 0.5rem; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.3); font-weight: 600; }
  .nav-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 1rem; margin: 1px 0.5rem; border-radius: var(--radius-sm); color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: all 0.2s; }
  .nav-link:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.9); }
  .nav-link.active { background: rgba(37,99,235,0.35); color: white; border-left: 3px solid var(--blue-light); padding-left: calc(1rem - 3px); }
  .nav-icon { font-size: 1rem; width: 20px; text-align: center; }
  .sidebar-footer { padding: 1rem; border-top: 1px solid rgba(255,255,255,0.07); }
  .logout-btn { width: 100%; display: flex; align-items: center; gap: 0.6rem; padding: 0.65rem 1rem; background: rgba(220,38,38,0.12); color: #fca5a5; border: none; border-radius: var(--radius-sm); cursor: pointer; font-size: 0.85rem; font-weight: 500; transition: all 0.2s; font-family: var(--font-body); }
  .logout-btn:hover { background: rgba(220,38,38,0.25); color: #fee2e2; }
  .sidebar-cart-badge { background: #ef4444; color: white; border-radius: 999px; min-width: 18px; height: 18px; font-size: 0.65rem; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; padding: 0 4px; margin-left: auto; }
</style>