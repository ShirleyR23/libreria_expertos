---
import DashboardLayout from '../layouts/DashboardLayout.astro';
const userStr = Astro.cookies.get('user')?.value;
let user = null;
try { user = userStr ? JSON.parse(userStr) : null; } catch (e) {}
if (!user || user.role_name !== 'ADMIN') return Astro.redirect('/login');
---
<DashboardLayout title="Auditoría del Sistema" userRole="ADMIN">
<style>
  /* ── Layout general ── */
  .audit-page { display: flex; flex-direction: column; gap: 1.5rem; }
  .page-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
  .page-title { font-family: var(--font-display); font-size: 1.75rem; color: var(--navy); display: flex; align-items: center; gap: .6rem; }

  /* ── Stat cards ── */
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .stat-card { background: var(--bg-card); border: 1.5px solid var(--gray-100); border-radius: var(--radius); padding: 1.1rem 1.25rem; display: flex; flex-direction: column; gap: .35rem; box-shadow: var(--shadow-sm); }
  .stat-label { font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--gray-400); }
  .stat-value { font-family: var(--font-display); font-size: 1.85rem; font-weight: 700; color: var(--navy); line-height: 1; }
  .stat-sub { font-size: .78rem; color: var(--gray-400); }
  .stat-card.s-blue  { border-top: 3px solid #3b82f6; }
  .stat-card.s-green { border-top: 3px solid #22c55e; }
  .stat-card.s-amber { border-top: 3px solid #f59e0b; }
  .stat-card.s-red   { border-top: 3px solid #ef4444; }

  /* ── Filtros ── */
  .filters-card { background: var(--bg-card); border: 1.5px solid var(--gray-100); border-radius: var(--radius); padding: 1.1rem 1.25rem; box-shadow: var(--shadow-sm); }
  .filters-title { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--gray-400); margin-bottom: .85rem; }
  .filters-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr auto; gap: .65rem; align-items: end; }
  .fi-group { display: flex; flex-direction: column; gap: .3rem; }
  .fi-label { font-size: .75rem; font-weight: 600; color: var(--gray-500); }
  .fi { padding: .5rem .875rem; border: 1.5px solid var(--gray-200); border-radius: var(--radius-sm); font-size: .875rem; font-family: var(--font-body); color: var(--gray-800); background: white; width: 100%; }
  .fi:focus { outline: none; border-color: var(--blue-mid); }
  .btn-clear { padding: .5rem .875rem; background: var(--gray-100); border: 1.5px solid var(--gray-200); border-radius: var(--radius-sm); font-size: .825rem; font-weight: 600; color: var(--gray-600); cursor: pointer; white-space: nowrap; }
  .btn-clear:hover { background: var(--gray-200); }

  /* ── Tabla ── */
  .table-card { background: var(--bg-card); border: 1.5px solid var(--gray-100); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; }
  .table-toolbar { display: flex; align-items: center; justify-content: space-between; padding: .875rem 1.25rem; border-bottom: 1px solid var(--gray-100); flex-wrap: wrap; gap: .5rem; }
  .total-badge { background: var(--blue-ghost); color: var(--blue-dark); padding: .28rem .875rem; border-radius: 99px; font-size: .8rem; font-weight: 700; }
  .log-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: .845rem; }
  thead th { background: var(--navy); color: white; padding: .65rem 1rem; text-align: left; font-size: .73rem; text-transform: uppercase; letter-spacing: .05em; white-space: nowrap; }
  tbody td { padding: .6rem 1rem; border-bottom: 1px solid var(--gray-100); vertical-align: middle; }
  tbody tr:hover td { background: var(--gray-50); }
  tbody tr:last-child td { border-bottom: none; }
  .empty-row td { text-align: center; padding: 3rem; color: var(--gray-400); font-size: .9rem; }

  /* ── Badges de acción ── */
  .badge { display: inline-flex; align-items: center; gap: .3rem; padding: 2px 9px; border-radius: 99px; font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; white-space: nowrap; }
  .b-login           { background: #f1f5f9; color: #475569; }
  .b-register        { background: #dcfce7; color: #166534; }
  .b-create_book     { background: #dbeafe; color: #1e40af; }
  .b-update_book     { background: #e0e7ff; color: #3730a3; }
  .b-delete_book     { background: #fee2e2; color: #991b1b; }
  .b-create_sale     { background: #d1fae5; color: #065f46; }
  .b-cancel_sale     { background: #fef3c7; color: #92400e; }
  .b-create_purchase { background: #cffafe; color: #164e63; }
  .b-cancel_purchase { background: #fce7f3; color: #9d174d; }
  .b-create_employee { background: #f3e8ff; color: #6b21a8; }
  .b-update_employee { background: #ede9fe; color: #5b21b6; }
  .b-other           { background: #f9fafb; color: #6b7280; }

  /* ── Detalle expandible ── */
  .det-wrap { max-width: 240px; }
  .det-text { font-size: .775rem; color: var(--gray-500); word-break: break-word; line-height: 1.4; }
  .det-toggle { font-size: .7rem; color: var(--blue-mid); cursor: pointer; background: none; border: none; padding: 0; font-weight: 600; }

  /* ── Usuario chip ── */
  .user-chip { display: inline-flex; align-items: center; gap: .4rem; font-size: .825rem; font-weight: 600; color: var(--navy); }
  .user-avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--blue-pale); color: var(--blue-mid); font-size: .65rem; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; text-transform: uppercase; }

  /* ── Load more ── */
  .load-more { text-align: center; padding: 1.25rem 0; border-top: 1px solid var(--gray-100); }

  /* ── Dark mode ── */
  html.dark .stat-card, html.dark .filters-card, html.dark .table-card {
    background: rgba(20,30,50,0.7); border-color: rgba(255,255,255,0.07);
    box-shadow: 0 4px 20px rgba(0,0,0,0.35);
  }
  html.dark .stat-value { color: #e2e8f0; }
  html.dark .fi { background: rgba(10,15,30,0.6); color: #e2e8f0; border-color: rgba(255,255,255,0.1); }
  html.dark tbody td { border-color: rgba(255,255,255,0.05); color: #cbd5e1; }
  html.dark tbody tr:hover td { background: rgba(37,99,235,0.08); }
  html.dark .table-toolbar { border-color: rgba(255,255,255,0.06); }
  html.dark thead th { background: rgba(10,15,30,0.8); color: #64748b; }
  html.dark .user-chip { color: #e2e8f0; }
  html.dark .user-avatar { background: rgba(37,99,235,0.2); }
  html.dark .btn-clear { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.1); color: #94a3b8; }
  html.dark .load-more { border-color: rgba(255,255,255,0.06); }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .filters-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .filters-grid { grid-template-columns: 1fr; }
    .page-header { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .stats-row { grid-template-columns: 1fr 1fr; }
    .stat-value { font-size: 1.4rem; }
  }
</style>

<div class="audit-page">

  <!-- HEADER -->
  <div class="page-header">
    <h1 class="page-title">🔍 Auditoría del Sistema</h1>
    <div style="display:flex;gap:.65rem;align-items:center;flex-wrap:wrap">
      <button class="btn btn-secondary btn-sm" onclick="exportCSV()">⬇ Exportar CSV</button>
      <button class="btn btn-secondary btn-sm" onclick="reload()">🔄 Actualizar</button>
    </div>
  </div>

  <!-- STAT CARDS -->
  <div class="stats-row">
    <div class="stat-card s-blue">
      <span class="stat-label">Total de registros</span>
      <span class="stat-value" id="statTotal">—</span>
      <span class="stat-sub">en el sistema</span>
    </div>
    <div class="stat-card s-green">
      <span class="stat-label">Hoy</span>
      <span class="stat-value" id="statHoy">—</span>
      <span class="stat-sub">acciones registradas</span>
    </div>
    <div class="stat-card s-amber">
      <span class="stat-label">Usuarios activos</span>
      <span class="stat-value" id="statUsuarios">—</span>
      <span class="stat-sub">con actividad reciente</span>
    </div>
    <div class="stat-card s-red">
      <span class="stat-label">Eliminaciones</span>
      <span class="stat-value" id="statDeletes">—</span>
      <span class="stat-sub">registros borrados</span>
    </div>
  </div>

  <!-- FILTROS -->
  <div class="filters-card">
    <div class="filters-title">🔎 Filtros</div>
    <div class="filters-grid">
      <div class="fi-group">
        <label class="fi-label">Tipo de acción</label>
        <select id="fAccion" class="fi" onchange="applyFilter()">
          <option value="">Todas las acciones</option>
          <option value="LOGIN">Login</option>
          <option value="REGISTER">Registro</option>
          <option value="CREATE_BOOK">Libro creado</option>
          <option value="UPDATE_BOOK">Libro editado</option>
          <option value="DELETE_BOOK">Libro eliminado</option>
          <option value="CREATE_SALE">Venta creada</option>
          <option value="CANCEL_SALE">Venta cancelada</option>
          <option value="CREATE_PURCHASE">Compra creada</option>
          <option value="CANCEL_PURCHASE">Compra cancelada</option>
          <option value="CREATE_EMPLOYEE">Empleado creado</option>
          <option value="UPDATE_EMPLOYEE">Empleado editado</option>
        </select>
      </div>
      <div class="fi-group">
        <label class="fi-label">Tabla / Módulo</label>
        <select id="fTabla" class="fi" onchange="applyFilter()">
          <option value="">Todas las tablas</option>
          <option value="users">Usuarios</option>
          <option value="books">Libros</option>
          <option value="sales">Ventas</option>
          <option value="purchases">Compras</option>
        </select>
      </div>
      <div class="fi-group">
        <label class="fi-label">Buscar usuario</label>
        <input type="text" id="fUsuario" class="fi" placeholder="Nombre del usuario…" oninput="applyFilter()">
      </div>
      <div class="fi-group">
        <label class="fi-label">Desde fecha</label>
        <input type="date" id="fFecha" class="fi" onchange="applyFilter()">
      </div>
      <button class="btn-clear" onclick="clearFilters()">✕ Limpiar</button>
    </div>
  </div>

  <!-- TABLA -->
  <div class="table-card">
    <div class="table-toolbar">
      <span class="total-badge" id="totalBadge">Cargando…</span>
      <span style="font-size:.78rem;color:var(--gray-400)" id="filteredInfo"></span>
    </div>
    <div class="log-wrap">
      <table>
        <thead>
          <tr>
            <th style="width:50px">#</th>
            <th>Fecha y hora</th>
            <th>Usuario</th>
            <th>Acción</th>
            <th>Módulo</th>
            <th>ID Reg.</th>
            <th>Detalle</th>
          </tr>
        </thead>
        <tbody id="logBody">
          <tr class="empty-row"><td colspan="7">Cargando registros…</td></tr>
        </tbody>
      </table>
    </div>
    <div class="load-more" id="loadMoreArea" style="display:none">
      <button class="btn btn-secondary btn-sm" onclick="loadMore()">Cargar más registros</button>
    </div>
  </div>

</div>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';
  const token = localStorage.getItem('token');

  let allLogs: any[] = [];
  let displayedLogs: any[] = [];
  let skip = 0;
  const LIMIT = 100;

  // ── Badge CSS class por acción ──────────────────────────────────────────
  function badgeClass(accion: string): string {
    const a = accion.toLowerCase();
    if (a === 'login') return 'b-login';
    if (a.includes('register')) return 'b-register';
    if (a === 'create_book') return 'b-create_book';
    if (a === 'update_book') return 'b-update_book';
    if (a === 'delete_book') return 'b-delete_book';
    if (a.includes('create_sale')) return 'b-create_sale';
    if (a.includes('cancel_sale')) return 'b-cancel_sale';
    if (a.includes('create_purchase')) return 'b-create_purchase';
    if (a.includes('cancel_purchase')) return 'b-cancel_purchase';
    if (a === 'create_employee') return 'b-create_employee';
    if (a === 'update_employee') return 'b-update_employee';
    return 'b-other';
  }

  function accionLabel(accion: string): string {
    const map: Record<string, string> = {
      LOGIN: 'Inicio sesión',
      REGISTER_CLIENT: 'Registro cliente',
      CREATE_BOOK: 'Libro creado',
      UPDATE_BOOK: 'Libro editado',
      DELETE_BOOK: 'Libro eliminado',
      CREATE_SALE_ONLINE: 'Venta online',
      CREATE_SALE_PRESENCIAL: 'Venta presencial',
      CANCEL_SALE: 'Venta cancelada',
      CREATE_PURCHASE: 'Compra creada',
      CANCEL_PURCHASE: 'Compra cancelada',
      CREATE_EMPLOYEE: 'Empleado creado',
      UPDATE_EMPLOYEE: 'Empleado editado',
    };
    return map[accion] || accion;
  }

  function fmtDate(s: string): string {
    if (!s) return '—';
    const d = new Date(s);
    return d.toLocaleString('es-HN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function initials(nombre: string): string {
    return (nombre || '?').split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
  }

  // ── Renderizar filas ────────────────────────────────────────────────────
  function renderRows(logs: any[]): string {
    if (!logs.length) {
      return '<tr class="empty-row"><td colspan="7">No se encontraron registros con los filtros aplicados</td></tr>';
    }
    return logs.map((l, i) => {
      const det = l.detalle || '—';
      const short = det.length > 60 ? det.substring(0, 60) + '…' : det;
      const hasMore = det.length > 60;
      return `
        <tr>
          <td style="color:var(--gray-400);font-size:.75rem">${l.id}</td>
          <td style="white-space:nowrap;font-size:.8rem">${fmtDate(l.created_at)}</td>
          <td>
            <div class="user-chip">
              <div class="user-avatar">${initials(l.user_nombre || 'S')}</div>
              <span>${l.user_nombre || 'Sistema'}</span>
            </div>
          </td>
          <td><span class="badge ${badgeClass(l.accion)}">${accionLabel(l.accion)}</span></td>
          <td style="font-size:.8rem;color:var(--gray-500)">${l.tabla || '—'}</td>
          <td style="font-size:.8rem;color:var(--gray-400)">${l.registro_id ?? '—'}</td>
          <td>
            <div class="det-wrap">
              <div class="det-text" id="det-${l.id}-short">${short}</div>
              ${hasMore ? `
                <div class="det-text" id="det-${l.id}-full" style="display:none">${det}</div>
                <button class="det-toggle" onclick="toggleDet(${l.id})">Ver más</button>
              ` : ''}
            </div>
          </td>
        </tr>`;
    }).join('');
  }

  (window as any).toggleDet = (id: number) => {
    const s = document.getElementById(`det-${id}-short`);
    const f = document.getElementById(`det-${id}-full`);
    const btn = s?.parentElement?.querySelector('.det-toggle') as HTMLButtonElement;
    if (!s || !f) return;
    const isHidden = f.style.display === 'none';
    s.style.display = isHidden ? 'none' : 'block';
    f.style.display = isHidden ? 'block' : 'none';
    if (btn) btn.textContent = isHidden ? 'Ver menos' : 'Ver más';
  };

  // ── Actualizar estadísticas ─────────────────────────────────────────────
  function updateStats(logs: any[]) {
    const today = new Date().toDateString();
    const hoy = logs.filter(l => l.created_at && new Date(l.created_at).toDateString() === today).length;
    const usuarios = new Set(logs.map(l => l.user_nombre).filter(Boolean)).size;
    const deletes = logs.filter(l => l.accion.includes('DELETE') || l.accion.includes('CANCEL')).length;

    document.getElementById('statHoy')!.textContent = String(hoy);
    document.getElementById('statUsuarios')!.textContent = String(usuarios);
    document.getElementById('statDeletes')!.textContent = String(deletes);
  }

  // ── Aplicar filtros ─────────────────────────────────────────────────────
  function applyFilter() {
    const fa = (document.getElementById('fAccion') as HTMLSelectElement).value.toLowerCase();
    const ft = (document.getElementById('fTabla') as HTMLSelectElement).value.toLowerCase();
    const fu = (document.getElementById('fUsuario') as HTMLInputElement).value.toLowerCase();
    const ff = (document.getElementById('fFecha') as HTMLInputElement).value;

    displayedLogs = allLogs.filter(l => {
      if (fa && !l.accion.toLowerCase().includes(fa)) return false;
      if (ft && (l.tabla || '').toLowerCase() !== ft) return false;
      if (fu && !(l.user_nombre || '').toLowerCase().includes(fu)) return false;
      if (ff) {
        const logDate = l.created_at ? new Date(l.created_at).toISOString().slice(0, 10) : '';
        if (logDate < ff) return false;
      }
      return true;
    });

    document.getElementById('logBody')!.innerHTML = renderRows(displayedLogs);
    const hasFilters = fa || ft || fu || ff;
    document.getElementById('filteredInfo')!.textContent =
      hasFilters ? `Mostrando ${displayedLogs.length} de ${allLogs.length} registros` : '';
  }

  (window as any).clearFilters = () => {
    (document.getElementById('fAccion') as HTMLSelectElement).value = '';
    (document.getElementById('fTabla') as HTMLSelectElement).value = '';
    (document.getElementById('fUsuario') as HTMLInputElement).value = '';
    (document.getElementById('fFecha') as HTMLInputElement).value = '';
    applyFilter();
  };

  // ── Exportar CSV ────────────────────────────────────────────────────────
  (window as any).exportCSV = () => {
    const source = displayedLogs.length ? displayedLogs : allLogs;
    if (!source.length) { alert('No hay registros para exportar.'); return; }
    const headers = ['ID', 'Fecha', 'Usuario', 'Acción', 'Módulo', 'ID Registro', 'Detalle'];
    const rows = source.map(l => [
      l.id,
      fmtDate(l.created_at),
      l.user_nombre || 'Sistema',
      l.accion,
      l.tabla || '',
      l.registro_id ?? '',
      (l.detalle || '').replace(/,/g, ';'),
    ]);
    const csv = [headers, ...rows].map(r => r.join(',')).join('\n');
    const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `auditoria_${new Date().toISOString().slice(0,10)}.csv`;
    a.click();
  };

  // ── Carga de datos ──────────────────────────────────────────────────────
  async function reload() {
    skip = 0; allLogs = [];
    document.getElementById('logBody')!.innerHTML =
      '<tr class="empty-row"><td colspan="7">Cargando registros…</td></tr>';
    document.getElementById('totalBadge')!.textContent = 'Cargando…';
    await loadMore(true);
  }

  (window as any).loadMore = async (first = false) => {
    try {
      const q = new URLSearchParams({ limit: String(LIMIT), skip: String(skip) });
      const res = await fetch(`${API_URL}/audit/logs?${q}`, {
        headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' }
      });
      if (!res.ok) throw new Error(res.status === 401 ? 'Sin autorización' : 'Error al cargar registros');
      const data = await res.json();

      allLogs = first ? data.logs : [...allLogs, ...data.logs];
      skip += data.logs.length;

      document.getElementById('statTotal')!.textContent = data.total.toLocaleString('es-HN');
      document.getElementById('totalBadge')!.textContent = `${data.total.toLocaleString('es-HN')} registros totales`;

      updateStats(allLogs);
      applyFilter();

      document.getElementById('loadMoreArea')!.style.display = skip < data.total ? 'block' : 'none';
    } catch (e: any) {
      document.getElementById('logBody')!.innerHTML =
        `<tr class="empty-row"><td colspan="7" style="color:var(--danger)">⚠ ${e.message}</td></tr>`;
      document.getElementById('totalBadge')!.textContent = 'Error al cargar';
    }
  };

  (window as any).reload = reload;
  reload();
</script>

</DashboardLayout>