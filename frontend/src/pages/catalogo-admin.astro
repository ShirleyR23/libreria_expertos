---
import DashboardLayout from '../layouts/DashboardLayout.astro';

const userStr = Astro.cookies.get('user')?.value;
let user = null;
try { user = userStr ? JSON.parse(userStr) : null; } catch (e) {}
if (!user || (user.role_name !== 'ADMIN' && user.role_name !== 'EMPLEADO')) return Astro.redirect('/login');
---

<DashboardLayout title="Catálogo de Libros" userRole={user.role_name}>
  <!-- TOOLBAR -->
  <div class="cat-toolbar">
    <div class="inv-search-wrap">
      <span class="inv-search-icon">🔍</span>
      <input type="text" id="catSearch" class="inv-search" placeholder="Buscar por título, autor o categoría…">
    </div>
    <select id="catFilter" class="cat-filter-select">
      <option value="">Todas las categorías</option>
    </select>
    <select id="catSort" class="cat-filter-select">
      <option value="default">Ordenar por relevancia</option>
      <option value="name">A–Z</option>
      <option value="price-asc">Precio: menor a mayor</option>
      <option value="price-desc">Precio: mayor a menor</option>
      <option value="stock-asc">Menor stock primero</option>
    </select>
  </div>

  <!-- STATS -->
  <div class="cat-stats">
    <div class="inv-stat-card blue"><div class="inv-stat-num" id="statTotal">—</div><div class="inv-stat-lbl">Total títulos</div></div>
    <div class="inv-stat-card green"><div class="inv-stat-num" id="statDisponibles">—</div><div class="inv-stat-lbl">Disponibles</div></div>
    <div class="inv-stat-card orange"><div class="inv-stat-num" id="statBestsellers">—</div><div class="inv-stat-lbl">Bestsellers</div></div>
    <div class="inv-stat-card red"><div class="inv-stat-num" id="statAgotados">—</div><div class="inv-stat-lbl">Agotados</div></div>
  </div>

  <!-- LOADING -->
  <div id="catLoading" class="cat-loading">
    <div class="loading-spinner"></div>
    <p style="color:var(--gray-400);margin-top:0.75rem">Cargando catálogo…</p>
  </div>

  <!-- GRID -->
  <div id="catGrid" class="cat-grid" style="display:none"></div>

  <!-- EMPTY -->
  <div id="catEmpty" class="cat-empty" style="display:none">
    <div style="font-size:3rem">📭</div>
    <h3>No se encontraron libros</h3>
    <p>Intenta con otros términos o cambia el filtro</p>
  </div>

  <!-- MODAL RESEÑAS -->
  <div id="reviewsModal" class="reviews-modal-overlay" style="display:none">
    <div class="reviews-modal-box">
      <div class="reviews-modal-header">
        <div>
          <h2 id="reviewsModalTitle" class="reviews-modal-title">Reseñas</h2>
          <p id="reviewsModalSub" class="reviews-modal-sub"></p>
        </div>
        <button onclick="document.getElementById('reviewsModal').style.display='none'" class="reviews-modal-close">✕</button>
      </div>
      <div id="reviewsModalBody" class="reviews-modal-body">
        <div class="reviews-loading">Cargando reseñas…</div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script is:inline>
  const API = 'http://localhost:8000/api/v1';
  const BACKEND = 'http://localhost:8000';
  const token = localStorage.getItem('token');
  let allBooks = [];
  let categories = [];

  const CAT_CONFIG = {
    'FICCION':    { color:'#7c3aed', light:'#c4b5fd', icon:'🌙' },
    'NO_FICCION': { color:'#0891b2', light:'#a5f3fc', icon:'📰' },
    'CIENCIA':    { color:'#16a34a', light:'#86efac', icon:'🔬' },
    'TECNOLOGIA': { color:'#2563eb', light:'#93c5fd', icon:'💻' },
    'HISTORIA':   { color:'#b45309', light:'#fcd34d', icon:'🏛️' },
    'ARTE':       { color:'#db2777', light:'#f9a8d4', icon:'🎨' },
    'LITERATURA': { color:'#ea580c', light:'#fdba74', icon:'✒️' },
    'INFANTIL':   { color:'#e11d48', light:'#fda4af', icon:'🦄' },
    'ACADEMICO':  { color:'#4338ca', light:'#a5b4fc', icon:'🎓' },
    'FILOSOFIA':  { color:'#334155', light:'#94a3b8', icon:'🧠' },
  };
  function getCfg(name) {
    const k = (name||'').toUpperCase().replace(/\s/g,'_').replace(/Ó/g,'O').replace(/Í/g,'I').replace(/É/g,'E').replace(/Á/g,'A').replace(/Ú/g,'U');
    return CAT_CONFIG[k] || { color:'#1d4ed8', light:'#93c5fd', icon:'📖' };
  }

  async function loadCatalog() {
    try {
      const [booksRes, catsRes] = await Promise.all([
        fetch(`${API}/books/inventory/all?limit=500`, { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch(`${API}/books/categories`, { headers: { 'Authorization': `Bearer ${token}` } })
      ]);
      if (booksRes.ok) allBooks = await booksRes.json();
      if (catsRes.ok) {
        categories = await catsRes.json();
        const sel = document.getElementById('catFilter');
        categories.forEach(c => {
          const o = document.createElement('option');
          o.value = c.id; o.textContent = c.name;
          sel.appendChild(o);
        });
      }
      renderCatalog();
    } catch(e) {
      document.getElementById('catLoading').innerHTML = '<p style="color:var(--danger);padding:2rem">Error al cargar el catálogo.</p>';
    }
  }

  function getFiltered() {
    const q = document.getElementById('catSearch').value.toLowerCase();
    const cat = document.getElementById('catFilter').value;
    const sort = document.getElementById('catSort').value;
    let books = allBooks.filter(b => {
      const matchQ = !q || `${b.nombre} ${b.autor} ${b.categoria?.name||''}`.toLowerCase().includes(q);
      const matchC = !cat || String(b.categoria_id) === cat || String(b.categoria?.id) === cat;
      return matchQ && matchC;
    });
    if (sort === 'name') books.sort((a,b) => a.nombre.localeCompare(b.nombre));
    else if (sort === 'price-asc') books.sort((a,b) => a.precio - b.precio);
    else if (sort === 'price-desc') books.sort((a,b) => b.precio - a.precio);
    else if (sort === 'stock-asc') books.sort((a,b) => a.stock - b.stock);
    return books;
  }

  function renderCatalog() {
    const books = getFiltered();
    document.getElementById('catLoading').style.display = 'none';

    document.getElementById('statTotal').textContent = allBooks.length;
    document.getElementById('statDisponibles').textContent = allBooks.filter(b => b.stock > 0).length;
    document.getElementById('statBestsellers').textContent = allBooks.filter(b => b.es_bestseller).length;
    document.getElementById('statAgotados').textContent = allBooks.filter(b => b.stock === 0).length;

    if (!books.length) {
      document.getElementById('catGrid').style.display = 'none';
      document.getElementById('catEmpty').style.display = 'flex';
      return;
    }
    document.getElementById('catEmpty').style.display = 'none';
    document.getElementById('catGrid').style.display = 'grid';

    document.getElementById('catGrid').innerHTML = books.map(b => {
      const cfg = getCfg(b.categoria?.name || '');
      const shortTitle = b.nombre.length > 28 ? b.nombre.substring(0,28)+'…' : b.nombre;
      const shortAuthor = (b.autor||'').length > 24 ? b.autor.substring(0,24)+'…' : (b.autor||'');
      const stockClass = b.stock === 0 ? 'stock-out' : b.stock < 5 ? 'stock-low' : 'stock-ok';
      const stockLabel = b.stock === 0 ? '✖ Agotado' : b.stock < 5 ? `⚡ ${b.stock} disp.` : `✔ ${b.stock} disp.`;
      const cover = b.imagen_url
        ? `<img src="${b.imagen_url.startsWith('http') ? b.imagen_url : BACKEND+b.imagen_url}" class="cat-cover-img" loading="lazy" onerror="this.style.display='none';this.nextSibling.style.removeProperty('display')">`
        : '';
      const placeholderStyle = b.imagen_url ? 'display:none' : '';
      const catTag = b.categoria?.name ? `<span class="cat-tag" style="background:${cfg.light}20;color:${cfg.color};border:1px solid ${cfg.light}">${cfg.icon} ${b.categoria.name}</span>` : '';
      const bestseller = b.es_bestseller ? '<span class="badge-bs">⭐ Bestseller</span>' : '';
      const tieneDescuento = !!b.precio_original;
      const precioBase = tieneDescuento ? parseFloat(b.precio_original) : null;
      const discPct = tieneDescuento ? Math.round((1 - parseFloat(b.precio) / precioBase) * 100) : 0;
      const discountBadge = tieneDescuento ? `<div class="cat-discount-badge">-${discPct}%</div>` : '';

      return `<div class="cat-card${tieneDescuento ? ' cat-card-discount' : ''}">
        <div class="cat-cover" style="background:${cfg.light}">
          ${cover}
          <div class="cat-placeholder" style="${placeholderStyle}">
            <span class="cat-ph-icon" style="color:${cfg.color}">${cfg.icon}</span>
            <p class="cat-ph-title" style="color:${cfg.color}">${shortTitle}</p>
            <p class="cat-ph-author" style="color:${cfg.color}">${shortAuthor}</p>
          </div>
          ${bestseller ? `<div class="cat-bestseller-badge">${bestseller}</div>` : ''}
          ${discountBadge}
          ${b.stock === 0 ? '<div class="cat-out-overlay">Agotado</div>' : ''}
        </div>
        <div class="cat-info">
          ${catTag}
          <h3 class="cat-name">${b.nombre}</h3>
          <p class="cat-author">✍️ ${b.autor}</p>
          ${b.editorial ? `<p class="cat-editorial">${b.editorial}${b.anio_publicacion ? ' · '+b.anio_publicacion : ''}</p>` : ''}
          <div class="cat-bottom">
            <div>
              ${tieneDescuento
                ? `<div class="cat-price cat-price-discount">L ${parseFloat(b.precio).toFixed(2)} <span class="cat-price-orig">L ${precioBase.toFixed(2)}</span></div>`
                : `<div class="cat-price">L ${parseFloat(b.precio).toFixed(2)}</div>`
              }
              <div class="cat-stock ${stockClass}">${stockLabel}</div>
            </div>
            <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end">
              <button class="btn-review-book" onclick="event.stopPropagation();openReviews(${b.id},'${b.nombre.replace(/'/g,"\\'")}')">⭐ Reseñas</button>
              <a href="/inventario" class="btn-edit-book" title="Editar en inventario">✏️</a>
            </div>
          </div>
        </div>
      </div>`;
    }).join('');;
  }

  ['catSearch','catFilter','catSort'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', renderCatalog);
    document.getElementById(id)?.addEventListener('change', renderCatalog);
  });

  async function openReviews(bookId, bookName) {
    const modal = document.getElementById('reviewsModal');
    const body  = document.getElementById('reviewsModalBody');
    document.getElementById('reviewsModalTitle').textContent = `Reseñas: ${bookName}`;
    document.getElementById('reviewsModalSub').textContent = '';
    body.innerHTML = '<div class="reviews-loading">Cargando reseñas…</div>';
    modal.style.display = 'flex';
    try {
      const [revRes, sumRes] = await Promise.all([
        fetch(`${API}/reviews/book/${bookId}`),
        fetch(`${API}/reviews/book/${bookId}/summary`)
      ]);
      const reviews = revRes.ok ? await revRes.json() : [];
      const summary = sumRes.ok ? await sumRes.json() : { promedio: 0, total_resenas: 0 };
      document.getElementById('reviewsModalSub').textContent =
        summary.total_resenas > 0
          ? `⭐ ${parseFloat(summary.promedio).toFixed(1)} · ${summary.total_resenas} reseña${summary.total_resenas !== 1 ? 's' : ''}`
          : 'Sin reseñas todavía';
      if (!reviews.length) {
        body.innerHTML = '<div class="reviews-empty"><span style="font-size:2.5rem">📭</span><p>Este libro aún no tiene reseñas.</p></div>';
        return;
      }
      body.innerHTML = reviews.map(rv => {
        const stars = '★'.repeat(rv.calificacion) + '☆'.repeat(5 - rv.calificacion);
        return `<div class="review-item">
          <div class="review-item-top">
            <span class="review-stars">${stars}</span>
            <span class="review-date">${new Date(rv.fecha_creacion || rv.created_at || '').toLocaleDateString('es-HN')}</span>
          </div>
          ${rv.titulo ? `<div class="review-titulo">${rv.titulo}</div>` : ''}
          ${rv.cuerpo  ? `<div class="review-cuerpo">${rv.cuerpo}</div>`  : ''}
          <div class="review-author">— ${rv.usuario_nombre || rv.usuario?.nombre || 'Cliente'}</div>
        </div>`;
      }).join('');
    } catch(e) {
      body.innerHTML = '<div class="reviews-empty" style="color:var(--danger)">Error al cargar reseñas.</div>';
    }
  }
  window.openReviews = openReviews;

  loadCatalog();
</script>

<style is:global>
  .cat-toolbar { display:flex; align-items:center; gap:0.75rem; margin-bottom:1.5rem; flex-wrap:wrap; }
  .inv-search-wrap { position:relative; flex:1; min-width:220px; }
  .inv-search-icon { position:absolute; left:0.875rem; top:50%; transform:translateY(-50%); }
  .inv-search { width:100%; padding:0.6rem 0.875rem 0.6rem 2.5rem; border:2px solid var(--gray-200); border-radius:var(--radius-sm); font-family:inherit; font-size:0.9rem; background:var(--bg-card); }
  .inv-search:focus { outline:none; border-color:var(--blue-mid); }
  .cat-filter-select { padding:0.6rem 0.875rem; border:2px solid var(--gray-200); border-radius:var(--radius-sm); font-family:inherit; font-size:0.875rem; background:var(--bg-card); cursor:pointer; }
  .cat-filter-select:focus { outline:none; border-color:var(--blue-mid); }

  .cat-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:1.5rem; }
  .inv-stat-card { padding:1.25rem 1.5rem; background:var(--bg-card); border-radius:var(--radius); border:1px solid rgba(13,27,46,0.08); box-shadow:0 2px 12px rgba(13,27,46,0.08); }
  .inv-stat-num { font-size:1.75rem; font-weight:700; font-family:var(--font-display); }
  .inv-stat-lbl { font-size:0.8rem; color:var(--gray-400); margin-top:2px; }
  .inv-stat-card.blue .inv-stat-num { color:var(--blue-mid); }
  .inv-stat-card.green .inv-stat-num { color:var(--success); }
  .inv-stat-card.orange .inv-stat-num { color:var(--warning); }
  .inv-stat-card.red .inv-stat-num { color:var(--danger); }
  @media(max-width:768px) { .cat-stats { grid-template-columns:repeat(2,1fr); } }

  .cat-loading { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5rem 2rem; }
  @keyframes spin { to { transform:rotate(360deg); } }
  .loading-spinner { width:44px; height:44px; border:3px solid var(--gray-200); border-top-color:var(--blue-mid); border-radius:50%; animation:spin 0.8s linear infinite; }

  .cat-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(210px,1fr)); gap:1.5rem; }

  .cat-card { background:var(--bg-card); border-radius:var(--radius); overflow:hidden; box-shadow:0 2px 14px rgba(13,27,46,0.10); border:1px solid rgba(13,27,46,0.07); transition:all 0.3s cubic-bezier(0.25,0.8,0.25,1); display:flex; flex-direction:column; }
  .cat-card:hover { transform:translateY(-4px); box-shadow:0 10px 32px rgba(13,27,46,0.16); border-color:transparent; }

  .cat-cover { position:relative; height:180px; overflow:hidden; flex-shrink:0; }
  .cat-cover-img { width:100%; height:100%; object-fit:contain; display:block; transition:transform 0.4s; }
  .cat-card:hover .cat-cover-img { transform:scale(1.04); }
  .cat-placeholder { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.35rem; padding:0.75rem; transition:transform 0.4s; }
  .cat-card:hover .cat-placeholder { transform:scale(1.04); }
  .cat-ph-icon { font-size:3rem; filter:drop-shadow(0 4px 8px rgba(0,0,0,0.12)); animation:ph-float 3s ease-in-out infinite; }
  @keyframes ph-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  .cat-ph-title { font-size:0.7rem; font-weight:700; text-align:center; line-height:1.3; max-width:90%; }
  .cat-ph-author { font-size:0.62rem; opacity:0.75; text-align:center; max-width:90%; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .cat-bestseller-badge { position:absolute; top:8px; left:8px; }
  .badge-bs { background:linear-gradient(135deg,#f59e0b,#d97706); color:white; padding:2px 8px; border-radius:999px; font-size:0.65rem; font-weight:700; box-shadow:0 2px 6px rgba(245,158,11,0.4); }
  .cat-discount-badge { position:absolute; bottom:8px; left:8px; background:linear-gradient(135deg,#dc2626,#991b1b); color:white; padding:4px 10px; border-radius:999px; font-size:0.72rem; font-weight:800; box-shadow:0 2px 8px rgba(220,38,38,0.45); z-index:2; letter-spacing:0.02em; }
  .cat-card-discount .cat-price { color:#dc2626 !important; }
  .cat-price-orig { font-size:0.75rem; color:#94a3b8; text-decoration:line-through; margin-left:3px; font-weight:400; }
  .cat-out-overlay { position:absolute; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:0.9rem; }

  .cat-info { padding:0.875rem 1rem 1rem; flex:1; display:flex; flex-direction:column; gap:0.3rem; }
  .cat-tag { display:inline-block; padding:2px 8px; border-radius:999px; font-size:0.65rem; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; margin-bottom:0.15rem; }
  .cat-name { font-family:var(--font-display); font-size:0.9rem; font-weight:700; color:var(--navy); line-height:1.35; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
  .cat-author { font-size:0.75rem; color:var(--gray-400); }
  .cat-editorial { font-size:0.7rem; color:var(--gray-400); }
  .cat-bottom { display:flex; align-items:flex-end; justify-content:space-between; margin-top:auto; padding-top:0.6rem; border-top:1px solid var(--gray-100); }
  .cat-price { font-size:1rem; font-weight:700; color:var(--blue-mid); }
  .cat-stock { font-size:0.7rem; font-weight:600; margin-top:1px; }
  .cat-stock.stock-ok { color:#16a34a; }
  .cat-stock.stock-low { color:#d97706; }
  .cat-stock.stock-out { color:#dc2626; }
  .btn-edit-book { width:30px; height:30px; border-radius:50%; background:var(--blue-ghost); display:flex; align-items:center; justify-content:center; font-size:0.8rem; text-decoration:none; transition:all 0.2s; flex-shrink:0; border:1px solid var(--blue-pale); }
  .btn-edit-book:hover { background:var(--blue-pale); transform:scale(1.1); }
  .btn-review-book { padding:3px 9px; border-radius:999px; background:#fef9c3; color:#92400e; border:1px solid #fde68a; font-size:0.65rem; font-weight:700; cursor:pointer; font-family:inherit; transition:all .15s; white-space:nowrap; }
  .btn-review-book:hover { background:#fde68a; }

  /* Reviews modal */
  .reviews-modal-overlay { position:fixed; inset:0; background:rgba(13,27,46,.65); backdrop-filter:blur(4px); z-index:9000; display:flex; align-items:center; justify-content:center; padding:1rem; }
  .reviews-modal-box { background:white; border-radius:var(--radius-lg); box-shadow:0 20px 60px rgba(0,0,0,.25); width:100%; max-width:600px; max-height:85vh; display:flex; flex-direction:column; overflow:hidden; animation:rmSlide .22s ease; }
  @keyframes rmSlide { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }
  .reviews-modal-header { display:flex; align-items:flex-start; justify-content:space-between; padding:1.25rem 1.5rem; border-bottom:1px solid var(--gray-100); flex-shrink:0; gap:1rem; }
  .reviews-modal-title { font-family:var(--font-display); font-size:1.15rem; font-weight:700; color:var(--navy); line-height:1.3; }
  .reviews-modal-sub { font-size:.82rem; color:var(--gray-400); margin-top:3px; }
  .reviews-modal-close { width:32px; height:32px; border-radius:50%; background:var(--gray-100); border:none; cursor:pointer; font-size:.8rem; flex-shrink:0; }
  .reviews-modal-body { overflow-y:auto; flex:1; padding:1.25rem 1.5rem; display:flex; flex-direction:column; gap:.875rem; }
  .reviews-loading { text-align:center; padding:2rem; color:var(--gray-400); }
  .reviews-empty { text-align:center; padding:2.5rem 1rem; color:var(--gray-400); display:flex; flex-direction:column; align-items:center; gap:.5rem; }
  .review-item { background:var(--gray-50); border:1px solid var(--gray-100); border-radius:10px; padding:1rem; }
  .review-item-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:.4rem; }
  .review-stars { color:#f59e0b; font-size:1rem; letter-spacing:1px; }
  .review-date { font-size:.72rem; color:var(--gray-400); }
  .review-titulo { font-weight:700; font-size:.88rem; color:var(--navy); margin-bottom:.25rem; }
  .review-cuerpo { font-size:.85rem; color:var(--gray-600); line-height:1.55; }
  .review-author { font-size:.75rem; color:var(--gray-400); font-style:italic; margin-top:.4rem; }

  /* Dark mode for reviews modal */
  html.dark .reviews-modal-box { background:#0f172a; border:1px solid rgba(255,255,255,.1); }
  html.dark .reviews-modal-title { color:#f1f5f9; }
  html.dark .reviews-modal-sub { color:#64748b; }
  html.dark .reviews-modal-header { border-color:rgba(255,255,255,.08); }
  html.dark .reviews-modal-close { background:rgba(255,255,255,.1); color:#94a3b8; }
  html.dark .review-item { background:rgba(255,255,255,.05); border-color:rgba(255,255,255,.08); }
  html.dark .review-titulo { color:#e2e8f0; }
  html.dark .review-cuerpo { color:#94a3b8; }
  html.dark .review-author { color:#475569; }
  html.dark .btn-review-book { background:rgba(245,158,11,.15); color:#fcd34d; border-color:rgba(245,158,11,.25); }
  html.dark .btn-review-book:hover { background:rgba(245,158,11,.28); }

  .cat-empty { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5rem 2rem; text-align:center; gap:0.75rem; background:var(--bg-card); border-radius:var(--radius); border:1px solid rgba(13,27,46,0.08); }
  .cat-empty h3 { font-family:var(--font-display); font-size:1.25rem; color:var(--navy); }
  .cat-empty p { color:var(--gray-400); }

  /* ══ PAGE-LEVEL DARK MODE + LIQUID GLASS + RESPONSIVE ══════════════════ */

  /* -- Liquid Glass base (claro y oscuro) -- */
  .glass-card {
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(18px) saturate(180%);
