---
import PublicLayout from '../layouts/PublicLayout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';
const token = Astro.cookies.get('token')?.value;
const userStr = Astro.cookies.get('user')?.value;
let user = null;
try { user = userStr ? JSON.parse(decodeURIComponent(userStr)) : null; } catch (e) {}
const isCliente = user?.role_name === 'CLIENTE';
const dashboardUrl = user?.role_name === 'ADMIN' ? '/dashboard-admin' : user?.role_name === 'EMPLEADO' ? '/dashboard-empleado' : '/mis-compras';
---

<PublicLayout title="Catálogo de Libros">

  <!-- NAV -->
  <nav class="top-nav">
    <div class="nav-inner">
      <a href="/catalogo" class="brand">
        <img src="/honduletras-logo-dark.svg" alt="HonduLetras" class="brand-logo-img">
      </a>
      <div class="nav-actions">
        {isCliente ? (
          <a href="/carrito" class="cart-nav-btn" id="cartNavBtn" title="Ver carrito">
            🛒
            <span class="cart-nav-badge" id="cartNavBadge" style="display:none">0</span>
          </a>
        ) : (
          <button type="button" class="cart-nav-btn" id="cartNavBtn" title="Ver carrito" onclick="document.getElementById('loginRequiredModal').style.display='flex'">
            🛒
          </button>
        )}
        {user ? (
          <>
            <span class="nav-greeting">Hola, <strong>{user.nombre}</strong></span>
            <a href={dashboardUrl} class="btn btn-sm btn-outline-nav">Mi cuenta</a>
            <button id="logoutBtn" class="btn btn-sm btn-ghost-nav">Salir</button>
          </>
        ) : (
          <>
            <a href="/login" class="btn btn-sm btn-ghost-nav">Iniciar sesión</a>
            <a href="/register" class="btn btn-sm btn-primary">Registrarse</a>
          </>
        )}
        <button id="darkToggleCatalog" onclick="window.toggleDark()" class="dark-toggle-nav" title="Cambiar tema">🌙</button>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero-section">
    <div class="hero-content">
      <p class="hero-eyebrow">Bienvenido a nuestra colección</p>
      <h1 class="hero-title">Catálogo de <span class="hero-accent">Libros</span></h1>
      <p class="hero-sub">Explora nuestra selección de títulos cuidadosamente organizados para ti</p>
      <div class="hero-search">
        <div class="search-wrap">
          <span class="search-icon">🔍</span>
          <input type="text" id="searchInput" class="search-input" placeholder="Buscar por título, autor o ISBN…">
          <button id="clearSearch" class="search-clear" style="display:none">✕</button>
        </div>
        <select id="categorySelect" class="category-select">
          <option value="">Todas las categorías</option>
          <option value="__bestsellers__">⭐ Bestsellers</option>
        </select>
      </div>
    </div>
    <div class="hero-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>
  </header>

  <!-- MAIN -->
  <main class="main-wrap">

    <!-- STATS BAR -->
    <div class="stats-bar">
      <div class="stats-inner">
        <div class="stat-item">
          <span class="stat-icon">📖</span>
          <span id="totalCount" class="stat-num">—</span>
          <span class="stat-lbl">libros disponibles</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-icon">⭐</span>
          <span id="bestsellerCount" class="stat-num">—</span>
          <span class="stat-lbl">bestsellers</span>
        </div>
        <div class="stat-item" id="searchResultStat" style="display:none">
          <div class="stat-divider"></div>
          <span class="stat-icon">🔎</span>
          <span id="searchResultCount" class="stat-num">—</span>
          <span class="stat-lbl">resultados</span>
        </div>
      </div>
    </div>

    <!-- FILTER PILLS -->
    <div id="filterPills" class="filter-pills" style="display:none"></div>

    <!-- TOOLBAR -->
    <div class="toolbar">
      <div class="sort-group">
        <label class="sort-label">Ordenar:</label>
        <select id="sortSelect" class="sort-select">
          <option value="default">Relevancia</option>
          <option value="price-asc">Precio: menor a mayor</option>
          <option value="price-desc">Precio: mayor a menor</option>
          <option value="name-asc">Nombre A-Z</option>
          <option value="bestseller">Más vendidos primero</option>
        </select>
      </div>
    </div>

    <!-- SKELETON (cargando) -->
    <div id="skeletonGrid" class="books-grid">
      {Array.from({length: 12}).map(() => (
        <div class="book-skeleton">
          <div class="skeleton sk-img"></div>
          <div class="sk-body">
            <div class="skeleton sk-badge"></div>
            <div class="skeleton sk-title"></div>
            <div class="skeleton sk-title sk-short"></div>
            <div class="skeleton sk-author"></div>
            <div class="skeleton sk-price"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- BOOKS GRID -->
    <div id="booksGrid" class="books-grid" style="display:none"></div>

    <!-- EMPTY STATE -->
    <div id="emptyState" class="empty-state" style="display:none">
      <div class="empty-illustration">📭</div>
      <h3 class="empty-title">No se encontraron libros</h3>
      <p class="empty-desc">Intenta con otros términos o elimina los filtros activos.</p>
      <button onclick="clearAllFilters()" class="btn btn-primary">Limpiar filtros</button>
    </div>

    <!-- ERROR STATE -->
    <div id="errorState" class="error-state" style="display:none">
      <div class="empty-illustration">⚠️</div>
      <h3 class="empty-title">Error al cargar el catálogo</h3>
      <p class="empty-desc">No se pudo conectar con el servidor. Verifica que el backend esté activo.</p>
      <button onclick="loadBooks()" class="btn btn-primary">Reintentar</button>
    </div>

    <!-- INFINITE SCROLL SENTINEL + LOADER -->
    <div id="scrollSentinel" style="height:10px;margin-top:1rem;"></div>
    <div id="scrollLoader" class="scroll-loader" style="display:none">
      <div class="scroll-spinner"></div>
      <span>Cargando más libros…</span>
    </div>
    <div id="loadMoreWrap" style="display:none;justify-content:center;margin:1.5rem 0">
      <button id="loadMoreBtn" class="btn btn-secondary" onclick="triggerLoadMore()">Ver más libros</button>
    </div>
  </main>

  <!-- PDF PREVIEW MODAL -->
  <!-- ═══ REVIEW MODAL ═══════════════════════════════════════════════════ -->
  <!-- MODAL: Ver reseñas (solo lectura, abierto desde botón ⭐ Reseñas) -->
  <div id="viewReviewsModal" style="display:none;position:fixed;inset:0;background:rgba(13,27,46,.65);backdrop-filter:blur(4px);z-index:9200;align-items:center;justify-content:center;padding:1rem">
    <div class="vr-box">
      <div class="vr-header">
        <div>
          <h2 class="vr-title" id="vrTitle">Reseñas</h2>
          <p class="vr-sub" id="vrSub"></p>
        </div>
        <button class="vr-close" onclick="document.getElementById('viewReviewsModal').style.display='none'">✕</button>
      </div>
      <div class="vr-body" id="vrBody">
        <div class="vr-loading">Cargando reseñas…</div>
      </div>
    </div>
  </div>

  <div id="reviewModal" style="display:none;position:fixed;inset:0;background:rgba(13,27,46,.65);z-index:9100;align-items:center;justify-content:center;padding:1rem">
    <div class="review-modal-inner" style="border-radius:var(--radius-lg);padding:2rem;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;animation:slideUp .25s ease">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
        <h2 style="font-family:var(--font-display);font-size:1.3rem;color:var(--navy)" id="reviewBookTitle">Reseña</h2>
        <button id="closeReviewModal" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--gray-600)">✕</button>
      </div>
      <div id="reviewSummary"></div>
      <div id="reviewAlert"></div>
      <!-- Write review -->
      <div style="background:var(--gray-50);border-radius:var(--radius-sm);padding:1rem;margin-bottom:1rem">
        <p style="font-size:.82rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.5rem">Tu calificación</p>
        <div id="reviewStarsPicker" style="display:flex;gap:6px;font-size:1.8rem;cursor:pointer;margin-bottom:.75rem">
          <span class="rv-star" data-v="1" style="color:#d1d5db">★</span>
          <span class="rv-star" data-v="2" style="color:#d1d5db">★</span>
          <span class="rv-star" data-v="3" style="color:#d1d5db">★</span>
          <span class="rv-star" data-v="4" style="color:#d1d5db">★</span>
          <span class="rv-star" data-v="5" style="color:#d1d5db">★</span>
        </div>
        <input type="hidden" id="reviewEditId">
        <input type="text" id="reviewTitulo" placeholder="Título de la reseña (opcional)"
          style="width:100%;padding:.6rem .875rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-sm);font-family:var(--font-body);font-size:.9rem;margin-bottom:.6rem">
        <textarea id="reviewComentario" placeholder="Escribe tu opinión sobre este libro…" rows="3"
          style="width:100%;padding:.6rem .875rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-sm);font-family:var(--font-body);font-size:.9rem;resize:vertical"></textarea>
        <button id="reviewSubmitBtn" class="btn btn-primary" style="width:100%;margin-top:.75rem">✅ Publicar reseña</button>
      </div>
      <!-- Existing reviews -->
      <p style="font-size:.82rem;font-weight:600;color:var(--gray-600);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.5rem">Reseñas de otros lectores</p>
      <div id="reviewList"></div>
    </div>
  </div>

  <div id="pdfPreviewModal" class="pdf-prev-overlay" style="display:none">
    <div class="pdf-prev-box">
      <div class="pdf-prev-topbar">
        <div class="pdf-prev-meta">
          <div id="prevBookTitle" class="pdf-prev-title">—</div>
          <div id="prevBookAuthor" class="pdf-prev-author">—</div>
        </div>
        <div class="pdf-prev-controls">
          <button id="prevPdfPrev" class="pdf-prev-nav" disabled>‹</button>
          <span class="pdf-prev-page"><span id="prevCurrentPage">1</span> / <span id="prevTotalPages">—</span></span>
          <button id="nextPdfPrev" class="pdf-prev-nav">›</button>
        </div>
        <div style="display:flex;align-items:center;gap:0.5rem">
          <span class="pdf-prev-lock">🔒 Vista previa</span>
          <button id="closePdfPreview" class="pdf-prev-close">✕</button>
        </div>
      </div>
      <div class="pdf-prev-canvas-wrap" id="prevCanvasWrap">
        <div id="prevLoading" class="pdf-prev-loading">
          <div class="pdf-prev-spinner"></div>
          <p>Cargando vista previa…</p>
        </div>
        <canvas id="prevCanvas" style="display:none"></canvas>
        <div id="prevBlurGate" class="pdf-prev-blur-gate" style="display:none">
          <div class="pdf-prev-blur-content">
            <div class="pdf-prev-lock-icon">🔒</div>
            <h3>Contenido bloqueado</h3>
            <p>Esta es una vista previa. Compra el libro para leer el contenido completo.</p>
            <button class="btn btn-primary" onclick="document.getElementById('pdfPreviewModal').style.display='none'">Ver en catálogo</button>
          </div>
        </div>
      </div>
    </div>
    <div class="pdf-prev-drm"></div>
  </div>

  <!-- BUY MODAL -->
  <div id="buyModal" class="buy-modal-overlay" style="display:none">
    <div class="buy-modal-box">
      <div class="buy-modal-header">
        <h2 class="buy-modal-title">Confirmar compra</h2>
        <button id="closeBuyModal" class="buy-modal-close">✕</button>
      </div>
      <div class="buy-modal-body">
        <div id="buyBookInfo"></div>

        <div class="buy-section-title">Método de pago</div>
        <div class="pay-method-grid">
          <label class="pay-method-opt">
            <input type="radio" name="payMethod" value="tarjeta" checked>
            <span class="pay-method-card">💳 Tarjeta</span>
          </label>
        </div>

        <div id="cardFields" style="display:block" class="card-fields-wrap">
          <div class="form-group" style="margin-bottom:0.5rem">
            <label class="form-label" style="font-size:0.78rem">Número de tarjeta</label>
            <input type="text" id="cardNumber" class="form-input" maxlength="19" placeholder="1234 5678 9012 3456" autocomplete="cc-number">
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem">
            <div class="form-group" style="margin-bottom:0">
              <label class="form-label" style="font-size:0.78rem">Vencimiento</label>
              <input type="text" id="cardExpiry" class="form-input" maxlength="5" placeholder="MM/AA" autocomplete="cc-exp">
            </div>
            <div class="form-group" style="margin-bottom:0">
              <label class="form-label" style="font-size:0.78rem">CVV</label>
              <input type="text" id="cardCvv" class="form-input" maxlength="4" placeholder="123" autocomplete="cc-csc">
            </div>
          </div>
        </div>

        <div class="form-group" style="margin-top:0.75rem;margin-bottom:0">
          <label class="form-label" style="font-size:0.78rem">RTN del cliente <span style="color:var(--gray-400);font-weight:400">(opcional — para factura fiscal)</span></label>
          <input type="text" id="buyRtn" class="form-input" placeholder="0000-0000-000000" maxlength="20">
        </div>

        <div class="buy-price-breakdown" style="margin-top:0.75rem;border-top:1px solid var(--gray-200);padding-top:0.75rem">
          <div class="buy-breakdown-row">
            <span>Subtotal</span>
            <span id="buySubtotal">L 0.00</span>
          </div>
          <div class="buy-breakdown-row muted">
            <span>ISV (15%)</span>
            <span id="buyIsv">L 0.00</span>
          </div>
          <div class="buy-breakdown-row grand">
            <span>Total a pagar</span>
            <span id="buyTotal" class="buy-total-amount">L 0.00</span>
          </div>
        </div>
      </div>
      <div class="buy-modal-footer">
        <button id="cancelBuyBtn" class="btn btn-secondary">Cancelar</button>
        <button id="confirmBuyBtn" class="btn btn-primary">🛒 Confirmar compra</button>
      </div>
    </div>
  </div>

  <!-- ===== MODAL: Login requerido para carrito ===== -->
  <div id="loginRequiredModal" style="display:none" class="lrm-overlay" role="dialog" aria-modal="true" aria-labelledby="lrmTitle">
    <div class="lrm-box">
      <div class="lrm-icon">🛒</div>
      <h2 class="lrm-title" id="lrmTitle">Tu carrito te está esperando</h2>
      <p class="lrm-body">
        Para agregar libros al carrito y realizar compras necesitas tener una cuenta.<br>
        Es gratis, rápido y te da acceso a tu biblioteca digital personal.
      </p>
      <div class="lrm-actions">
        <a href="/login" class="lrm-btn lrm-btn-primary">
          <span>👤</span> Iniciar sesión
        </a>
        <a href="/register" class="lrm-btn lrm-btn-secondary">
          <span>✨</span> Crear cuenta gratis
        </a>
      </div>
      <button class="lrm-close" onclick="document.getElementById('loginRequiredModal').style.display='none'" aria-label="Cerrar">✕</button>
    </div>
  </div>


</PublicLayout>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" is:inline></script>

<script is:inline define:vars={{ API_URL, isCliente, token }}>
  // PDF.js worker
  if (window.pdfjsLib) {
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
  }
  const BACKEND = API_URL || 'http://localhost:8000/api/v1';
  const BACKEND_BASE = 'http://localhost:8000';
  let allBooks = [];
  let categories = [];
  let showOnlyBestsellers = false;
  let currentSearch = '';
  let currentCategory = '';
  let currentSort = 'default';
  let buyBook = null;

  // Advanced filters state
  let advFilters = { priceMin: null, priceMax: null, yearMin: null, yearMax: null, editorial: '', discount: false, pdf: false, stock: false };
  let advOpen = false;

  // Infinite scroll state
  const PAGE_SIZE = 48;
  let visibleCount = PAGE_SIZE;
  let filteredBooks = [];
  let isLoadingMore = false;

  // ============================================================
  // CATEGORY CONFIG — colores e iconos
  // ============================================================
  const CAT_CONFIG = {
    'FICCION':     { color: '#7c3aed', bg: '#f5f3ff', light: '#c4b5fd', icon: '🌙', label: 'Ficción' },
    'NO_FICCION':  { color: '#0891b2', bg: '#ecfeff', light: '#a5f3fc', icon: '📰', label: 'No Ficción' },
    'CIENCIA':     { color: '#16a34a', bg: '#f0fdf4', light: '#86efac', icon: '🔬', label: 'Ciencia' },
    'TECNOLOGIA':  { color: '#2563eb', bg: '#eff6ff', light: '#93c5fd', icon: '💻', label: 'Tecnología' },
    'HISTORIA':    { color: '#b45309', bg: '#fffbeb', light: '#fcd34d', icon: '🏛️', label: 'Historia' },
    'ARTE':        { color: '#db2777', bg: '#fdf2f8', light: '#f9a8d4', icon: '🎨', label: 'Arte' },
    'LITERATURA':  { color: '#ea580c', bg: '#fff7ed', light: '#fdba74', icon: '✒️', label: 'Literatura' },
    'INFANTIL':    { color: '#e11d48', bg: '#fff1f2', light: '#fda4af', icon: '🦄', label: 'Infantil' },
    'ACADEMICO':   { color: '#4338ca', bg: '#eef2ff', light: '#a5b4fc', icon: '🎓', label: 'Académico' },
    'FILOSOFIA':   { color: '#334155', bg: '#f8fafc', light: '#94a3b8', icon: '🧠', label: 'Filosofía' },
  };

  function getCatKey(name) {
    return (name || '').toUpperCase()
      .replace(/Ó/g,'O').replace(/Í/g,'I').replace(/É/g,'E').replace(/Á/g,'A').replace(/Ú/g,'U')
      .replace(/\s+/g,'_').replace(/-/g,'_');
  }
  function getCfg(name) {
    return CAT_CONFIG[getCatKey(name)] || { color:'#1d4ed8', bg:'#eff6ff', light:'#bfdbfe', icon:'📖', label: name || '' };
  }

  // ============================================================
  // INIT
  // ============================================================
  // Set of book IDs the client has already purchased
  window._purchasedIds = new Set();

  async function init() {
    if (isCliente && token) {
      try {
        const r = await fetch(`${BACKEND}/sales/my-books`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if (r.ok) {
          const books = await r.json();
          books.forEach(b => window._purchasedIds.add(b.id));
        }
      } catch {}
    }
    await Promise.all([loadCategories(), loadBooks()]);
    loadRatings();   // fire-and-forget, updates cards when ready
    setupSearch();
    setupAdvancedFilters();
    setupInfiniteScroll();
  }

  async function loadCategories() {
    try {
      const r = await fetch(`${BACKEND}/books/categories`);
      if (r.ok) {
        categories = await r.json();
        const sel = document.getElementById('categorySelect');
        categories.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id;
          const cfg = getCfg(c.name);
          opt.textContent = `${cfg.icon} ${c.name}`;
          sel.appendChild(opt);
        });
      }
    } catch(e) {}
  }

  async function loadBooks(search, categoryId) {
    search = search ?? currentSearch;
    categoryId = categoryId ?? currentCategory;
    showSkeleton();
    visibleCount = PAGE_SIZE;
    try {
      const params = new URLSearchParams({ limit: 200 });
      if (search) params.append('search', search);
      if (categoryId) params.append('categoria_id', categoryId);
      const r = await fetch(`${BACKEND}/books/catalog?${params}`);
      if (!r.ok) throw new Error();
      allBooks = await r.json();
      updateStats();
      renderBooks();
    } catch(e) {
      showError();
    }
  }

  function applyAdvancedFilters(books) {
    return books.filter(b => {
      const price = parseFloat(b.precio);
      if (advFilters.priceMin !== null && price < advFilters.priceMin) return false;
      if (advFilters.priceMax !== null && price > advFilters.priceMax) return false;
      if (advFilters.yearMin && b.anio_publicacion && b.anio_publicacion < advFilters.yearMin) return false;
      if (advFilters.yearMax && b.anio_publicacion && b.anio_publicacion > advFilters.yearMax) return false;
      if (advFilters.editorial && !(b.editorial || '').toLowerCase().includes(advFilters.editorial.toLowerCase())) return false;
      if (advFilters.discount && !b.precio_original) return false;
      if (advFilters.pdf && !b.has_pdf) return false;
      if (advFilters.stock && b.stock <= 0) return false;
      return true;
    });
  }

  function countActiveAdvFilters() {
    let n = 0;
    if (advFilters.priceMin !== null) n++;
    if (advFilters.priceMax !== null) n++;
    if (advFilters.yearMin) n++;
    if (advFilters.yearMax) n++;
    if (advFilters.editorial) n++;
    if (advFilters.discount) n++;
    if (advFilters.pdf) n++;
    if (advFilters.stock) n++;
    return n;
  }

  function setupAdvancedFilters() {
    document.getElementById('toggleAdvBtn').addEventListener('click', () => {
      advOpen = !advOpen;
      document.getElementById('advFiltersPanel').style.display = advOpen ? 'block' : 'none';
      document.getElementById('advChevron').textContent = advOpen ? '▲' : '▼';
    });
    document.getElementById('applyAdvBtn').addEventListener('click', () => {
      advFilters.priceMin = parseFloat(document.getElementById('priceMin').value) || null;
      advFilters.priceMax = parseFloat(document.getElementById('priceMax').value) || null;
      advFilters.yearMin = parseInt(document.getElementById('yearMin').value) || null;
      advFilters.yearMax = parseInt(document.getElementById('yearMax').value) || null;
      advFilters.editorial = document.getElementById('editorialFilter').value.trim();
      advFilters.discount = document.getElementById('filterDiscount').checked;
      advFilters.pdf = document.getElementById('filterPdf').checked;
      advFilters.stock = document.getElementById('filterStock').checked;
      const cnt = countActiveAdvFilters();
      const cntEl = document.getElementById('advFilterCount');
      if (cnt > 0) { cntEl.textContent = cnt; cntEl.style.display = 'inline-flex'; }
      else { cntEl.style.display = 'none'; }
      visibleCount = PAGE_SIZE;
      renderBooks();
    });
    document.getElementById('clearAdvBtn').addEventListener('click', () => {
      advFilters = { priceMin: null, priceMax: null, yearMin: null, yearMax: null, editorial: '', discount: false, pdf: false, stock: false };
      document.getElementById('priceMin').value = '';
      document.getElementById('priceMax').value = '';
      document.getElementById('yearMin').value = '';
      document.getElementById('yearMax').value = '';
      document.getElementById('editorialFilter').value = '';
      document.getElementById('filterDiscount').checked = false;
      document.getElementById('filterPdf').checked = false;
      document.getElementById('filterStock').checked = false;
      document.getElementById('advFilterCount').style.display = 'none';
      visibleCount = PAGE_SIZE;
      renderBooks();
    });
  }

  function triggerLoadMore() {
    if (isLoadingMore || visibleCount >= filteredBooks.length) return;
    isLoadingMore = true;
    const loader = document.getElementById('scrollLoader');
    if (loader) loader.style.display = 'flex';
    setTimeout(() => {
      visibleCount = Math.min(visibleCount + PAGE_SIZE, filteredBooks.length);
      appendMoreBooks();
      if (loader) loader.style.display = 'none';
      isLoadingMore = false;
    }, 300);
  }
  window.triggerLoadMore = triggerLoadMore;

  function setupInfiniteScroll() {
    const sentinel = document.getElementById('scrollSentinel');
    const loader = document.getElementById('scrollLoader');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !isLoadingMore && visibleCount < filteredBooks.length) {
          isLoadingMore = true;
          loader.style.display = 'flex';
          setTimeout(() => {
            visibleCount = Math.min(visibleCount + PAGE_SIZE, filteredBooks.length);
            appendMoreBooks();
            loader.style.display = 'none';
            isLoadingMore = false;
          }, 400);
        }
      });
    }, { rootMargin: '200px' });
    observer.observe(sentinel);
  }

  function appendMoreBooks() {
    const grid = document.getElementById('booksGrid');
    const newSlice = filteredBooks.slice(visibleCount - PAGE_SIZE, visibleCount);
    newSlice.forEach(b => {
      const div = document.createElement('div');
      div.innerHTML = bookCardHTML(b);
      const card = div.firstElementChild;
      grid.appendChild(card);
    });
    const loadMoreWrap2 = document.getElementById('loadMoreWrap');
    if (loadMoreWrap2) loadMoreWrap2.style.display = visibleCount < filteredBooks.length ? 'flex' : 'none';
    if (isCliente) {
      grid.querySelectorAll('.btn-buy:not([data-bound])').forEach(btn => {
        btn.dataset.bound = '1';
        btn.addEventListener('click', () => openBuyModal({
          id: +btn.dataset.id, nombre: btn.dataset.nombre,
          precio: +btn.dataset.precio, stock: +btn.dataset.stock, imagen_url: btn.dataset.img || ''
        }));
      });
    }
  }

  function setupSearch() {
    const input = document.getElementById('searchInput');
    const clearBtn = document.getElementById('clearSearch');
    const catSel = document.getElementById('categorySelect');
    const sortSel = document.getElementById('sortSelect');
    let timer;
    input.addEventListener('input', () => {
      clearBtn.style.display = input.value ? 'flex' : 'none';
      clearTimeout(timer);
      timer = setTimeout(() => { currentSearch = input.value.trim(); loadBooks(currentSearch, currentCategory); updatePills(); }, 380);
    });
    clearBtn.addEventListener('click', () => {
      input.value = ''; clearBtn.style.display = 'none';
      currentSearch = ''; loadBooks('', currentCategory); updatePills();
    });
    catSel.addEventListener('change', () => {
      const val = catSel.value;
      if (val === '__bestsellers__') {
        showOnlyBestsellers = true;
        currentCategory = '';
      } else {
        showOnlyBestsellers = false;
        currentCategory = val;
      }
      loadBooks(currentSearch, currentCategory);
      updatePills();
    });
    sortSel.addEventListener('change', () => { currentSort = sortSel.value; renderBooks(); });
  }

  function getSorted(books) {
    const b = [...books];
    if (currentSort === 'price-asc') return b.sort((a,z) => a.precio - z.precio);
    if (currentSort === 'price-desc') return b.sort((a,z) => z.precio - a.precio);
    if (currentSort === 'name-asc') return b.sort((a,z) => a.nombre.localeCompare(z.nombre));
    if (currentSort === 'bestseller') return b.sort((a,z) => (z.es_bestseller?1:0) - (a.es_bestseller?1:0));
    return b;
  }

  function renderBooks() {
    const grid = document.getElementById('booksGrid');
    const empty = document.getElementById('emptyState');
    document.getElementById('skeletonGrid').style.display = 'none';
    let base = showOnlyBestsellers ? allBooks.filter(b => b.es_bestseller) : allBooks;
    base = applyAdvancedFilters(base);
    filteredBooks = getSorted(base);
    if (filteredBooks.length === 0) { grid.style.display = 'none'; empty.style.display = 'flex'; return; }
    empty.style.display = 'none';
    grid.style.display = 'grid';
    const firstPage = filteredBooks.slice(0, visibleCount);
    const loadMoreWrap = document.getElementById('loadMoreWrap');
    if (loadMoreWrap) loadMoreWrap.style.display = visibleCount < filteredBooks.length ? 'flex' : 'none';
    grid.innerHTML = firstPage.map(b => bookCardHTML(b)).join('');
    const srStat = document.getElementById('searchResultStat');
    if (currentSearch || currentCategory || countActiveAdvFilters() > 0) {
      srStat.style.display = 'flex';
      document.getElementById('searchResultCount').textContent = filteredBooks.length;
    } else { srStat.style.display = 'none'; }
    if (isCliente) {
      grid.querySelectorAll('.btn-buy').forEach(btn => {
        btn.dataset.bound = '1';
        btn.addEventListener('click', () => openBuyModal({
          id: +btn.dataset.id, nombre: btn.dataset.nombre,
          precio: +btn.dataset.precio, stock: +btn.dataset.stock, imagen_url: btn.dataset.img || ''
        }));
      });
    }
  }

  // ============================================================
  // BOOK CARD HTML — portada colorida por categoría
  // ============================================================
  function bookCardHTML(book) {
    const precio = parseFloat(book.precio);
    const catName = book.categoria?.name || '';
    const cfg = getCfg(catName);
    const outOfStock = book.stock === 0;
    const lowStock = book.stock > 0 && book.stock < 5;
    const hasImg = !!book.imagen_url;
    const imgUrl = hasImg
      ? (book.imagen_url.startsWith('http') ? book.imagen_url : `${BACKEND_BASE}${book.imagen_url}`)
      : '';

    // Cover: image OR colorful placeholder
    const shortTitle = book.nombre.length > 30 ? book.nombre.substring(0, 30) + '…' : book.nombre;
    const shortAuthor = (book.autor || '').length > 26 ? (book.autor || '').substring(0, 26) + '…' : (book.autor || '');
    const coverContent = hasImg
      ? `<img src="${imgUrl}" alt="" class="cover-img-bg" aria-hidden="true" loading="lazy">` +
        `<img src="${imgUrl}" alt="${book.nombre}" class="cover-img" loading="lazy" width="230" height="200"
            onerror="this.style.display='none';this.previousElementSibling.style.display='none';this.nextElementSibling.style.removeProperty('display')">`
      : '';
    const placeholderDisplay = hasImg ? 'display:none;' : '';

    // Tags by category
    const tagBadge = catName
      ? `<span class="book-cat-tag" style="background:${cfg.bg};color:${cfg.color}">${cfg.icon} ${catName}</span>`
      : '';

    // Stock label
    const stockLabel = outOfStock
      ? `<span class="book-stock out">✖ Sin stock</span>`
      : lowStock
        ? `<span class="book-stock low">⚡ Solo ${book.stock} disponibles</span>`
        : `<span class="book-stock ok">✔ ${book.stock} disponibles</span>`;

    // Buttons: add to cart / quick buy — hidden if client already owns this book
    const yaComprado = isCliente && window._purchasedIds && window._purchasedIds.has(book.id);
    const addCartBtn = isCliente && !outOfStock && !yaComprado
      ? `<button class="btn-cart" onclick='addToCart(${JSON.stringify({id:book.id,nombre:book.nombre,autor:book.autor,precio:precio,stock:book.stock,imagen_url:book.imagen_url||""})})' title="Agregar al carrito">🛒 Agregar</button>`
      : '';
    const buyBtn = isCliente && !outOfStock && !yaComprado
      ? `<button class="btn-buy" data-id="${book.id}" data-nombre="${book.nombre}" data-precio="${precio}" data-stock="${book.stock}" data-img="${book.imagen_url || ''}" title="Comprar ahora">⚡</button>`
      : '';
    const ownedBadge = yaComprado
      ? `<span class="btn-owned">✅ Ya lo tienes</span>`
      : '';

    // PDF preview button (visible to all if book has PDF)
    const pdfPreviewBtn = book.has_pdf
      ? `<button class="btn-pdf-preview" onclick="openPdfPreview(${book.id}, '${book.nombre.replace(/'/g,"\'").replace(/"/g,'\"')}', '${(book.autor||'').replace(/'/g,"\'")}')" title="Vista previa del libro">📄 Vista previa</button>`
      : '';

    // Bestseller ribbon
    const bestseller = book.es_bestseller ? `<div class="badge-bestseller">⭐ Bestseller</div>` : '';
    const outBadge = outOfStock ? `<div class="badge-out">Agotado</div>` : '';
    const lowBadge = lowStock && !outOfStock ? `<div class="badge-low">¡Últimas!</div>` : '';

    // Discount badge
    const tieneDescuento = !!book.precio_original;
    const precioOriginal = tieneDescuento ? parseFloat(book.precio_original) : null;
    const discountPct = tieneDescuento ? Math.round((1 - precio / precioOriginal) * 100) : 0;
    const discountBadge = tieneDescuento ? `<div class="badge-discount">-${discountPct}%</div>` : '';

    // Editorial line
    const editLine = book.editorial
      ? `<p class="book-editorial">${book.editorial}${book.anio_publicacion ? ' · ' + book.anio_publicacion : ''}</p>`
      : '';

    // Star rating (from cached summaries)
    const ratingData = window._ratings && window._ratings[book.id];
    const starLine = ratingData && ratingData.total_resenas > 0
      ? `<div class="book-stars" onclick="openReviewModal(${book.id},'${book.nombre.replace(/'/g,"\'")}')">
           <span style="color:#f59e0b">${'★'.repeat(Math.round(ratingData.promedio))}${'☆'.repeat(5-Math.round(ratingData.promedio))}</span>
           <span class="star-count">${ratingData.promedio.toFixed(1)} (${ratingData.total_resenas})</span>
         </div>`
      : `<div class="book-stars-empty" onclick="openReviewModal(${book.id},'${book.nombre.replace(/'/g,"\'")}')">
           <span style="color:#d1d5db">☆☆☆☆☆</span>
           <span class="star-count">Sin reseñas</span>
         </div>`;
    // Review button for clients who purchased
    const reviewBtn = isCliente && yaComprado
      ? `<button class="btn-review" onclick="openReviewModal(${book.id},'${book.nombre.replace(/'/g,"\'")}')">✍️ Reseña</button>`
      : '';
    // Button to view all reviews (visible to everyone)
    const verResenasBtn = `<button class="btn-ver-resenas" data-book-id="${book.id}" data-book-name="${book.nombre.replace(/"/g,'&quot;')}" onclick="openViewReviewsModal(this.dataset.bookId, this.dataset.bookName)">⭐ Reseñas</button>`;

    return `
      <article class="book-card${outOfStock ? ' oos' : ''}${tieneDescuento ? ' has-discount' : ''}">
        <div class="book-cover" style="background:${cfg.light}">
          ${coverContent}
          <div class="cover-placeholder" style="${placeholderDisplay}background:${cfg.light};">
            <div class="ph-glow" style="background:radial-gradient(circle at 50% 40%, ${cfg.color}30 0%, transparent 68%)"></div>
            <span class="ph-icon" style="color:${cfg.color}">${cfg.icon}</span>
            <p class="ph-title" style="color:${cfg.color}">${shortTitle}</p>
            <p class="ph-author" style="color:${cfg.color}">${shortAuthor}</p>
          </div>
          ${bestseller}${outBadge}${lowBadge}${discountBadge}
        </div>
        <div class="book-info">
          ${tagBadge}
          <h3 class="book-name">${book.nombre}</h3>
          <p class="book-author">✍️ ${book.autor}</p>
          ${editLine}
          ${starLine}
          <div class="book-bottom">
            <div>
              ${tieneDescuento
                ? `<p class="book-price">L ${precio.toFixed(2)} <span class="book-price-original">L ${precioOriginal.toFixed(2)}</span></p>`
                : `<p class="book-price">L ${precio.toFixed(2)}</p>`
              }
              ${stockLabel}
            </div>
            <div style="display:flex;flex-direction:column;gap:0.35rem;align-items:flex-end">
              ${addCartBtn}${ownedBadge}
              <div style="display:flex;gap:0.35rem;align-items:center;flex-wrap:wrap;justify-content:flex-end">
                ${buyBtn}
                ${pdfPreviewBtn}
                ${reviewBtn}
                ${verResenasBtn}
              </div>
            </div>
          </div>
        </div>
      </article>`;
  }

  function updateStats() {
    document.getElementById('totalCount').textContent = allBooks.length;
    document.getElementById('bestsellerCount').textContent = allBooks.filter(b => b.es_bestseller).length;
  }

  function updatePills() {
    const c = document.getElementById('filterPills');
    const pills = [];
    if (currentSearch) pills.push(`<span class="pill">🔍 "${currentSearch}" <button onclick="clearSearch()">✕</button></span>`);
    if (showOnlyBestsellers) {
      pills.push(`<span class="pill pill-bestseller">⭐ Bestsellers <button onclick="clearCategory()">✕</button></span>`);
    } else if (currentCategory) {
      const cat = categories.find(x => x.id == currentCategory);
      if (cat) { const cfg = getCfg(cat.name); pills.push(`<span class="pill" style="background:${cfg.bg};color:${cfg.color}">${cfg.icon} ${cat.name} <button onclick="clearCategory()" style="color:${cfg.color}">✕</button></span>`); }
    }
    c.innerHTML = pills.join('');
    c.style.display = pills.length ? 'flex' : 'none';
  }

  window.clearSearch = () => {
    document.getElementById('searchInput').value = '';
    document.getElementById('clearSearch').style.display = 'none';
    currentSearch = ''; loadBooks('', currentCategory); updatePills();
  };
  window.clearCategory = () => {
    document.getElementById('categorySelect').value = '';
    currentCategory = '';
    showOnlyBestsellers = false;
    loadBooks(currentSearch, '');
    updatePills();
  };
  window.clearAllFilters = () => { clearSearch(); clearCategory(); };

  function showSkeleton() {
    document.getElementById('skeletonGrid').style.display = 'grid';
    document.getElementById('booksGrid').style.display = 'none';
    document.getElementById('emptyState').style.display = 'none';
    document.getElementById('errorState').style.display = 'none';
  }
  function showError() {
    document.getElementById('skeletonGrid').style.display = 'none';
    document.getElementById('booksGrid').style.display = 'none';
    document.getElementById('emptyState').style.display = 'none';
    document.getElementById('errorState').style.display = 'flex';
  }

  // ============================================================
  // BUY MODAL — siempre cantidad 1 (copia digital)
  // ============================================================
  function openBuyModal(book) {
    buyBook = book;
    const thumbHtml = book.imagen_url
      ? `<img src="${book.imagen_url.startsWith('http') ? book.imagen_url : BACKEND_BASE+book.imagen_url}" class="buy-thumb" alt="${book.nombre}" onerror="this.style.display='none';this.nextSibling.style.display='flex'">`
      : '';
    const thumbDefault = `<div class="buy-thumb-default" style="display:${book.imagen_url?'none':'flex'}">📖</div>`;
    document.getElementById('buyBookInfo').innerHTML = `
      <div class="buy-book-card">
        ${thumbHtml}${thumbDefault}
        <div>
          <h4 class="buy-book-name">${book.nombre}</h4>
          <p class="buy-book-price-unit">L ${parseFloat(book.precio).toFixed(2)}</p>
          <p class="buy-book-avail">${book.stock} disponibles</p>
        </div>
      </div>`;
    const _precio = parseFloat(book.precio);
    const _isv = _precio * 0.15;
    const _total = _precio + _isv;
    document.getElementById('buySubtotal').textContent = `L ${_precio.toFixed(2)}`;
    document.getElementById('buyIsv').textContent = `L ${_isv.toFixed(2)}`;
    document.getElementById('buyTotal').textContent = `L ${_total.toFixed(2)}`;
    document.getElementById('buyModal').style.display = 'flex';
  }

  document.getElementById('closeBuyModal')?.addEventListener('click', () => { document.getElementById('buyModal').style.display = 'none'; });

  // Auto-format card number (spaces every 4 digits)
  document.getElementById('cardNumber')?.addEventListener('input', (e) => {
    let v = e.target.value.replace(/\D/g, '').substring(0, 16);
    e.target.value = v.match(/.{1,4}/g)?.join(' ') || v;
  });
  // Auto-format expiry MM/AA
  document.getElementById('cardExpiry')?.addEventListener('input', (e) => {
    let v = e.target.value.replace(/\D/g, '').substring(0, 4);
    if (v.length >= 3) v = v.substring(0,2) + '/' + v.substring(2);
    e.target.value = v;
  });

  // Payment method toggle
  document.querySelectorAll('input[name="payMethod"]').forEach(r => {
    r.addEventListener('change', () => {
      document.getElementById('cardFields').style.display = r.value === 'tarjeta' ? 'block' : 'none';
    });
  });
  document.getElementById('cancelBuyBtn')?.addEventListener('click', () => { document.getElementById('buyModal').style.display = 'none'; });

  document.getElementById('confirmBuyBtn')?.addEventListener('click', async () => {
    if (!buyBook) return;
    const pm = document.querySelector('input[name="payMethod"]:checked')?.value || 'efectivo';
    if (pm === 'tarjeta') {
      const cNum = document.getElementById('cardNumber')?.value.replace(/\s/g,'');
      const cExp = document.getElementById('cardExpiry')?.value.trim();
      const cCvv = document.getElementById('cardCvv')?.value.trim();
      if (!cNum || cNum.length < 13) { Modal.error('Tarjeta inválida', 'Ingresa el número completo de tu tarjeta.'); return; }
      if (!cExp || cExp.length < 5) { Modal.error('Tarjeta inválida', 'Ingresa la fecha de vencimiento (MM/AA).'); return; }
      if (!cCvv || cCvv.length < 3) { Modal.error('Tarjeta inválida', 'Ingresa el CVV de tu tarjeta.'); return; }
    }
    const btn = document.getElementById('confirmBuyBtn');
    btn.disabled = true; btn.textContent = 'Procesando…';
    try {
      const tok = localStorage.getItem('token');
      const r = await fetch(`${BACKEND}/sales/online`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${tok}` },
        body: JSON.stringify({
          tipo: 'ONLINE',
          items: [{ libro_id: buyBook.id, cantidad: 1 }],
          notas: (() => {
            const pm = document.querySelector('input[name="payMethod"]:checked')?.value || 'efectivo';
            const rtn = document.getElementById('buyRtn').value.trim();
            const cNum = document.getElementById('cardNumber')?.value.replace(/\s/g,'').trim();
            const c4 = cNum ? cNum.slice(-4) : '';
            let n = 'Copia digital | Pago: ' + pm.charAt(0).toUpperCase() + pm.slice(1);
            if (pm === 'tarjeta' && c4) n += ' (*' + c4 + ')';
            if (rtn) n += ' | RTN: ' + rtn;
            return n;
          })()
        })
      });
      if (!r.ok) {
        const d = await r.json();
        const msg = Array.isArray(d.detail)
          ? d.detail.map(e => e.msg).join(', ')
          : (d.detail || 'Error al comprar');
        throw new Error(msg);
      }
      document.getElementById('buyModal').style.display = 'none';
      // Add newly purchased book to the local set so UI updates immediately
      if (buyBook) window._purchasedIds.add(buyBook.id);
      Modal.success('¡Compra realizada!', `Compraste <strong>${buyBook.nombre}</strong> (copia digital). Puedes leerlo en "Mis Libros".`);
      await loadBooks();
    } catch(e) {
      Modal.error('Error al comprar', e.message);
    } finally {
      btn.disabled = false; btn.textContent = '🛒 Confirmar compra';
    }
  });

  // ── PDF PREVIEW ──────────────────────────────────────────────────────────
  let prevPdfDoc = null, prevPage = 1;
  const prevCanvas = document.getElementById('prevCanvas');
  const prevCtx = prevCanvas ? prevCanvas.getContext('2d') : null;

  // Block right-click on preview
  document.getElementById('pdfPreviewModal')?.addEventListener('contextmenu', e => e.preventDefault());

  window.openPdfPreview = async function(bookId, title, author) {
    prevPage = 1;
    document.getElementById('prevBookTitle').textContent = title;
    document.getElementById('prevBookAuthor').textContent = author;
    document.getElementById('prevCurrentPage').textContent = '1';
    document.getElementById('prevTotalPages').textContent = '—';
    document.getElementById('prevCanvas').style.display = 'none';
    document.getElementById('prevBlurGate').style.display = 'none';
    document.getElementById('prevLoading').style.display = 'flex';
    document.getElementById('pdfPreviewModal').style.display = 'flex';

    try {
      const r = await fetch(`${BACKEND}/books/pdf-preview/${bookId}`);
      if (!r.ok) throw new Error('No disponible');
      const buf = await r.arrayBuffer();
      prevPdfDoc = await pdfjsLib.getDocument({ data: buf }).promise;
      document.getElementById('prevTotalPages').textContent = prevPdfDoc.numPages;
      document.getElementById('prevLoading').style.display = 'none';
      document.getElementById('prevCanvas').style.display = 'block';
      await renderPrevPage(1);
    } catch(e) {
      document.getElementById('prevLoading').innerHTML = '<p style="color:#dc2626">No hay vista previa disponible para este libro.</p>';
    }
  };

  async function renderPrevPage(num) {
    if (!prevPdfDoc) return;
    const page = await prevPdfDoc.getPage(num);
    const wrap = document.getElementById('prevCanvasWrap');
    const scale = (wrap.clientWidth * 0.88) / page.getViewport({scale:1}).width;
    const viewport = page.getViewport({ scale });
    prevCanvas.width = viewport.width;
    prevCanvas.height = viewport.height;
    await page.render({ canvasContext: prevCtx, viewport }).promise;
    document.getElementById('prevCurrentPage').textContent = num;
    document.getElementById('prevPdfPrev').disabled = num <= 1;
    // Last preview page shows blur gate for next
    const isLast = num >= prevPdfDoc.numPages;
    document.getElementById('nextPdfPrev').disabled = isLast;
    document.getElementById('prevBlurGate').style.display = isLast ? 'flex' : 'none';
  }

  document.getElementById('prevPdfPrev')?.addEventListener('click', () => {
    if (prevPage > 1) { prevPage--; renderPrevPage(prevPage); }
  });
  document.getElementById('nextPdfPrev')?.addEventListener('click', () => {
    if (prevPdfDoc && prevPage < prevPdfDoc.numPages) { prevPage++; renderPrevPage(prevPage); }
  });
  document.getElementById('closePdfPreview')?.addEventListener('click', () => {
    document.getElementById('pdfPreviewModal').style.display = 'none';
    prevPdfDoc = null;
  });

  // LOGOUT
  document.getElementById('logoutBtn')?.addEventListener('click', () => {
    localStorage.removeItem('token'); localStorage.removeItem('user');
    document.cookie = 'token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
    document.cookie = 'user=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
    window.location.href = '/catalogo';
  });

  // ── CARRITO ─────────────────────────────────────────────────
  const CART_KEY = 'libreria_cart';

  window.addToCart = function(book) {
    let cart = [];
    try { cart = JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch {}
    const idx = cart.findIndex(i => i.id === book.id);
    if (idx >= 0) { cart[idx].qty = (cart[idx].qty || 1) + 1; }
    else { cart.push({ ...book, qty: 1 }); }
    localStorage.setItem(CART_KEY, JSON.stringify(cart));
    updateCartBadgeNav();
    showCartToast(book.nombre);
  };

  function updateCartBadgeNav() {
    let cart = [];
    try { cart = JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch {}
    const total = cart.reduce((s, i) => s + (i.qty || 1), 0);
    const badge = document.getElementById('cartNavBadge');
    if (badge) { badge.textContent = total; badge.style.display = total > 0 ? 'inline-flex' : 'none'; }
  }

  function showCartToast(nombre) {
    let t = document.getElementById('cartToast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'cartToast';
      t.className = 'cart-toast';
      document.body.appendChild(t);
    }
    const short = nombre.length > 32 ? nombre.slice(0, 32) + '…' : nombre;
    const cartLink = isCliente ? `<a href="/carrito">Ver carrito →</a>` : `<a href="#" onclick="event.preventDefault();document.getElementById('loginRequiredModal').style.display='flex'">Ver carrito →</a>`;
    t.innerHTML = `<span>✅</span><span><strong>${short}</strong> agregado al carrito</span>${cartLink}`;
    t.classList.add('show');
    clearTimeout(t._timer);
    t._timer = setTimeout(() => t.classList.remove('show'), 3500);
  }

  // ── RATINGS ────────────────────────────────────────────────────────────
  window._ratings = {};
  async function loadRatings() {
    // Fetch summaries for all visible books
    const bookIds = allBooks.map(b => b.id);
    if (!bookIds.length) return;
    await Promise.all(bookIds.map(async id => {
      try {
        const r = await fetch(`${BACKEND}/reviews/book/${id}/summary`);
        if (r.ok) window._ratings[id] = await r.json();
      } catch {}
    }));
    renderBooks(); // re-render with stars
  }

  // ── REVIEW MODAL ───────────────────────────────────────────────────────
  let _reviewBookId = null;
  let _reviewCal = 5;

  window.openReviewModal = async function(bookId, bookName) {
    _reviewBookId = bookId;
    const modal = document.getElementById('reviewModal');
    document.getElementById('reviewBookTitle').textContent = bookName;
    document.getElementById('reviewAlert').innerHTML = '';
    document.getElementById('reviewTitulo').value = '';
    document.getElementById('reviewComentario').value = '';
    setReviewStars(5);

    if (isCliente && token) {
      try {
        const r = await fetch(`${BACKEND}/reviews/can-review/${bookId}`, {
          headers: { Authorization: `Bearer ${token}` }
        });
        const data = await r.json();
        if (!data.can_review && data.reason === 'already_reviewed') {
          const rv = data.review;
          document.getElementById('reviewTitulo').value = rv.titulo || '';
          document.getElementById('reviewComentario').value = rv.comentario || '';
          setReviewStars(rv.calificacion);
          document.getElementById('reviewEditId').value = rv.id;
          document.getElementById('reviewSubmitBtn').textContent = '💾 Actualizar reseña';
        } else {
          document.getElementById('reviewEditId').value = '';
          document.getElementById('reviewSubmitBtn').textContent = '✅ Publicar reseña';
        }
        if (!data.can_review && data.reason === 'no_purchase') {
          document.getElementById('reviewAlert').innerHTML =
            '<div class="alert alert-error" style="margin-bottom:.75rem;font-size:.85rem">Debes comprar este libro para poder reseñarlo.</div>';
          document.getElementById('reviewSubmitBtn').disabled = true;
        } else {
          document.getElementById('reviewSubmitBtn').disabled = false;
        }
      } catch {}
    } else {
      document.getElementById('reviewAlert').innerHTML =
        '<div class="alert alert-error" style="margin-bottom:.75rem;font-size:.85rem">Inicia sesión para dejar una reseña.</div>';
      document.getElementById('reviewSubmitBtn').disabled = true;
    }

    // Load existing reviews
    try {
      const r = await fetch(`${BACKEND}/reviews/book/${bookId}`);
      const reviews = await r.json();
      const summary = window._ratings[bookId] || { total_resenas: 0, promedio: 0 };
      const listEl = document.getElementById('reviewList');
      if (!reviews.length) {
        listEl.innerHTML = '<p style="color:var(--gray-400);font-size:.88rem;text-align:center;padding:1rem 0">Sé el primero en reseñar este libro</p>';
      } else {
        listEl.innerHTML = reviews.map(rv => `
          <div style="padding:.75rem 0;border-bottom:1px solid var(--gray-100)">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.3rem">
              <strong style="font-size:.88rem">${rv.cliente_nombre}</strong>
              <span style="color:#f59e0b;font-size:.95rem">${'★'.repeat(rv.calificacion)}${'☆'.repeat(5-rv.calificacion)}</span>
            </div>
            ${rv.titulo ? `<div style="font-weight:600;font-size:.85rem;margin-bottom:.25rem">${rv.titulo}</div>` : ''}
            ${rv.comentario ? `<div style="font-size:.83rem;color:var(--gray-600);line-height:1.5">${rv.comentario}</div>` : ''}
          </div>`).join('');
        // Summary header
        const sumEl = document.getElementById('reviewSummary');
        if (sumEl) {
          sumEl.innerHTML = summary.total_resenas > 0
            ? `<div style="text-align:center;padding:.75rem;background:var(--gray-50);border-radius:var(--radius-sm);margin-bottom:.75rem">
                 <div style="font-size:2rem;font-weight:700;color:var(--navy)">${summary.promedio.toFixed(1)}</div>
                 <div style="color:#f59e0b;font-size:1.2rem">${'★'.repeat(Math.round(summary.promedio))}${'☆'.repeat(5-Math.round(summary.promedio))}</div>
                 <div style="font-size:.8rem;color:var(--gray-600)">${summary.total_resenas} reseña${summary.total_resenas !== 1 ? 's' : ''}</div>
               </div>`
            : '';
        }
      }
    } catch {}

    modal.style.display = 'flex';
  };

  function setReviewStars(val) {
    _reviewCal = val;
    document.querySelectorAll('.rv-star').forEach(s => {
      const v = parseInt(s.dataset.v);
      s.textContent = v <= val ? '★' : '☆';
      s.style.color = v <= val ? '#f59e0b' : '#d1d5db';
    });
  }

  document.querySelectorAll('.rv-star').forEach(s => {
    s.addEventListener('click', () => setReviewStars(parseInt(s.dataset.v)));
    s.addEventListener('mouseenter', () => {
      const v = parseInt(s.dataset.v);
      document.querySelectorAll('.rv-star').forEach(x => {
        x.style.color = parseInt(x.dataset.v) <= v ? '#f59e0b' : '#d1d5db';
      });
    });
  });
  document.getElementById('reviewStarsPicker')?.addEventListener('mouseleave', () => setReviewStars(_reviewCal));

  document.getElementById('closeReviewModal')?.addEventListener('click', () => {
    document.getElementById('reviewModal').style.display = 'none';
  });

  document.getElementById('reviewSubmitBtn')?.addEventListener('click', async () => {
    const editId = document.getElementById('reviewEditId').value;
    const titulo    = document.getElementById('reviewTitulo').value.trim() || null;
    const comentario = document.getElementById('reviewComentario').value.trim() || null;
    const btn = document.getElementById('reviewSubmitBtn');
    btn.disabled = true; btn.textContent = 'Guardando…';
    try {
      if (editId) {
        await fetch(`${BACKEND}/reviews/${editId}`, {
          method: 'PUT', headers: { 'Content-Type':'application/json', Authorization:`Bearer ${token}` },
          body: JSON.stringify({ calificacion: _reviewCal, titulo, comentario })
        });
      } else {
        await fetch(`${BACKEND}/reviews/`, {
          method: 'POST', headers: { 'Content-Type':'application/json', Authorization:`Bearer ${token}` },
          body: JSON.stringify({ libro_id: _reviewBookId, calificacion: _reviewCal, titulo, comentario })
        });
      }
      // refresh ratings
      const rs = await fetch(`${BACKEND}/reviews/book/${_reviewBookId}/summary`);
      if (rs.ok) window._ratings[_reviewBookId] = await rs.json();
      renderBooks();
      document.getElementById('reviewModal').style.display = 'none';
    } catch(e) {
      document.getElementById('reviewAlert').innerHTML =
        `<div class="alert alert-error" style="font-size:.85rem">${e.message}</div>`;
      btn.disabled = false; btn.textContent = editId ? '💾 Actualizar reseña' : '✅ Publicar reseña';
    }
  });

  // ── VIEW-ONLY REVIEWS MODAL ───────────────────────────────────────────────
  window.openViewReviewsModal = async function(bookId, bookName) {
    const modal = document.getElementById('viewReviewsModal');
    const body  = document.getElementById('vrBody');
    document.getElementById('vrTitle').textContent = bookName;
    document.getElementById('vrSub').textContent = '';
    body.innerHTML = '<div class="vr-loading">Cargando reseñas…</div>';
    modal.style.display = 'flex';
    try {
      const [revRes, sumRes] = await Promise.all([
        fetch(`${BACKEND}/reviews/book/${bookId}`),
        fetch(`${BACKEND}/reviews/book/${bookId}/summary`)
      ]);
      const reviews = revRes.ok ? await revRes.json() : [];
      const summary = sumRes.ok ? await sumRes.json() : { promedio: 0, total_resenas: 0 };
      document.getElementById('vrSub').textContent =
        summary.total_resenas > 0
          ? `⭐ ${parseFloat(summary.promedio).toFixed(1)} promedio · ${summary.total_resenas} reseña${summary.total_resenas !== 1 ? 's' : ''}`
          : 'Aún no hay reseñas para este libro';
      if (!reviews.length) {
        body.innerHTML = '<div class="vr-empty"><span style="font-size:2.5rem">📭</span><p>Este libro no tiene reseñas todavía.</p></div>';
        return;
      }
      body.innerHTML = reviews.map(rv => {
        const filled = Math.round(rv.calificacion || 0);
        const stars = '★'.repeat(filled) + '☆'.repeat(5 - filled);
        const fecha = rv.fecha_creacion || rv.created_at
          ? new Date(rv.fecha_creacion || rv.created_at).toLocaleDateString('es-HN')
          : '';
        return `<div class="vr-item">
          <div class="vr-item-top">
            <span class="vr-stars">${stars}</span>
            ${fecha ? `<span class="vr-date">${fecha}</span>` : ''}
          </div>
          ${rv.titulo ? `<div class="vr-titulo">${rv.titulo}</div>` : ''}
          ${rv.comentario || rv.cuerpo ? `<div class="vr-cuerpo">${rv.comentario || rv.cuerpo}</div>` : ''}
          <div class="vr-author">— ${rv.usuario_nombre || rv.usuario?.nombre || 'Lector'}</div>
        </div>`;
      }).join('');
    } catch(e) {
      body.innerHTML = '<div class="vr-empty" style="color:var(--danger)">Error al cargar reseñas.</div>';
    }
  };

  init();
  updateCartBadgeNav();

  // ── DARK MODE init & sync toggle label ───────────────────────────────────
  (function(){
    const saved = localStorage.getItem('darkMode');
    const pref  = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const on    = saved === 'true' || (saved === null && pref);
    if (on) document.documentElement.classList.add('dark');
    const btn = document.getElementById('darkToggleCatalog');
    if (btn) btn.textContent = on ? '☀️' : '🌙';
  })();
  window.toggleDark = function() {
    const on = document.documentElement.classList.toggle('dark');
    localStorage.setItem('darkMode', on);
    const btn = document.getElementById('darkToggleCatalog');
    if (btn) btn.textContent = on ? '☀️' : '🌙';
  };

  // Login-required modal: close on overlay click or ESC
  document.addEventListener('click', function(e) {
    const modal = document.getElementById('loginRequiredModal');
    if (modal && e.target === modal) modal.style.display = 'none';
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      const modal = document.getElementById('loginRequiredModal');
      if (modal && modal.style.display !== 'none') modal.style.display = 'none';
    }
  });
</script>

