---
import PublicLayout from '../layouts/PublicLayout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';
const token = Astro.cookies.get('token')?.value;
const userStr = Astro.cookies.get('user')?.value;
let user = null;
try { user = userStr ? JSON.parse(decodeURIComponent(userStr)) : null; } catch (e) {}
const isCliente = user?.role_name === 'CLIENTE';
const dashboardUrl = user?.role_name === 'ADMIN' ? '/dashboard-admin' : user?.role_name === 'EMPLEADO' ? '/dashboard-empleado' : '/mis-compras';
---

<PublicLayout title="Catálogo de Libros">

  <!-- NAV -->
  <nav class="top-nav">
    <div class="nav-inner">
      <a href="/catalogo" class="brand">
        <div class="brand-icon">📚</div>
        <span class="brand-name">Librería</span>
      </a>
      <div class="nav-actions">
        {user ? (
          <>
            <span class="nav-greeting">Hola, <strong>{user.nombre}</strong></span>
            <a href={dashboardUrl} class="btn btn-sm btn-outline-nav">Mi cuenta</a>
            <button id="logoutBtn" class="btn btn-sm btn-ghost-nav">Salir</button>
          </>
        ) : (
          <>
            <a href="/login" class="btn btn-sm btn-ghost-nav">Iniciar sesión</a>
            <a href="/register" class="btn btn-sm btn-primary">Registrarse</a>
          </>
        )}
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero-section">
    <div class="hero-content">
      <p class="hero-eyebrow">Bienvenido a nuestra colección</p>
      <h1 class="hero-title">Catálogo de <span class="hero-accent">Libros</span></h1>
      <p class="hero-sub">Explora nuestra selección de títulos cuidadosamente organizados para ti</p>
      <div class="hero-search">
        <div class="search-wrap">
          <span class="search-icon">🔍</span>
          <input type="text" id="searchInput" class="search-input" placeholder="Buscar por título, autor o ISBN…">
          <button id="clearSearch" class="search-clear" style="display:none">✕</button>
        </div>
        <select id="categorySelect" class="category-select">
          <option value="">Todas las categorías</option>
          <option value="__bestsellers__">⭐ Bestsellers</option>
        </select>
      </div>
    </div>
    <div class="hero-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>
  </header>

  <!-- MAIN -->
  <main class="main-wrap">

    <!-- STATS BAR -->
    <div class="stats-bar">
      <div class="stats-inner">
        <div class="stat-item">
          <span class="stat-icon">📖</span>
          <span id="totalCount" class="stat-num">—</span>
          <span class="stat-lbl">libros disponibles</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-icon">⭐</span>
          <span id="bestsellerCount" class="stat-num">—</span>
          <span class="stat-lbl">bestsellers</span>
        </div>
        <div class="stat-item" id="searchResultStat" style="display:none">
          <div class="stat-divider"></div>
          <span class="stat-icon">🔎</span>
          <span id="searchResultCount" class="stat-num">—</span>
          <span class="stat-lbl">resultados</span>
        </div>
      </div>
    </div>

    <!-- FILTER PILLS -->
    <div id="filterPills" class="filter-pills" style="display:none"></div>

    <!-- TOOLBAR -->
    <div class="toolbar">
      <div class="sort-group">
        <label class="sort-label">Ordenar:</label>
        <select id="sortSelect" class="sort-select">
          <option value="default">Relevancia</option>
          <option value="price-asc">Precio: menor a mayor</option>
          <option value="price-desc">Precio: mayor a menor</option>
          <option value="name-asc">Nombre A-Z</option>
          <option value="bestseller">Más vendidos primero</option>
        </select>
      </div>
    </div>

    <!-- SKELETON (cargando) -->
    <div id="skeletonGrid" class="books-grid">
      {Array.from({length: 12}).map(() => (
        <div class="book-skeleton">
          <div class="skeleton sk-img"></div>
          <div class="sk-body">
            <div class="skeleton sk-badge"></div>
            <div class="skeleton sk-title"></div>
            <div class="skeleton sk-title sk-short"></div>
            <div class="skeleton sk-author"></div>
            <div class="skeleton sk-price"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- BOOKS GRID -->
    <div id="booksGrid" class="books-grid" style="display:none"></div>

    <!-- EMPTY STATE -->
    <div id="emptyState" class="empty-state" style="display:none">
      <div class="empty-illustration">📭</div>
      <h3 class="empty-title">No se encontraron libros</h3>
      <p class="empty-desc">Intenta con otros términos o elimina los filtros activos.</p>
      <button onclick="clearAllFilters()" class="btn btn-primary">Limpiar filtros</button>
    </div>

    <!-- ERROR STATE -->
    <div id="errorState" class="error-state" style="display:none">
      <div class="empty-illustration">⚠️</div>
      <h3 class="empty-title">Error al cargar el catálogo</h3>
      <p class="empty-desc">No se pudo conectar con el servidor. Verifica que el backend esté activo.</p>
      <button onclick="loadBooks()" class="btn btn-primary">Reintentar</button>
    </div>
  </main>

  <!-- PDF PREVIEW MODAL -->
  <div id="pdfPreviewModal" class="pdf-prev-overlay" style="display:none">
    <div class="pdf-prev-box">
      <div class="pdf-prev-topbar">
        <div class="pdf-prev-meta">
          <div id="prevBookTitle" class="pdf-prev-title">—</div>
          <div id="prevBookAuthor" class="pdf-prev-author">—</div>
        </div>
        <div class="pdf-prev-controls">
          <button id="prevPdfPrev" class="pdf-prev-nav" disabled>‹</button>
          <span class="pdf-prev-page"><span id="prevCurrentPage">1</span> / <span id="prevTotalPages">—</span></span>
          <button id="nextPdfPrev" class="pdf-prev-nav">›</button>
        </div>
        <div style="display:flex;align-items:center;gap:0.5rem">
          <span class="pdf-prev-lock">🔒 Vista previa</span>
          <button id="closePdfPreview" class="pdf-prev-close">✕</button>
        </div>
      </div>
      <div class="pdf-prev-canvas-wrap" id="prevCanvasWrap">
        <div id="prevLoading" class="pdf-prev-loading">
          <div class="pdf-prev-spinner"></div>
          <p>Cargando vista previa…</p>
        </div>
        <canvas id="prevCanvas" style="display:none"></canvas>
        <div id="prevBlurGate" class="pdf-prev-blur-gate" style="display:none">
          <div class="pdf-prev-blur-content">
            <div class="pdf-prev-lock-icon">🔒</div>
            <h3>Contenido bloqueado</h3>
            <p>Esta es una vista previa. Compra el libro para leer el contenido completo.</p>
            <button class="btn btn-primary" onclick="document.getElementById('pdfPreviewModal').style.display='none'">Ver en catálogo</button>
          </div>
        </div>
      </div>
    </div>
    <div class="pdf-prev-drm"></div>
  </div>

  <!-- BUY MODAL -->
  <div id="buyModal" class="buy-modal-overlay" style="display:none">
    <div class="buy-modal-box">
      <div class="buy-modal-header">
        <h2 class="buy-modal-title">Confirmar compra</h2>
        <button id="closeBuyModal" class="buy-modal-close">✕</button>
      </div>
      <div class="buy-modal-body">
        <div id="buyBookInfo"></div>

        <!-- Compra digital: siempre 1 copia -->
        <div class="buy-digital-notice">
          <span class="buy-digital-icon">📱</span>
          <div>
            <div class="buy-digital-title">Copia digital — 1 unidad</div>
            <div class="buy-digital-desc">Las compras online son copias digitales. Podrás leer el libro desde "Mis Libros" con tu cuenta.</div>
          </div>
        </div>

        <div class="buy-section-title">Método de pago</div>
        <div class="pay-method-grid">
          <label class="pay-method-opt">
            <input type="radio" name="payMethod" value="efectivo" checked>
            <span class="pay-method-card">💵 Efectivo</span>
          </label>
          <label class="pay-method-opt">
            <input type="radio" name="payMethod" value="tarjeta">
            <span class="pay-method-card">💳 Tarjeta</span>
          </label>
          <label class="pay-method-opt">
            <input type="radio" name="payMethod" value="transferencia">
            <span class="pay-method-card">🏦 Transferencia</span>
          </label>
        </div>

        <div id="cardFields" style="display:none" class="card-fields-wrap">
          <div class="form-group" style="margin-bottom:0.5rem">
            <label class="form-label" style="font-size:0.78rem">Últimos 4 dígitos de la tarjeta</label>
            <input type="text" id="cardLast4" class="form-input" maxlength="4" placeholder="1234" pattern="[0-9]{4}">
          </div>
        </div>

        <div class="form-group" style="margin-top:0.75rem;margin-bottom:0">
          <label class="form-label" style="font-size:0.78rem">RTN del cliente <span style="color:var(--gray-400);font-weight:400">(opcional — para factura fiscal)</span></label>
          <input type="text" id="buyRtn" class="form-input" placeholder="0000-0000-000000" maxlength="20">
        </div>

        <div class="buy-total-row" style="margin-top:0.75rem">
          <span>Total a pagar:</span>
          <span id="buyTotal" class="buy-total-amount">L 0.00</span>
        </div>
      </div>
      <div class="buy-modal-footer">
        <button id="cancelBuyBtn" class="btn btn-secondary">Cancelar</button>
        <button id="confirmBuyBtn" class="btn btn-primary">🛒 Confirmar compra</button>
      </div>
    </div>
  </div>

</PublicLayout>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" is:inline></script>

<script is:inline define:vars={{ API_URL, isCliente }}>
  // PDF.js worker
  if (window.pdfjsLib) {
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
  }
  const BACKEND = API_URL || 'http://localhost:8000/api/v1';
  const BACKEND_BASE = 'http://localhost:8000';
  let allBooks = [];
  let categories = [];
  let showOnlyBestsellers = false;
  let currentSearch = '';
  let currentCategory = '';
  let currentSort = 'default';
  let buyBook = null;

  // ============================================================
  // CATEGORY CONFIG — colores e iconos
  // ============================================================
  const CAT_CONFIG = {
    'FICCION':     { color: '#7c3aed', bg: '#f5f3ff', light: '#c4b5fd', icon: '🌙', label: 'Ficción' },
    'NO_FICCION':  { color: '#0891b2', bg: '#ecfeff', light: '#a5f3fc', icon: '📰', label: 'No Ficción' },
    'CIENCIA':     { color: '#16a34a', bg: '#f0fdf4', light: '#86efac', icon: '🔬', label: 'Ciencia' },
    'TECNOLOGIA':  { color: '#2563eb', bg: '#eff6ff', light: '#93c5fd', icon: '💻', label: 'Tecnología' },
    'HISTORIA':    { color: '#b45309', bg: '#fffbeb', light: '#fcd34d', icon: '🏛️', label: 'Historia' },
    'ARTE':        { color: '#db2777', bg: '#fdf2f8', light: '#f9a8d4', icon: '🎨', label: 'Arte' },
    'LITERATURA':  { color: '#ea580c', bg: '#fff7ed', light: '#fdba74', icon: '✒️', label: 'Literatura' },
    'INFANTIL':    { color: '#e11d48', bg: '#fff1f2', light: '#fda4af', icon: '🦄', label: 'Infantil' },
    'ACADEMICO':   { color: '#4338ca', bg: '#eef2ff', light: '#a5b4fc', icon: '🎓', label: 'Académico' },
    'FILOSOFIA':   { color: '#334155', bg: '#f8fafc', light: '#94a3b8', icon: '🧠', label: 'Filosofía' },
  };

  function getCatKey(name) {
    return (name || '').toUpperCase()
      .replace(/Ó/g,'O').replace(/Í/g,'I').replace(/É/g,'E').replace(/Á/g,'A').replace(/Ú/g,'U')
      .replace(/\s+/g,'_').replace(/-/g,'_');
  }
  function getCfg(name) {
    return CAT_CONFIG[getCatKey(name)] || { color:'#1d4ed8', bg:'#eff6ff', light:'#bfdbfe', icon:'📖', label: name || '' };
  }

  // ============================================================
  // INIT
  // ============================================================
  async function init() {
    await Promise.all([loadCategories(), loadBooks()]);
    setupSearch();
  }

  async function loadCategories() {
    try {
      const r = await fetch(`${BACKEND}/books/categories`);
      if (r.ok) {
        categories = await r.json();
        const sel = document.getElementById('categorySelect');
        categories.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id;
          const cfg = getCfg(c.name);
          opt.textContent = `${cfg.icon} ${c.name}`;
          sel.appendChild(opt);
        });
      }
    } catch(e) {}
  }

  async function loadBooks(search, categoryId) {
    search = search ?? currentSearch;
    categoryId = categoryId ?? currentCategory;
    showSkeleton();
    try {
      const params = new URLSearchParams({ limit: 200 });
      if (search) params.append('search', search);
      if (categoryId) params.append('categoria_id', categoryId);
      const r = await fetch(`${BACKEND}/books/catalog?${params}`);
      if (!r.ok) throw new Error();
      allBooks = await r.json();
      updateStats();
      renderBooks();
    } catch(e) {
      showError();
    }
  }

  function setupSearch() {
    const input = document.getElementById('searchInput');
    const clearBtn = document.getElementById('clearSearch');
    const catSel = document.getElementById('categorySelect');
    const sortSel = document.getElementById('sortSelect');
    let timer;
    input.addEventListener('input', () => {
      clearBtn.style.display = input.value ? 'flex' : 'none';
      clearTimeout(timer);
      timer = setTimeout(() => { currentSearch = input.value.trim(); loadBooks(currentSearch, currentCategory); updatePills(); }, 380);
    });
    clearBtn.addEventListener('click', () => {
      input.value = ''; clearBtn.style.display = 'none';
      currentSearch = ''; loadBooks('', currentCategory); updatePills();
    });
    catSel.addEventListener('change', () => {
      const val = catSel.value;
      if (val === '__bestsellers__') {
        showOnlyBestsellers = true;
        currentCategory = '';
      } else {
        showOnlyBestsellers = false;
        currentCategory = val;
      }
      loadBooks(currentSearch, currentCategory);
      updatePills();
    });
    sortSel.addEventListener('change', () => { currentSort = sortSel.value; renderBooks(); });
  }

  function getSorted(books) {
    const b = [...books];
    if (currentSort === 'price-asc') return b.sort((a,z) => a.precio - z.precio);
    if (currentSort === 'price-desc') return b.sort((a,z) => z.precio - a.precio);
    if (currentSort === 'name-asc') return b.sort((a,z) => a.nombre.localeCompare(z.nombre));
    if (currentSort === 'bestseller') return b.sort((a,z) => (z.es_bestseller?1:0) - (a.es_bestseller?1:0));
    return b;
  }

  function renderBooks() {
    const grid = document.getElementById('booksGrid');
    const empty = document.getElementById('emptyState');
    document.getElementById('skeletonGrid').style.display = 'none';
    const filtered = showOnlyBestsellers ? allBooks.filter(b => b.es_bestseller) : allBooks;
    const books = getSorted(filtered);
    if (books.length === 0) { grid.style.display = 'none'; empty.style.display = 'flex'; return; }
    empty.style.display = 'none';
    grid.style.display = 'grid';
    grid.innerHTML = books.map(b => bookCardHTML(b)).join('');
    const srStat = document.getElementById('searchResultStat');
    if (currentSearch || currentCategory) {
      srStat.style.display = 'flex';
      document.getElementById('searchResultCount').textContent = books.length;
    } else { srStat.style.display = 'none'; }
    if (isCliente) {
      grid.querySelectorAll('.btn-buy').forEach(btn => {
        btn.addEventListener('click', () => openBuyModal({
          id: +btn.dataset.id, nombre: btn.dataset.nombre,
          precio: +btn.dataset.precio, stock: +btn.dataset.stock, imagen_url: btn.dataset.img || ''
        }));
      });
    }
  }

  // ============================================================
  // BOOK CARD HTML — portada colorida por categoría
  // ============================================================
  function bookCardHTML(book) {
    const precio = parseFloat(book.precio);
    const catName = book.categoria?.name || '';
    const cfg = getCfg(catName);
    const outOfStock = book.stock === 0;
    const lowStock = book.stock > 0 && book.stock < 5;
    const hasImg = !!book.imagen_url;
    const imgUrl = hasImg ? `${BACKEND_BASE}${book.imagen_url}` : '';

    // Cover: image OR colorful placeholder
    const shortTitle = book.nombre.length > 30 ? book.nombre.substring(0, 30) + '…' : book.nombre;
    const shortAuthor = (book.autor || '').length > 26 ? (book.autor || '').substring(0, 26) + '…' : (book.autor || '');
    const coverContent = hasImg
      ? `<img src="${imgUrl}" alt="${book.nombre}" class="cover-img" loading="lazy" width="230" height="200"
            onerror="this.style.display='none';this.nextElementSibling.style.removeProperty('display')">`
      : '';
    const placeholderDisplay = hasImg ? 'display:none;' : '';

    // Tags by category
    const tagBadge = catName
      ? `<span class="book-cat-tag" style="background:${cfg.bg};color:${cfg.color}">${cfg.icon} ${catName}</span>`
      : '';

    // Stock label
    const stockLabel = outOfStock
      ? `<span class="book-stock out">✖ Sin stock</span>`
      : lowStock
        ? `<span class="book-stock low">⚡ Solo ${book.stock} disponibles</span>`
        : `<span class="book-stock ok">✔ ${book.stock} disponibles</span>`;

    // Buy button
    const buyBtn = isCliente && !outOfStock
      ? `<button class="btn-buy" data-id="${book.id}" data-nombre="${book.nombre}" data-precio="${precio}" data-stock="${book.stock}" data-img="${book.imagen_url || ''}" title="Comprar">🛒</button>`
      : '';

    // PDF preview button (visible to all if book has PDF)
    const pdfPreviewBtn = book.has_pdf
      ? `<button class="btn-pdf-preview" onclick="openPdfPreview(${book.id}, '${book.nombre.replace(/'/g,"\'").replace(/"/g,'\"')}', '${(book.autor||'').replace(/'/g,"\'")}')" title="Vista previa del libro">📄 Vista previa</button>`
      : '';

    // Bestseller ribbon
    const bestseller = book.es_bestseller ? `<div class="badge-bestseller">⭐ Bestseller</div>` : '';
    const outBadge = outOfStock ? `<div class="badge-out">Agotado</div>` : '';
    const lowBadge = lowStock && !outOfStock ? `<div class="badge-low">¡Últimas!</div>` : '';

    // Discount badge
    const tieneDescuento = !!book.precio_original;
    const precioOriginal = tieneDescuento ? parseFloat(book.precio_original) : null;
    const discountPct = tieneDescuento ? Math.round((1 - precio / precioOriginal) * 100) : 0;
    const discountBadge = tieneDescuento ? `<div class="badge-discount">-${discountPct}%</div>` : '';

    // Editorial line
    const editLine = book.editorial
      ? `<p class="book-editorial">${book.editorial}${book.anio_publicacion ? ' · ' + book.anio_publicacion : ''}</p>`
      : '';

    return `
      <article class="book-card${outOfStock ? ' oos' : ''}${tieneDescuento ? ' has-discount' : ''}">
        <div class="book-cover" style="background:${cfg.light}">
          ${coverContent}
          <div class="cover-placeholder" style="${placeholderDisplay}background:${cfg.light};">
            <div class="ph-glow" style="background:radial-gradient(circle at 50% 40%, ${cfg.color}30 0%, transparent 68%)"></div>
            <span class="ph-icon" style="color:${cfg.color}">${cfg.icon}</span>
            <p class="ph-title" style="color:${cfg.color}">${shortTitle}</p>
            <p class="ph-author" style="color:${cfg.color}">${shortAuthor}</p>
          </div>
          ${bestseller}${outBadge}${lowBadge}${discountBadge}
        </div>
        <div class="book-info">
          ${tagBadge}
          <h3 class="book-name">${book.nombre}</h3>
          <p class="book-author">✍️ ${book.autor}</p>
          ${editLine}
          <div class="book-bottom">
            <div>
              ${tieneDescuento
                ? `<p class="book-price">L ${precio.toFixed(2)} <span class="book-price-original">L ${precioOriginal.toFixed(2)}</span></p>`
                : `<p class="book-price">L ${precio.toFixed(2)}</p>`
              }
              ${stockLabel}
            </div>
            <div style="display:flex;flex-direction:column;gap:0.35rem;align-items:flex-end">
              ${buyBtn}
              ${pdfPreviewBtn}
            </div>
          </div>
        </div>
      </article>`;
  }

  function updateStats() {
    document.getElementById('totalCount').textContent = allBooks.length;
    document.getElementById('bestsellerCount').textContent = allBooks.filter(b => b.es_bestseller).length;
  }

  function updatePills() {
    const c = document.getElementById('filterPills');
    const pills = [];
    if (currentSearch) pills.push(`<span class="pill">🔍 "${currentSearch}" <button onclick="clearSearch()">✕</button></span>`);
    if (showOnlyBestsellers) {
      pills.push(`<span class="pill pill-bestseller">⭐ Bestsellers <button onclick="clearCategory()">✕</button></span>`);
    } else if (currentCategory) {
      const cat = categories.find(x => x.id == currentCategory);
      if (cat) { const cfg = getCfg(cat.name); pills.push(`<span class="pill" style="background:${cfg.bg};color:${cfg.color}">${cfg.icon} ${cat.name} <button onclick="clearCategory()" style="color:${cfg.color}">✕</button></span>`); }
    }
    c.innerHTML = pills.join('');
    c.style.display = pills.length ? 'flex' : 'none';
  }

  window.clearSearch = () => {
    document.getElementById('searchInput').value = '';
    document.getElementById('clearSearch').style.display = 'none';
    currentSearch = ''; loadBooks('', currentCategory); updatePills();
  };
  window.clearCategory = () => {
    document.getElementById('categorySelect').value = '';
    currentCategory = '';
    showOnlyBestsellers = false;
    loadBooks(currentSearch, '');
    updatePills();
  };
  window.clearAllFilters = () => { clearSearch(); clearCategory(); };

  function showSkeleton() {
    document.getElementById('skeletonGrid').style.display = 'grid';
    document.getElementById('booksGrid').style.display = 'none';
    document.getElementById('emptyState').style.display = 'none';
    document.getElementById('errorState').style.display = 'none';
  }
  function showError() {
    document.getElementById('skeletonGrid').style.display = 'none';
    document.getElementById('booksGrid').style.display = 'none';
    document.getElementById('emptyState').style.display = 'none';
    document.getElementById('errorState').style.display = 'flex';
  }

  // ============================================================
  // BUY MODAL — siempre cantidad 1 (copia digital)
  // ============================================================
  function openBuyModal(book) {
    buyBook = book;
    const thumbHtml = book.imagen_url
      ? `<img src="${BACKEND_BASE}${book.imagen_url}" class="buy-thumb" alt="${book.nombre}" onerror="this.style.display='none';this.nextSibling.style.display='flex'">`
      : '';
    const thumbDefault = `<div class="buy-thumb-default" style="display:${book.imagen_url?'none':'flex'}">📖</div>`;
    document.getElementById('buyBookInfo').innerHTML = `
      <div class="buy-book-card">
        ${thumbHtml}${thumbDefault}
        <div>
          <h4 class="buy-book-name">${book.nombre}</h4>
          <p class="buy-book-price-unit">L ${parseFloat(book.precio).toFixed(2)}</p>
          <p class="buy-book-avail">${book.stock} disponibles</p>
        </div>
      </div>`;
    document.getElementById('buyTotal').textContent = `L ${parseFloat(book.precio).toFixed(2)}`;
    document.getElementById('buyModal').style.display = 'flex';
  }

  document.getElementById('closeBuyModal')?.addEventListener('click', () => { document.getElementById('buyModal').style.display = 'none'; });

  // Payment method toggle
  document.querySelectorAll('input[name="payMethod"]').forEach(r => {
    r.addEventListener('change', () => {
      document.getElementById('cardFields').style.display = r.value === 'tarjeta' ? 'block' : 'none';
    });
  });
  document.getElementById('cancelBuyBtn')?.addEventListener('click', () => { document.getElementById('buyModal').style.display = 'none'; });

  document.getElementById('confirmBuyBtn')?.addEventListener('click', async () => {
    if (!buyBook) return;
    const btn = document.getElementById('confirmBuyBtn');
    btn.disabled = true; btn.textContent = 'Procesando…';
    try {
      const tok = localStorage.getItem('token');
      const r = await fetch(`${BACKEND}/sales/online`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${tok}` },
        body: JSON.stringify({
          tipo: 'ONLINE',
          items: [{ libro_id: buyBook.id, cantidad: 1 }],
          notas: (() => {
            const pm = document.querySelector('input[name="payMethod"]:checked')?.value || 'efectivo';
            const rtn = document.getElementById('buyRtn').value.trim();
            const c4 = document.getElementById('cardLast4')?.value.trim();
            let n = 'Copia digital | Pago: ' + pm.charAt(0).toUpperCase() + pm.slice(1);
            if (pm === 'tarjeta' && c4) n += ' (*' + c4 + ')';
            if (rtn) n += ' | RTN: ' + rtn;
            return n;
          })()
        })
      });
      if (!r.ok) {
        const d = await r.json();
        const msg = Array.isArray(d.detail)
          ? d.detail.map(e => e.msg).join(', ')
          : (d.detail || 'Error al comprar');
        throw new Error(msg);
      }
      document.getElementById('buyModal').style.display = 'none';
      Modal.success('¡Compra realizada!', `Compraste <strong>${buyBook.nombre}</strong> (copia digital). Puedes leerlo en "Mis Libros".`);
      await loadBooks();
    } catch(e) {
      Modal.error('Error al comprar', e.message);
    } finally {
      btn.disabled = false; btn.textContent = '🛒 Confirmar compra';
    }
  });

  // ── PDF PREVIEW ──────────────────────────────────────────────────────────
  let prevPdfDoc = null, prevPage = 1;
  const prevCanvas = document.getElementById('prevCanvas');
  const prevCtx = prevCanvas ? prevCanvas.getContext('2d') : null;

  // Block right-click on preview
  document.getElementById('pdfPreviewModal')?.addEventListener('contextmenu', e => e.preventDefault());

  window.openPdfPreview = async function(bookId, title, author) {
    prevPage = 1;
    document.getElementById('prevBookTitle').textContent = title;
    document.getElementById('prevBookAuthor').textContent = author;
    document.getElementById('prevCurrentPage').textContent = '1';
    document.getElementById('prevTotalPages').textContent = '—';
    document.getElementById('prevCanvas').style.display = 'none';
    document.getElementById('prevBlurGate').style.display = 'none';
    document.getElementById('prevLoading').style.display = 'flex';
    document.getElementById('pdfPreviewModal').style.display = 'flex';

    try {
      const r = await fetch(`${BACKEND}/books/pdf-preview/${bookId}`);
      if (!r.ok) throw new Error('No disponible');
      const buf = await r.arrayBuffer();
      prevPdfDoc = await pdfjsLib.getDocument({ data: buf }).promise;
      document.getElementById('prevTotalPages').textContent = prevPdfDoc.numPages;
      document.getElementById('prevLoading').style.display = 'none';
      document.getElementById('prevCanvas').style.display = 'block';
      await renderPrevPage(1);
    } catch(e) {
      document.getElementById('prevLoading').innerHTML = '<p style="color:#dc2626">No hay vista previa disponible para este libro.</p>';
    }
  };

  async function renderPrevPage(num) {
    if (!prevPdfDoc) return;
    const page = await prevPdfDoc.getPage(num);
    const wrap = document.getElementById('prevCanvasWrap');
    const scale = (wrap.clientWidth * 0.88) / page.getViewport({scale:1}).width;
    const viewport = page.getViewport({ scale });
    prevCanvas.width = viewport.width;
    prevCanvas.height = viewport.height;
    await page.render({ canvasContext: prevCtx, viewport }).promise;
    document.getElementById('prevCurrentPage').textContent = num;
    document.getElementById('prevPdfPrev').disabled = num <= 1;
    // Last preview page shows blur gate for next
    const isLast = num >= prevPdfDoc.numPages;
    document.getElementById('nextPdfPrev').disabled = isLast;
    document.getElementById('prevBlurGate').style.display = isLast ? 'flex' : 'none';
  }

  document.getElementById('prevPdfPrev')?.addEventListener('click', () => {
    if (prevPage > 1) { prevPage--; renderPrevPage(prevPage); }
  });
  document.getElementById('nextPdfPrev')?.addEventListener('click', () => {
    if (prevPdfDoc && prevPage < prevPdfDoc.numPages) { prevPage++; renderPrevPage(prevPage); }
  });
  document.getElementById('closePdfPreview')?.addEventListener('click', () => {
    document.getElementById('pdfPreviewModal').style.display = 'none';
    prevPdfDoc = null;
  });

  // LOGOUT
  document.getElementById('logoutBtn')?.addEventListener('click', () => {
    localStorage.removeItem('token'); localStorage.removeItem('user');
    document.cookie = 'token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
    document.cookie = 'user=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
    window.location.href = '/catalogo';
  });

  init();
</script>

