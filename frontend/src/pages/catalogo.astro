  .badge-out { position:absolute; inset:0; background:rgba(0,0,0,0.52); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:0.9rem; z-index:2; }
  .badge-low { position:absolute; top:8px; right:8px; background:linear-gradient(135deg,#ef4444,#dc2626); color:white; padding:3px 9px; border-radius:999px; font-size:0.65rem; font-weight:700; z-index:2; }
  .badge-discount { position:absolute; bottom:8px; left:8px; background:linear-gradient(135deg,#dc2626,#991b1b); color:white; padding:4px 10px; border-radius:999px; font-size:0.72rem; font-weight:800; z-index:2; box-shadow:0 2px 8px rgba(220,38,38,0.45); letter-spacing:0.02em; }
  .book-price-original { font-size:0.78rem; color:#94a3b8; text-decoration:line-through; margin-left:4px; font-weight:400; }
  .book-card.has-discount .book-price { color:#dc2626; }

  /* BOOK INFO — más padding y gaps */
  .book-info { padding:1rem 1.125rem 1.125rem; flex:1; display:flex; flex-direction:column; gap:0.4rem; }
  .book-cat-tag { display:inline-block; padding:3px 9px; border-radius:999px; font-size:0.67rem; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; }
  .book-name { font-family:var(--font-display); font-size:0.97rem; font-weight:700; color:var(--navy); line-height:1.35; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; margin-top:0.1rem; }
  .book-author { font-size:0.78rem; color:var(--gray-400); font-weight:500; }
  .book-editorial { font-size:0.72rem; color:var(--gray-400); }
  .book-bottom { display:flex; align-items:flex-start; justify-content:space-between; margin-top:auto; padding-top:0.75rem; border-top:1px solid var(--gray-100); gap:0.5rem; }
  .book-stars, .book-stars-empty { display:flex; align-items:center; gap:.35rem; font-size:.78rem; cursor:pointer; margin:.3rem 0; color:var(--gray-500); }
  .book-stars:hover, .book-stars-empty:hover { opacity:.8; }
  .star-count { font-size:.75rem; color:var(--gray-400); }
  .btn-review { background:var(--beige-light); color:#92400e; border:none; border-radius:6px; padding:3px 9px; font-size:.7rem; font-weight:600; cursor:pointer; white-space:nowrap; transition:all .15s; }
  .btn-review:hover { background:var(--beige); }
  .btn-ver-resenas { background:#fef9c3; color:#92400e; border:1px solid #fde68a; border-radius:6px; padding:3px 9px; font-size:.7rem; font-weight:700; cursor:pointer; white-space:nowrap; transition:all .15s; font-family:inherit; }
  .btn-ver-resenas:hover { background:#fde68a; }

  /* View-only reviews modal */
  .vr-box { background:white; border-radius:var(--radius-lg); box-shadow:0 20px 60px rgba(0,0,0,.28); width:100%; max-width:580px; max-height:88vh; display:flex; flex-direction:column; overflow:hidden; animation:vrSlide .22s ease; }
  @keyframes vrSlide { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }
  .vr-header { display:flex; align-items:flex-start; justify-content:space-between; padding:1.25rem 1.5rem; border-bottom:1px solid var(--gray-100); flex-shrink:0; gap:1rem; }
  .vr-title { font-family:var(--font-display); font-size:1.15rem; font-weight:700; color:var(--navy); line-height:1.3; }
  .vr-sub { font-size:.82rem; color:var(--gray-400); margin-top:3px; }
  .vr-close { width:32px; height:32px; border-radius:50%; background:var(--gray-100); border:none; cursor:pointer; font-size:.85rem; flex-shrink:0; transition:background .15s; }
  .vr-close:hover { background:var(--gray-200); }
  .vr-body { overflow-y:auto; flex:1; padding:1.25rem 1.5rem; display:flex; flex-direction:column; gap:.875rem; }
  .vr-loading,.vr-empty { text-align:center; padding:2.5rem 1rem; color:var(--gray-400); display:flex; flex-direction:column; align-items:center; gap:.5rem; }
  .vr-item { background:var(--gray-50); border:1px solid var(--gray-100); border-radius:10px; padding:1rem; }
  .vr-item-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:.35rem; }
  .vr-stars { color:#f59e0b; font-size:1rem; letter-spacing:1px; }
  .vr-date { font-size:.72rem; color:var(--gray-400); }
  .vr-titulo { font-weight:700; font-size:.88rem; color:var(--navy); margin-bottom:.25rem; }
  .vr-cuerpo { font-size:.85rem; color:var(--gray-600); line-height:1.6; }
  .vr-author { font-size:.75rem; color:var(--gray-400); font-style:italic; margin-top:.4rem; }
  .book-price { font-size:1.05rem; font-weight:700; color:var(--blue-mid); white-space:nowrap; }
  .book-stock { font-size:0.72rem; font-weight:600; margin-top:2px; }
  .book-stock.ok { color:#16a34a; }
  .book-stock.low { color:#d97706; }
  .book-stock.out { color:#dc2626; }
  .btn-buy { width:34px; height:34px; border-radius:50%; background:var(--blue-mid); color:white; border:none; cursor:pointer; font-size:0.85rem; display:flex; align-items:center; justify-content:center; transition:all 0.2s; flex-shrink:0; box-shadow:0 2px 8px rgba(37,99,235,0.3); }
  .btn-buy:hover { background:var(--blue-dark); transform:scale(1.1); }

  /* SKELETON — misma altura que la cover real */
  @keyframes shimmer { 0%{background-position:-500px 0} 100%{background-position:500px 0} }
  .skeleton { background:linear-gradient(90deg,var(--gray-100) 25%,var(--gray-200) 50%,var(--gray-100) 75%); background-size:1000px 100%; animation:shimmer 1.5s infinite linear; border-radius:var(--radius-sm); }
  .book-skeleton { background:var(--bg-card); border-radius:var(--radius); overflow:hidden; border:1px solid var(--gray-200); }
  .sk-img { height:200px; border-radius:0; }
  .sk-body { padding:1rem 1.125rem 1.125rem; display:flex; flex-direction:column; gap:0.6rem; }
  .sk-badge { height:16px; width:65px; border-radius:999px; }
  .sk-title { height:14px; }
  .sk-short { width:72%; }
  .sk-author { height:12px; width:52%; }
  .sk-price { height:17px; width:40%; margin-top:0.3rem; }

  /* EMPTY / ERROR */
  .empty-state,.error-state { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5rem 2rem; text-align:center; gap:1rem; }
  .empty-illustration { font-size:4rem; }
  .empty-title { font-family:var(--font-display); font-size:1.5rem; color:var(--navy); }
  .empty-desc { color:var(--gray-400); max-width:360px; }

  /* BUY MODAL */
  .buy-modal-overlay { position:fixed; inset:0; background:rgba(13,27,46,0.65); backdrop-filter:blur(4px); z-index:8000; display:flex; align-items:center; justify-content:center; padding:1rem; }
  .buy-modal-box { background:var(--bg-card); border-radius:var(--radius-lg); box-shadow:var(--shadow-lg); width:100%; max-width:460px; overflow:hidden; animation:slideUp 0.25s ease; }
  @keyframes slideUp { from{opacity:0;transform:translateY(20px) scale(0.97)} to{opacity:1;transform:none} }
  .buy-modal-header { display:flex; align-items:center; justify-content:space-between; padding:1.25rem 1.5rem; border-bottom:1px solid var(--gray-100); }
  .buy-modal-title { font-family:var(--font-display); font-size:1.25rem; color:var(--navy); }
  .buy-modal-close { background:var(--gray-100); border:none; border-radius:50%; width:32px; height:32px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:0.8rem; }
  .buy-modal-body { padding:1.5rem; display:flex; flex-direction:column; gap:1.25rem; }
  .buy-book-card { display:flex; gap:1rem; align-items:flex-start; padding:1rem; background:var(--gray-50); border-radius:var(--radius-sm); border:1px solid var(--gray-200); }
  .buy-thumb { width:70px; height:95px; object-fit:cover; border-radius:6px; display:block; }
  .buy-thumb-default { width:70px; height:95px; background:linear-gradient(135deg,var(--blue-dark),var(--navy)); border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:1.75rem; }
  .buy-book-name { font-family:var(--font-display); font-size:1rem; font-weight:600; color:var(--navy); margin-bottom:0.25rem; }
  .buy-book-price-unit { font-size:0.875rem; color:var(--blue-mid); font-weight:600; }
  .buy-book-avail { font-size:0.8rem; color:var(--gray-400); }
  .buy-digital-notice { display:flex; gap:0.875rem; align-items:flex-start; background:#eff6ff; border:1.5px solid #bfdbfe; border-radius:10px; padding:0.875rem 1rem; }
  .buy-digital-icon { font-size:1.5rem; flex-shrink:0; }
  .buy-digital-title { font-weight:700; font-size:0.85rem; color:#1d4ed8; margin-bottom:2px; }
  .buy-digital-desc { font-size:0.78rem; color:#3b82f6; line-height:1.4; }
  .buy-total-row { display:flex; justify-content:space-between; align-items:center; padding:1rem; background:var(--blue-ghost); border-radius:var(--radius-sm); border:1.5px solid var(--blue-pale); }
  .buy-total-amount { font-family:var(--font-display); font-size:1.35rem; font-weight:700; color:var(--blue-mid); }
  .buy-modal-footer { display:flex; justify-content:flex-end; gap:0.75rem; padding:1rem 1.5rem 1.5rem; }

  .buy-section-title { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--gray-400); margin:0.875rem 0 0.5rem; }
  .pay-method-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:0.5rem; margin-bottom:0.75rem; }
  .pay-method-opt { cursor:pointer; }
  .pay-method-opt input { display:none; }
  .pay-method-card { display:flex; align-items:center; justify-content:center; padding:0.55rem; border:1.5px solid var(--gray-200); border-radius:var(--radius-sm); font-size:0.78rem; font-weight:600; transition:all 0.15s; background:var(--bg-card); gap:0.3rem; }
  .pay-method-opt input:checked + .pay-method-card { border-color:var(--blue-mid); background:var(--blue-ghost); color:var(--blue-mid); }
  .pay-method-card:hover { border-color:var(--blue-mid); }
  .card-fields-wrap { margin-bottom:0.5rem; }
  .buy-price-breakdown { display:flex; flex-direction:column; gap:0.3rem; }
  .buy-breakdown-row { display:flex; justify-content:space-between; font-size:0.88rem; color:var(--gray-600); }
  .buy-breakdown-row.muted { font-size:0.8rem; color:var(--gray-400); }
  .buy-breakdown-row.grand { font-size:1.05rem; font-weight:700; color:var(--navy); margin-top:0.35rem; padding-top:0.5rem; border-top:2px solid var(--gray-200); }

  @media(max-width:768px) {
    .hero-section { padding:3rem 1rem 2rem; }
    .main-wrap { padding:1.25rem 1rem; }
    .books-grid { grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:1.25rem; }
    .book-cover { height:170px; }
    .sk-img { height:170px; }
    .book-info { padding:0.875rem; }
    .nav-inner { padding:0 1rem; }
    .hero-search { flex-direction:column; }
    .category-select { width:100%; }
  }

  /* ── CART NAV BUTTON ── */
  .cart-nav-btn { position:relative; display:flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:50%; background:rgba(255,255,255,0.1); color:white; text-decoration:none; font-size:1.1rem; transition:background 0.2s; }
  .cart-nav-btn:hover { background:rgba(255,255,255,0.2); }
  .cart-nav-badge { position:absolute; top:-3px; right:-3px; background:#ef4444; color:white; border-radius:999px; min-width:18px; height:18px; font-size:0.65rem; font-weight:700; display:inline-flex; align-items:center; justify-content:center; padding:0 4px; border:2px solid rgba(13,27,46,0.9); }

  /* ── CART BUTTON ON CARD ── */
  .btn-cart { display:flex; align-items:center; gap:0.3rem; padding:5px 10px; border-radius:6px; background:var(--blue-mid); color:white; border:none; cursor:pointer; font-size:0.72rem; font-weight:700; transition:all 0.2s; white-space:nowrap; box-shadow:0 2px 6px rgba(37,99,235,0.3); }
  .btn-cart:hover { background:var(--blue-dark); transform:scale(1.04); }
  .btn-owned { display:flex; align-items:center; gap:0.3rem; padding:5px 10px; border-radius:6px; background:#dcfce7; color:#16a34a; font-size:0.72rem; font-weight:700; border:1px solid #86efac; white-space:nowrap; }

  /* ── TOAST NOTIFICATION ── */
  .cart-toast { position:fixed; bottom:2rem; right:2rem; background:var(--bg-card); border-radius:12px; padding:0.875rem 1.25rem; box-shadow:0 8px 30px rgba(13,27,46,0.18); border:1px solid #e2e8f0; display:flex; align-items:center; gap:0.75rem; font-size:0.875rem; color:#0d1b2e; z-index:9999; transform:translateY(120%); opacity:0; transition:all 0.35s cubic-bezier(0.34,1.56,0.64,1); max-width:360px; border-left:4px solid #2563eb; }
  .cart-toast.show { transform:translateY(0); opacity:1; }
  .cart-toast a { color:#2563eb; font-weight:700; text-decoration:none; white-space:nowrap; }
  .cart-toast a:hover { text-decoration:underline; }
  /* ── PDF PREVIEW BUTTON ── */
  .btn-pdf-preview { background:var(--gray-100);color:var(--gray-600);border:1px solid var(--gray-200);border-radius:6px;padding:4px 9px;font-size:0.68rem;font-weight:600;cursor:pointer;white-space:nowrap;transition:all 0.15s; }
  .btn-pdf-preview:hover { background:#eff6ff;color:var(--blue-mid);border-color:var(--blue-mid); }

  /* ── PDF PREVIEW MODAL ── */
  .pdf-prev-overlay { position:fixed;inset:0;background:rgba(13,27,46,0.82);backdrop-filter:blur(6px);z-index:9500;display:flex;align-items:center;justify-content:center;padding:1rem; }
  .pdf-prev-box { background:var(--bg-card);border-radius:12px;width:100%;max-width:720px;max-height:92vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.5); }
  .pdf-prev-topbar { display:flex;align-items:center;justify-content:space-between;padding:0.875rem 1.25rem;background:#0d1b2e;gap:1rem;flex-shrink:0; }
  .pdf-prev-meta { flex:1;min-width:0; }
  .pdf-prev-title { font-weight:700;font-size:0.9rem;color:white;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
  .pdf-prev-author { font-size:0.72rem;color:rgba(255,255,255,0.45); }
  .pdf-prev-controls { display:flex;align-items:center;gap:0.5rem; }
  .pdf-prev-nav { width:28px;height:28px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:white;border-radius:6px;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center; }
  .pdf-prev-nav:disabled { opacity:0.3;cursor:default; }
  .pdf-prev-page { font-size:0.78rem;color:rgba(255,255,255,0.6);white-space:nowrap; }
  .pdf-prev-lock { font-size:0.72rem;font-weight:700;color:#f59e0b;background:rgba(245,158,11,0.15);padding:3px 8px;border-radius:999px;border:1px solid rgba(245,158,11,0.3); }
  .pdf-prev-close { width:28px;height:28px;background:rgba(255,255,255,0.08);border:none;color:white;border-radius:50%;cursor:pointer;font-size:0.8rem; }
  .pdf-prev-close:hover { background:rgba(239,68,68,0.4); }
  .pdf-prev-canvas-wrap { flex:1;overflow-y:auto;overflow-x:auto;display:flex;align-items:flex-start;justify-content:center;padding:1.25rem;background:#1f2937;position:relative;min-height:300px; }
  .pdf-prev-canvas-wrap canvas { box-shadow:0 4px 20px rgba(0,0,0,0.4);border-radius:2px;display:block; }
  .pdf-prev-loading { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.75rem;color:rgba(255,255,255,0.5);padding:3rem; }
  @keyframes pdf-spin { to { transform:rotate(360deg); } }
  .pdf-prev-spinner { width:36px;height:36px;border:3px solid rgba(255,255,255,0.15);border-top-color:#2563eb;border-radius:50%;animation:pdf-spin 0.8s linear infinite; }
  .pdf-prev-blur-gate { position:absolute;inset:0;background:linear-gradient(to bottom,rgba(31,41,55,0) 0%,rgba(31,41,55,0.85) 30%,rgba(31,41,55,0.97) 100%);backdrop-filter:blur(3px);display:flex;align-items:center;justify-content:center;z-index:10; }
  .pdf-prev-blur-content { text-align:center;color:white;padding:2rem;max-width:320px; }
  .pdf-prev-lock-icon { font-size:3rem;margin-bottom:0.75rem; }
  .pdf-prev-blur-content h3 { font-size:1.1rem;font-weight:700;margin-bottom:0.5rem; }
  .pdf-prev-blur-content p { font-size:0.85rem;color:rgba(255,255,255,0.65);margin-bottom:1.25rem;line-height:1.5; }
  .pdf-prev-drm { position:fixed;inset:0;z-index:9501;pointer-events:none; }
  /* ===== Login Required Modal ===== */
  .lrm-overlay { position:fixed; inset:0; background:rgba(13,27,46,0.65); backdrop-filter:blur(4px); z-index:10000; display:flex; align-items:center; justify-content:center; padding:1rem; animation:lrmFadeIn 0.2s ease; }
  @keyframes lrmFadeIn { from { opacity:0; } to { opacity:1; } }
  .lrm-box { position:relative; background:var(--bg-card); border-radius:20px; padding:2.5rem 2rem 2rem; max-width:420px; width:100%; text-align:center; box-shadow:0 24px 60px rgba(13,27,46,0.22); animation:lrmSlideUp 0.25s cubic-bezier(0.34,1.56,0.64,1); }
  @keyframes lrmSlideUp { from { transform:translateY(28px); opacity:0; } to { transform:translateY(0); opacity:1; } }
  .lrm-icon { font-size:3rem; margin-bottom:0.75rem; display:block; }
  .lrm-title { font-size:1.3rem; font-weight:800; color:#0d1b2e; margin:0 0 0.75rem; line-height:1.3; }
  .lrm-body { font-size:0.9rem; color:#475569; line-height:1.65; margin:0 0 1.75rem; }
  .lrm-actions { display:flex; flex-direction:column; gap:0.75rem; }
  .lrm-btn { display:flex; align-items:center; justify-content:center; gap:0.5rem; padding:0.8rem 1.25rem; border-radius:10px; font-size:0.95rem; font-weight:700; text-decoration:none; transition:all 0.2s; }
  .lrm-btn-primary { background:#2563eb; color:white; box-shadow:0 4px 14px rgba(37,99,235,0.35); }
  .lrm-btn-primary:hover { background:#1d4ed8; transform:translateY(-1px); box-shadow:0 6px 18px rgba(37,99,235,0.4); }
  .lrm-btn-secondary { background:#f1f5f9; color:#0d1b2e; border:1.5px solid #e2e8f0; }
  .lrm-btn-secondary:hover { background:#e2e8f0; transform:translateY(-1px); }
  .lrm-close { position:absolute; top:0.9rem; right:0.9rem; background:none; border:none; font-size:1rem; color:#94a3b8; cursor:pointer; width:30px; height:30px; display:flex; align-items:center; justify-content:center; border-radius:50%; transition:all 0.2s; }
  .lrm-close:hover { background:#f1f5f9; color:#475569; }
  /* Review modal inner box */
  .review-modal-inner { background:var(--bg-card); color:var(--text-main); }
  html.dark .lrm-title  { color: #f1f5f9; }
  html.dark .lrm-body   { color: #94a3b8; }
  html.dark .lrm-close  { color: #64748b; }
  html.dark .lrm-close:hover { background: rgba(255,255,255,0.08); color: #94a3b8; }
  html.dark .lrm-btn-secondary { background: rgba(255,255,255,0.06); color: #e2e8f0; border-color: rgba(255,255,255,0.1); }
  html.dark .lrm-btn-secondary:hover { background: rgba(255,255,255,0.12); }
  html.dark .cart-toast { color: #e2e8f0; border-color: rgba(255,255,255,0.08); }
  html.dark .cart-toast a { color: #60a5fa; }
  /* adv panel dark */
  html.dark .adv-toggle-btn { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.12); color: #94a3b8; }
  html.dark .adv-toggle-btn:hover { border-color: var(--blue-mid); color: #93c5fd; }
  html.dark .adv-panel { border-color: rgba(255,255,255,0.08); }
  html.dark .adv-label { color: #64748b; }
  html.dark .adv-input { background: rgba(255,255,255,0.05) !important; border-color: rgba(255,255,255,0.12) !important; color: #e2e8f0 !important; }
  html.dark .adv-check { color: #94a3b8; }
  html.dark .adv-actions { border-color: rgba(255,255,255,0.07); }
  /* buy modal dark */
  html.dark .buy-modal-title { color: #f1f5f9; }
  html.dark .buy-modal-header { border-color: rgba(255,255,255,0.08); }
  html.dark .buy-modal-close { background: rgba(255,255,255,0.08); color: #94a3b8; }
  html.dark .buy-book-card { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); }
  html.dark .buy-book-name { color: #f1f5f9; }
  html.dark .buy-book-price-unit { color: #60a5fa; }
  html.dark .buy-book-avail { color: #64748b; }
  html.dark .buy-modal-footer { border-color: rgba(255,255,255,0.08); }
  html.dark .buy-section-title { color: #64748b; }
  html.dark .pay-method-card { border-color: rgba(255,255,255,0.12); color: #94a3b8; }
  html.dark .pay-method-opt input:checked + .pay-method-card { border-color: #3b82f6; background: rgba(37,99,235,0.15); color: #93c5fd; }
  html.dark .buy-total-row { background: rgba(37,99,235,0.1); border-color: rgba(37,99,235,0.2); }
  html.dark .buy-digital-notice { background: rgba(37,99,235,0.1); border-color: rgba(37,99,235,0.2); }
  html.dark .buy-digital-title { color: #93c5fd; }
  html.dark .buy-digital-desc { color: #60a5fa; }
  /* review modal dark */
  html.dark .review-modal-inner { background: rgba(15,23,42,0.97) !important; border: 1px solid rgba(255,255,255,0.1); color: #e2e8f0; }
  html.dark .review-modal-inner h2 { color: #f1f5f9; }
  html.dark #reviewTitulo,
  html.dark #reviewComentario { background: rgba(255,255,255,0.05) !important; border-color: rgba(255,255,255,0.12) !important; color: #e2e8f0 !important; }
  html.dark #reviewSummary > div { background: rgba(255,255,255,0.05) !important; }
  html.dark #reviewList > div { border-color: rgba(255,255,255,0.07) !important; }
  /* sort select */
  html.dark .sort-select option { background: #0f172a; color: #e2e8f0; }
  /* stats bar */
  html.dark .stats-bar { background: rgba(255,255,255,0.04) !important; border-color: rgba(255,255,255,0.08) !important; }
  html.dark .stat-num { color: #93c5fd; }
  html.dark .stat-lbl { color: #64748b; }
  html.dark .stat-divider { background: rgba(255,255,255,0.1); }


  /* ══════════════════════════════════════════════════════════════════════
     MODO OSCURO — CATÁLOGO
     Estrategia: fondo profundo navy + tarjetas liquid glass + colores vivos
  ════════════════════════════════════════════════════════════════════════ */

  html.dark body {
    background: #07101f;
    color: #e2e8f0;
  }

  /* Fondo general de la página */
  html.dark .main-wrap {
    background: transparent;
  }

  /* Hero: no cambia, ya es oscuro */

  /* Stats bar */
  html.dark .stats-bar {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
