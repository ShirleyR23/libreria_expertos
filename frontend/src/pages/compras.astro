---
import DashboardLayout from '../layouts/DashboardLayout.astro';

const userStr = Astro.cookies.get('user')?.value;
let user = null;
try { user = userStr ? JSON.parse(userStr) : null; } catch (e) {}
if (!user || user.role_name !== 'ADMIN') return Astro.redirect('/login');
---

<DashboardLayout title="Compras a Proveedores" userRole="ADMIN">
  <!-- TOOLBAR -->
  <div class="v-toolbar">
    <div class="inv-search-wrap">
      <span class="inv-search-icon">🔍</span>
      <input type="text" id="comprasSearch" class="inv-search" placeholder="Buscar por proveedor o ID…">
    </div>
    <button id="newPurchaseBtn" class="btn btn-primary">＋ Nueva Compra</button>
  </div>

  <!-- STATS -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem">
    <div class="inv-stat-card blue"><div class="inv-stat-num" id="statCompras">—</div><div class="inv-stat-lbl">Total compras</div></div>
    <div class="inv-stat-card green"><div class="inv-stat-num" id="statGasto">—</div><div class="inv-stat-lbl">Gasto total</div></div>
    <div class="inv-stat-card orange"><div class="inv-stat-num" id="statPendientes">—</div><div class="inv-stat-lbl">Pendientes</div></div>
  </div>

  <!-- TABLE -->
  <div class="inv-table-card">
    <div id="comprasLoading" class="table-loading-wrap">
      <div class="loading-spinner"></div>
      <p style="color:var(--gray-400);margin-top:0.75rem">Cargando compras…</p>
    </div>
    <div id="comprasTableWrap" class="inv-table-wrap" style="display:none">
      <table class="inv-table">
        <thead>
          <tr><th>#ID</th><th>Proveedor</th><th>Libros</th><th>Total</th><th>Estado</th><th>Fecha</th></tr>
        </thead>
        <tbody id="comprasBody"></tbody>
      </table>
      <div id="comprasEmpty" class="empty-table-msg" style="display:none">No hay compras registradas todavía.</div>
    </div>
  </div>

  <!-- MODAL NUEVA COMPRA -->
  <div id="purchaseModal" class="modal-overlay">
    <div class="modal-box modal-lg" style="max-height:92vh;overflow-y:auto">
      <div class="sale-modal-header">
        <div>
          <div class="sale-modal-title">Nueva Compra a Proveedor</div>
          <div class="sale-modal-sub">Registra la compra de libros a un proveedor</div>
        </div>
        <button id="closePurchaseModal" class="modal-close-btn">✕</button>
      </div>
      <div style="padding:1.25rem 1.75rem">
        <!-- Datos del proveedor -->
        <div class="proveedor-section">
          <div class="section-label">📦 Datos del Proveedor</div>
          <div class="form-grid-2">
            <div class="form-group">
              <label class="form-label">Nombre del proveedor *</label>
              <input type="text" id="provNombre" class="form-input" placeholder="Ej: Editorial Planeta">
            </div>
            <div class="form-group">
              <label class="form-label">Contacto (email/teléfono)</label>
              <input type="text" id="provContacto" class="form-input" placeholder="contacto@editorial.com">
            </div>
          </div>
        </div>

        <!-- Items -->
        <div class="section-label" style="margin-bottom:0.75rem">📚 Libros a comprar</div>
        <div id="purchaseItemsContainer"></div>
        <button id="addPurchaseItemBtn" class="btn btn-secondary btn-sm" style="margin-bottom:1.25rem">＋ Agregar libro</button>

        <div class="form-group">
          <label class="form-label">Notas (opcional)</label>
          <textarea id="purchaseNotas" class="form-input" rows="2" placeholder="Información adicional…"></textarea>
        </div>
        <div class="sale-total-row">
          <span style="font-size:0.95rem;color:var(--gray-600)">Total de la compra:</span>
          <span class="sale-total-val">L <span id="purchaseTotal">0.00</span></span>
        </div>
      </div>
      <div style="padding:1rem 1.75rem 1.5rem;display:flex;justify-content:flex-end;gap:0.75rem;border-top:1px solid var(--gray-100)">
        <button id="cancelPurchaseBtn" class="btn btn-secondary">Cancelar</button>
        <button id="submitPurchaseBtn" class="btn btn-primary">📦 Registrar compra</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script is:inline>
  const API = 'http://localhost:8000/api/v1';
  const token = localStorage.getItem('token');
  let allBooks = [];
  let allPurchases = [];

  // ── LOAD PURCHASES ───────────────────────────────────────────
  async function loadPurchases() {
    document.getElementById('comprasLoading').style.display = 'flex';
    document.getElementById('comprasTableWrap').style.display = 'none';
    try {
      const r = await fetch(`${API}/purchases/`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (!r.ok) throw new Error();
      allPurchases = await r.json();
      renderPurchases(allPurchases);
    } catch(e) {
      document.getElementById('comprasLoading').innerHTML = '<p style="color:var(--danger);padding:2rem">Error al cargar. <button onclick="loadPurchases()" class="btn btn-secondary btn-sm" style="margin-left:0.5rem">Reintentar</button></p>';
    }
  }

  function renderPurchases(purchases) {
    document.getElementById('comprasLoading').style.display = 'none';
    document.getElementById('comprasTableWrap').style.display = 'block';

    const total = purchases.reduce((s, p) => s + parseFloat(p.total || 0), 0);
    document.getElementById('statCompras').textContent = purchases.length;
    document.getElementById('statGasto').textContent = 'L ' + total.toFixed(2);
    document.getElementById('statPendientes').textContent = purchases.filter(p => p.estado === 'PENDIENTE').length;

    const tbody = document.getElementById('comprasBody');
    if (!purchases.length) { tbody.innerHTML = ''; document.getElementById('comprasEmpty').style.display = 'block'; return; }
    document.getElementById('comprasEmpty').style.display = 'none';
    tbody.innerHTML = purchases.map(p => {
      const estadoClass = p.estado === 'COMPLETADA' ? 'badge-success' : p.estado === 'CANCELADA' ? 'badge-danger' : 'badge-warning';
      const fecha = new Date(p.fecha_compra || p.created_at).toLocaleDateString('es-HN', { day:'2-digit', month:'short', year:'numeric' });
      const numLibros = p.items?.length ?? '—';
      return `<tr>
        <td><span class="sale-id">#${p.id}</span></td>
        <td><strong>${p.proveedor_nombre}</strong>${p.proveedor_contacto ? `<br><small style="color:var(--gray-400)">${p.proveedor_contacto}</small>` : ''}</td>
        <td><span class="badge badge-info">${numLibros} título(s)</span></td>
        <td><strong class="inv-price">L ${parseFloat(p.total).toFixed(2)}</strong></td>
        <td><span class="badge ${estadoClass}">${p.estado}</span></td>
        <td class="sale-date">${fecha}</td>
      </tr>`;
    }).join('');
  }

  // ── SEARCH ───────────────────────────────────────────────────
  document.getElementById('comprasSearch')?.addEventListener('input', e => {
    const q = e.target.value.toLowerCase();
    if (!q) { renderPurchases(allPurchases); return; }
    renderPurchases(allPurchases.filter(p => `${p.id} ${p.proveedor_nombre}`.toLowerCase().includes(q)));
  });

  // ── LOAD BOOKS ───────────────────────────────────────────────
  async function loadBooks() {
    if (allBooks.length) return;
    try {
      const r = await fetch(`${API}/books/inventory/all?limit=500`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (r.ok) allBooks = await r.json();
    } catch(e) {}
  }

  // ── MODAL ────────────────────────────────────────────────────
  const modal = document.getElementById('purchaseModal');
  function openModal() { modal.classList.add('show'); }
  function closeModal() {
    modal.classList.remove('show');
    document.getElementById('purchaseItemsContainer').innerHTML = '';
    document.getElementById('provNombre').value = '';
    document.getElementById('provContacto').value = '';
    document.getElementById('purchaseNotas').value = '';
    document.getElementById('purchaseTotal').textContent = '0.00';
  }

  document.getElementById('newPurchaseBtn')?.addEventListener('click', async () => {
    await loadBooks();
    addPurchaseItem();
    openModal();
  });
  document.getElementById('closePurchaseModal')?.addEventListener('click', closeModal);
  document.getElementById('cancelPurchaseBtn')?.addEventListener('click', closeModal);
  modal?.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  function addPurchaseItem() {
    const container = document.getElementById('purchaseItemsContainer');
    const row = document.createElement('div');
    row.className = 'item-row';
    row.innerHTML = `
      <div class="form-group" style="flex:2">
        <label class="form-label">Libro</label>
        <select class="book-select form-input" required>
          <option value="">Seleccionar libro…</option>
          ${allBooks.map(b => `<option value="${b.id}" data-price="${b.precio}">${b.nombre} (stock: ${b.stock})</option>`).join('')}
        </select>
      </div>
      <div class="form-group" style="flex:0 0 100px">
        <label class="form-label">Cantidad</label>
        <input type="number" class="qty-inp form-input" min="1" value="1">
      </div>
      <div class="form-group" style="flex:0 0 130px">
        <label class="form-label">Costo unit. (L)</label>
        <input type="number" class="cost-inp form-input" step="0.01" min="0" placeholder="0.00">
      </div>
      <button type="button" class="remove-row-btn" title="Eliminar">🗑</button>
    `;
    row.querySelector('.qty-inp').addEventListener('input', updatePurchaseTotal);
    row.querySelector('.cost-inp').addEventListener('input', updatePurchaseTotal);
    row.querySelector('.remove-row-btn').addEventListener('click', () => { row.remove(); updatePurchaseTotal(); });
    container.appendChild(row);
  }

  document.getElementById('addPurchaseItemBtn')?.addEventListener('click', addPurchaseItem);

  function updatePurchaseTotal() {
    let total = 0;
    document.querySelectorAll('#purchaseItemsContainer .item-row').forEach(row => {
      const qty = parseInt(row.querySelector('.qty-inp').value) || 0;
      const cost = parseFloat(row.querySelector('.cost-inp').value) || 0;
      total += qty * cost;
    });
    document.getElementById('purchaseTotal').textContent = total.toFixed(2);
  }

  document.getElementById('submitPurchaseBtn')?.addEventListener('click', async () => {
    const provNombre = document.getElementById('provNombre').value.trim();
    if (!provNombre) { Modal.error('Proveedor requerido', 'Ingresa el nombre del proveedor.'); return; }

    const items = [];
    let valid = true;
    document.querySelectorAll('#purchaseItemsContainer .item-row').forEach(row => {
      const bookId = row.querySelector('.book-select').value;
      const qty = parseInt(row.querySelector('.qty-inp').value);
      const cost = parseFloat(row.querySelector('.cost-inp').value);
      if (!bookId || !qty || isNaN(cost) || cost <= 0) { valid = false; return; }
      items.push({ libro_id: parseInt(bookId), cantidad: qty, costo_unitario: cost });
    });
    if (!valid) { Modal.error('Datos incompletos', 'Completa libro, cantidad y costo en todos los ítems.'); return; }
    if (!items.length) { Modal.warning('Sin items', 'Agrega al menos un libro a la compra.'); return; }

    const btn = document.getElementById('submitPurchaseBtn');
    btn.disabled = true; btn.textContent = 'Registrando…';
    try {
      const r = await fetch(`${API}/purchases/`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({
          proveedor_nombre: provNombre,
          proveedor_contacto: document.getElementById('provContacto').value.trim() || null,
          items,
          notas: document.getElementById('purchaseNotas').value
        }),
      });
      if (!r.ok) { const d = await r.json(); throw new Error(d.detail || 'Error al registrar'); }
      closeModal();
      Modal.success('¡Compra registrada!', 'La compra fue registrada y el stock fue actualizado.', () => loadPurchases());
    } catch(e) {
      Modal.error('Error al registrar compra', e.message);
    } finally {
      btn.disabled = false; btn.textContent = '📦 Registrar compra';
    }
  });

  // ── INIT ─────────────────────────────────────────────────────
  loadPurchases();
  setInterval(loadPurchases, 30000);
</script>

<style is:global>
  .v-toolbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; gap:1rem; flex-wrap:wrap; }
  .inv-search-wrap { position:relative; flex:1; max-width:380px; }
  .inv-search-icon { position:absolute; left:0.875rem; top:50%; transform:translateY(-50%); }
  .inv-search { width:100%; padding:0.6rem 0.875rem 0.6rem 2.5rem; border:2px solid var(--gray-200); border-radius:var(--radius-sm); font-family:inherit; font-size:0.9rem; }
  .inv-search:focus { outline:none; border-color:var(--blue-mid); }
  .inv-stat-card { padding:1.25rem 1.5rem; background:white; border-radius:var(--radius); border:1px solid rgba(13,27,46,0.06); box-shadow:0 4px 20px rgba(13,27,46,0.14); }
  .inv-stat-num { font-size:1.75rem; font-weight:700; font-family:var(--font-display); }
  .inv-stat-lbl { font-size:0.8rem; color:var(--gray-400); margin-top:2px; }
  .inv-stat-card.blue .inv-stat-num { color:var(--blue-mid); }
  .inv-stat-card.green .inv-stat-num { color:var(--success); font-size:1.3rem; }
  .inv-stat-card.orange .inv-stat-num { color:var(--warning); }
  .inv-table-card { background:white; border-radius:var(--radius); border:1px solid rgba(13,27,46,0.06); box-shadow:0 4px 20px rgba(13,27,46,0.14); overflow:hidden; }
  .inv-table-wrap { overflow-x:auto; }
  .inv-table { width:100%; border-collapse:collapse; }
  .inv-table th { padding:0.875rem 1rem; text-align:left; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.07em; color:var(--gray-400); font-weight:600; background:var(--gray-50); border-bottom:1px solid var(--gray-200); }
  .inv-table td { padding:0.75rem 1rem; border-bottom:1px solid var(--gray-100); vertical-align:middle; }
  .inv-table tr:last-child td { border-bottom:none; }
  .inv-table tbody tr:hover { background:var(--gray-50); }
  .sale-id { font-family:monospace; font-size:0.8rem; background:var(--gray-100); padding:2px 6px; border-radius:4px; color:var(--gray-600); }
  .inv-price { color:var(--blue-mid); }
  .sale-date { font-size:0.8rem; color:var(--gray-400); }
  .empty-table-msg { text-align:center; padding:3rem; color:var(--gray-400); }
  .table-loading-wrap { display:flex; align-items:center; justify-content:center; padding:4rem 2rem; flex-direction:column; }
  @keyframes spin { to { transform:rotate(360deg); } }
  .loading-spinner { width:44px; height:44px; border:3px solid var(--gray-200); border-top-color:var(--blue-mid); border-radius:50%; animation:spin 0.8s linear infinite; }
  /* MODAL */
  .modal-overlay { position:fixed; inset:0; background:rgba(13,27,46,0.65); backdrop-filter:blur(4px); z-index:9000; display:none; align-items:center; justify-content:center; padding:1rem; }
  .modal-overlay.show { display:flex; }
  .modal-box { background:white; border-radius:var(--radius-lg); box-shadow:var(--shadow-lg); width:100%; }
  .modal-box.modal-lg { max-width:680px; }
  .sale-modal-header { display:flex; justify-content:space-between; align-items:center; padding:1.5rem 1.75rem 1rem; border-bottom:1px solid var(--gray-100); }
  .sale-modal-title { font-family:var(--font-display); font-size:1.3rem; font-weight:700; color:var(--navy); }
  .sale-modal-sub { font-size:0.85rem; color:var(--gray-400); margin-top:2px; }
  .modal-close-btn { width:32px; height:32px; border-radius:50%; border:none; background:var(--gray-100); cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:0.8rem; }
  .modal-close-btn:hover { background:var(--gray-200); }
  .proveedor-section { padding:1rem; background:var(--gray-50); border-radius:var(--radius-sm); border:1.5px solid var(--gray-200); margin-bottom:1.5rem; }
  .section-label { font-size:0.85rem; font-weight:700; color:var(--navy); margin-bottom:0.75rem; }
  .form-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:0 1rem; }
  .item-row { display:flex; align-items:flex-end; gap:0.75rem; padding:1rem; background:var(--gray-50); border-radius:var(--radius-sm); border:1.5px solid var(--gray-200); margin-bottom:0.75rem; }
  .remove-row-btn { background:none; border:none; cursor:pointer; font-size:1.1rem; opacity:0.5; flex-shrink:0; margin-bottom:0.75rem; }
  .remove-row-btn:hover { opacity:1; }
  .sale-total-row { display:flex; justify-content:space-between; align-items:center; padding:1rem 1.25rem; background:var(--blue-ghost); border-radius:var(--radius-sm); border:1.5px solid var(--blue-pale); }
  .sale-total-val { font-family:var(--font-display); font-size:1.5rem; font-weight:700; color:var(--blue-mid); }
</style>
