---
// Dashboard de Empleado
import DashboardLayout from '../layouts/DashboardLayout.astro';

// Verificar que sea empleado
const userStr = Astro.cookies.get('user')?.value;
let user = null;
try {
  user = userStr ? JSON.parse(userStr) : null;
} catch (e) {}

if (!user || (user.role_name !== 'EMPLEADO' && user.role_name !== 'ADMIN')) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';

// Obtener datos
let inventoryAlerts = { reposicion: [], compra_urgente: [] };
let recentSales = [];

try {
  const [alertsRes, salesRes] = await Promise.all([
    fetch(`${API_URL}/expert/inventory-alerts`, {
      headers: { 'Authorization': `Bearer ${Astro.cookies.get('token')?.value}` }
    }),
    fetch(`${API_URL}/sales/all?limit=5`, {
      headers: { 'Authorization': `Bearer ${Astro.cookies.get('token')?.value}` }
    })
  ]);
  
  if (alertsRes.ok) inventoryAlerts = await alertsRes.json();
  if (salesRes.ok) recentSales = await salesRes.json();
} catch (e) {
  console.error('Error:', e);
}
---

<DashboardLayout title="Dashboard Empleado" userRole="EMPLEADO">
  <div class="grid grid-3">
    <div class="stat-card">
      <div class="stat-value" style="color: #f59e0b;">{inventoryAlerts.resumen?.total_alertas_reposicion || 0}</div>
      <div class="stat-label">Alertas de Stock</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: #ef4444;">{inventoryAlerts.resumen?.total_compras_urgentes || 0}</div>
      <div class="stat-label">Compras Urgentes</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color: #22c55e;">{recentSales.length}</div>
      <div class="stat-label">Ventas Recientes</div>
    </div>
  </div>
  
  <div class="grid grid-2 mt-4">
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Accesos Rápidos</h2>
      </div>
      <div class="quick-links">
        <a href="/inventario" class="quick-link">
          <span class="icon">📚</span>
          <span>Ver Inventario</span>
        </a>
        <a href="/ventas" class="quick-link">
          <span class="icon">💰</span>
          <span>Registrar Venta</span>
        </a>
        <a href="/catalogo" class="quick-link">
          <span class="icon">🏪</span>
          <span>Ver Catálogo</span>
        </a>
      </div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Ventas Recientes</h2>
      </div>
      <div class="recent-sales">
        {recentSales.length === 0 ? (
          <p class="empty">No hay ventas recientes</p>
        ) : (
          recentSales.map(sale => (
            <div class="sale-item">
              <div class="sale-info">
                <span class="sale-id">Venta #{sale.id}</span>
                <span class={`badge badge-${sale.status.toLowerCase()}`}>{sale.status}</span>
              </div>
              <span class="sale-total">L {sale.total.toFixed(2)}</span>
            </div>
          ))
        )}
      </div>
    </div>
  </div>
</DashboardLayout>

<style>
  .quick-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .quick-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: #f8fafc;
    border-radius: 8px;
    text-decoration: none;
    color: #1e293b;
    transition: all 0.2s;
  }
  
  .quick-link:hover {
    background: #e0e7ff;
  }
  
  .quick-link .icon {
    font-size: 1.5rem;
  }
  
  .recent-sales {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .sale-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    background: #f8fafc;
    border-radius: 8px;
  }
  
  .sale-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .sale-id {
    font-weight: 500;
  }
  
  .sale-total {
    font-weight: 600;
    color: #3b82f6;
  }
  
  .empty {
    color: #64748b;
    text-align: center;
    padding: 1rem;
  }
  
  .mt-4 {
    margin-top: 1.5rem;
  }
</style>
