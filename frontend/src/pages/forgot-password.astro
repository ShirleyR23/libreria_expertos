---
import PublicLayout from '../layouts/PublicLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';
---
<PublicLayout title="Recuperar contraseña">
<div class="auth-layout">
  <div class="auth-left">
    <div class="auth-left-inner">
      <div class="auth-brand"><span class="auth-brand-icon">📚</span><span class="auth-brand-name">Librería</span></div>
      <h2 class="auth-left-title">¿Olvidaste tu contraseña?</h2>
      <p class="auth-left-desc">No hay problema. Ingresa tu correo y te enviaremos un enlace para restablecerla.</p>
      <div class="auth-features">
        <div class="auth-feature"><span>🔒</span> Enlace seguro y temporal</div>
        <div class="auth-feature"><span>⏱</span> Válido por 30 minutos</div>
        <div class="auth-feature"><span>✉️</span> Revisa también tu carpeta de spam</div>
      </div>
    </div>
  </div>
  <div class="auth-right">
    <div class="login-card">
      <div class="login-header">
        <h1 class="login-title">Recuperar contraseña</h1>
        <p class="login-subtitle">Ingresa el correo de tu cuenta</p>
      </div>

      <div id="successAlert" class="auth-alert auth-alert-success" style="display:none">
        <strong>¡Correo enviado!</strong> Si el email existe en nuestro sistema, recibirás un enlace para restablecer tu contraseña. Revisa también tu carpeta de spam.
      </div>
      <div id="errorAlert" class="auth-alert auth-alert-error" style="display:none"></div>

      <div id="formSection">
        <div class="form-group">
          <label class="form-label">Correo electrónico</label>
          <input type="email" id="emailInput" class="form-input" placeholder="tu@email.com" autocomplete="email">
        </div>
        <button id="submitBtn" class="btn btn-primary btn-full" style="margin-top:1rem">
          <span id="btnText">Enviar enlace de recuperación</span>
          <span id="btnSpinner" class="spinner" style="display:none"></span>
        </button>
      </div>

      <p class="auth-footer-link" style="margin-top:1.5rem">
        <a href="/login">← Volver al inicio de sesión</a>
      </p>
    </div>
  </div>
</div>
</PublicLayout>

<script is:inline define:vars={{ API_URL }}>
  const BACKEND = API_URL || 'http://localhost:8000/api/v1';

  document.getElementById('submitBtn').addEventListener('click', async () => {
    const email = document.getElementById('emailInput').value.trim();
    if (!email) { showError('Por favor ingresa tu correo electrónico.'); return; }

    const btn = document.getElementById('submitBtn');
    const txt = document.getElementById('btnText');
    const spin = document.getElementById('btnSpinner');
    btn.disabled = true; txt.style.display = 'none'; spin.style.display = 'inline-block';
    document.getElementById('errorAlert').style.display = 'none';

    try {
      const r = await fetch(`${BACKEND}/auth/forgot-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      // Always show success (backend doesn't reveal if email exists)
      document.getElementById('formSection').style.display = 'none';
      document.getElementById('successAlert').style.display = 'block';
    } catch(e) {
      showError('Error al conectar con el servidor. Intenta de nuevo.');
    } finally {
      btn.disabled = false; txt.style.display = 'inline'; spin.style.display = 'none';
    }
  });

  document.getElementById('emailInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('submitBtn').click();
  });

  function showError(msg) {
    const el = document.getElementById('errorAlert');
    el.textContent = msg;
    el.style.display = 'block';
  }
</script>

<style is:global>
  /* Reuse auth styles from LoginForm */
  body { margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:#f8fafc; }
  .auth-layout { display:flex; min-height:100vh; }
  .auth-left { width:42%; background:linear-gradient(135deg,#0d1b2e 0%,#1a3560 100%); padding:3rem; display:flex; align-items:center; justify-content:center; }
  .auth-left-inner { max-width:360px; }
  .auth-brand { display:flex; align-items:center; gap:0.75rem; margin-bottom:2.5rem; }
  .auth-brand-icon { font-size:2rem; }
  .auth-brand-name { font-size:1.5rem; font-weight:700; color:white; font-family:'Playfair Display',Georgia,serif; }
  .auth-left-title { font-size:1.75rem; font-weight:700; color:white; line-height:1.3; margin-bottom:1rem; font-family:'Playfair Display',Georgia,serif; }
  .auth-left-desc { color:rgba(255,255,255,0.65); line-height:1.7; font-size:0.95rem; margin-bottom:2rem; }
  .auth-features { display:flex; flex-direction:column; gap:0.875rem; }
  .auth-feature { display:flex; align-items:center; gap:0.75rem; color:rgba(255,255,255,0.8); font-size:0.875rem; }
  .auth-right { flex:1; display:flex; align-items:center; justify-content:center; padding:2rem; }
  .login-card { background:white; border-radius:20px; padding:2.5rem; width:100%; max-width:420px; box-shadow:0 4px 24px rgba(0,0,0,0.08); }
  .login-header { margin-bottom:1.75rem; }
  .login-title { font-family:'Playfair Display',Georgia,serif; font-size:1.75rem; font-weight:700; color:#0d1b2e; margin-bottom:0.35rem; }
  .login-subtitle { color:#94a3b8; font-size:0.9rem; }
  .form-group { display:flex; flex-direction:column; gap:0.35rem; margin-bottom:1rem; }
  .form-label { font-size:0.8rem; font-weight:600; color:#475569; }
  .form-input { padding:0.75rem 1rem; border:1.5px solid #e2e8f0; border-radius:10px; font-size:0.95rem; font-family:inherit; color:#0d1b2e; transition:border-color 0.15s; }
  .form-input:focus { outline:none; border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,0.1); }
  .btn { display:inline-flex; align-items:center; justify-content:center; gap:0.5rem; padding:0.75rem 1.5rem; border-radius:10px; font-weight:600; font-size:0.95rem; cursor:pointer; border:none; transition:all 0.2s; font-family:inherit; }
  .btn-primary { background:#2563eb; color:white; }
  .btn-primary:hover:not(:disabled) { background:#1d4ed8; }
  .btn-primary:disabled { opacity:0.6; cursor:not-allowed; }
  .btn-full { width:100%; }
  .auth-alert { padding:0.875rem 1rem; border-radius:10px; font-size:0.875rem; line-height:1.5; }
  .auth-alert-error { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; margin-bottom:1rem; }
  .auth-alert-success { background:#f0fdf4; color:#16a34a; border:1px solid #86efac; margin-bottom:1rem; }
  .auth-footer-link { text-align:center; font-size:0.85rem; color:#94a3b8; margin-top:0; }
  .auth-footer-link a { color:#2563eb; font-weight:600; text-decoration:none; }
  .spinner { width:16px; height:16px; border:2px solid rgba(255,255,255,0.3); border-top-color:white; border-radius:50%; animation:spin 0.7s linear infinite; }
  @keyframes spin { to { transform:rotate(360deg); } }
  @media(max-width:768px) { .auth-left { display:none; } .auth-right { padding:1.5rem; } }
</style>
