---
import DashboardLayout from '../layouts/DashboardLayout.astro';

const userStr = Astro.cookies.get('user')?.value;
let user = null;
try { user = userStr ? JSON.parse(userStr) : null; } catch (e) {}
if (!user || (user.role_name !== 'EMPLEADO' && user.role_name !== 'ADMIN')) return Astro.redirect('/login');
const isAdmin = user.role_name === 'ADMIN';
---

<DashboardLayout title="Inventario" userRole={user.role_name}>
  <!-- TOOLBAR -->
  <div class="inv-toolbar">
    <div class="inv-search-wrap">
      <span class="inv-search-icon">🔍</span>
      <input type="text" id="invSearch" class="inv-search" placeholder="Buscar libro, autor o ISBN…">
    </div>
    {isAdmin && (
      <button id="addBookBtn" class="btn btn-primary">＋ Nuevo Libro</button>
    )}
  </div>

  <!-- STATS (se llenan vía JS) -->
  <div class="inv-stats">
    <div class="inv-stat-card blue">
      <div class="inv-stat-icon">📚</div>
      <div class="inv-stat-num" id="statTotal">
        <span class="skeleton" style="display:inline-block;width:40px;height:28px;border-radius:4px"></span>
      </div>
      <div class="inv-stat-lbl">Total libros</div>
    </div>
    <div class="inv-stat-card orange">
      <div class="inv-stat-icon">⚠️</div>
      <div class="inv-stat-num" id="statLow">
        <span class="skeleton" style="display:inline-block;width:40px;height:28px;border-radius:4px"></span>
      </div>
      <div class="inv-stat-lbl">Stock bajo</div>
    </div>
    <div class="inv-stat-card red">
      <div class="inv-stat-icon">🚫</div>
      <div class="inv-stat-num" id="statOut">
        <span class="skeleton" style="display:inline-block;width:40px;height:28px;border-radius:4px"></span>
      </div>
      <div class="inv-stat-lbl">Sin stock</div>
    </div>
    <div class="inv-stat-card gold">
      <div class="inv-stat-icon">⭐</div>
      <div class="inv-stat-num" id="statBest">
        <span class="skeleton" style="display:inline-block;width:40px;height:28px;border-radius:4px"></span>
      </div>
      <div class="inv-stat-lbl">Bestsellers</div>
    </div>
  </div>

  <!-- TABLE CARD -->
  <div class="inv-table-card">
    <!-- Loading skeleton for table -->
    <div id="tableSkeleton" class="table-loading-wrap">
      <div class="table-loading-inner">
        <div class="loading-spinner"></div>
        <p class="loading-text">Cargando inventario…</p>
      </div>
    </div>

    <!-- Actual table (hidden until loaded) -->
    <div id="tableWrap" class="inv-table-wrap" style="display:none">
      <table class="inv-table">
        <thead>
          <tr>
            <th>Portada</th>
            <th>Libro</th>
            <th>ISBN</th>
            <th>Categoría</th>
            <th>Stock</th>
            <th>Precio</th>
            <th>Estado</th>
            {isAdmin && <th>Acciones</th>}
          </tr>
        </thead>
        <tbody id="invTableBody"></tbody>
      </table>
    </div>

    <!-- Empty state -->
    <div id="tableEmpty" class="table-empty-state" style="display:none">
      <div style="font-size:3rem;margin-bottom:1rem">📭</div>
      <div style="font-size:1.1rem;font-weight:600;color:var(--navy)">No hay libros en el inventario</div>
      {isAdmin && <p style="color:var(--gray-400);margin-top:0.5rem">Agrega el primero con el botón "Nuevo Libro"</p>}
    </div>

    <!-- Error state -->
    <div id="tableError" class="table-empty-state" style="display:none">
      <div style="font-size:3rem;margin-bottom:1rem">⚠️</div>
      <div style="font-size:1.1rem;font-weight:600;color:var(--navy)">Error al cargar el inventario</div>
      <p style="color:var(--gray-400);margin-top:0.5rem">Verifica que el backend esté activo</p>
      <button onclick="loadInventory()" class="btn btn-primary" style="margin-top:1rem">Reintentar</button>
    </div>
  </div>

  <!-- BOOK MODAL (solo admin) -->
  {isAdmin && (
    <div id="bookModal" class="modal-overlay">
      <div class="modal-box modal-lg">
        <div class="modal-header">
          <div>
            <div class="modal-title" id="modalTitle">Nuevo Libro</div>
            <div class="modal-subtitle" id="modalSubtitle">Completa los datos del libro</div>
          </div>
          <button class="modal-close-btn" id="closeBookModal">✕</button>
        </div>

        <div class="modal-body">
          <input type="hidden" id="bookId">

          <!-- IMAGE UPLOAD -->
          <div class="img-upload-section">
            <div class="img-preview-wrap" id="imgPreviewWrap">
              <div class="img-preview-default" id="imgDefault">📖</div>
              <img id="imgPreview" class="img-preview" style="display:none" alt="Preview">
            </div>
            <div class="img-upload-info">
              <div class="img-upload-title">Portada del libro</div>
              <div class="img-upload-desc">JPG, PNG o WebP · Máx. 5 MB</div>
              <label for="bookImagen" class="btn btn-secondary btn-sm" style="cursor:pointer;display:inline-flex;margin-top:0.5rem">
                📷 Subir imagen
              </label>
              <input type="file" id="bookImagen" accept="image/*" style="display:none">
              <input type="hidden" id="bookImagenUrl">
            </div>
          </div>

          <!-- PDF UPLOAD -->
          <div class="pdf-upload-section" id="pdfUploadSection">
            <div class="pdf-upload-icon" id="pdfIcon">📄</div>
            <div class="pdf-upload-info">
              <div class="pdf-upload-title">PDF del libro <span class="pdf-upload-optional">(opcional)</span></div>
              <div class="pdf-upload-desc" id="pdfUploadDesc">PDF · Máx. 50 MB · Los clientes podrán leerlo en línea</div>
              <div style="display:flex;align-items:center;gap:0.75rem;margin-top:0.5rem;flex-wrap:wrap">
                <label for="bookPdf" class="btn btn-secondary btn-sm" style="cursor:pointer;display:inline-flex" id="pdfUploadLabel">
                  📤 Subir PDF
                </label>
                <input type="file" id="bookPdf" accept="application/pdf" style="display:none">
                <div id="pdfPreviewPagesWrap" style="display:flex;align-items:center;gap:0.5rem">
                  <label class="form-label" style="margin:0;font-size:0.78rem;white-space:nowrap">Páginas gratis:</label>
                  <input type="number" id="bookPdfPages" class="form-input" min="1" max="20" value="3" style="width:60px;padding:4px 8px;font-size:0.85rem">
                </div>
              </div>
              <div id="pdfStatusMsg" style="display:none;margin-top:0.4rem;font-size:0.78rem"></div>
            </div>
          </div>

          <div class="form-grid-2">
            <div class="form-group">
              <label class="form-label">Nombre *</label>
              <input type="text" id="bookNombre" class="form-input" placeholder="Título del libro">
            </div>
            <div class="form-group">
              <label class="form-label">ISBN *</label>
              <input type="text" id="bookIsbn" class="form-input" placeholder="0000000000">
            </div>
            <div class="form-group">
              <label class="form-label">Autor *</label>
              <input type="text" id="bookAutor" class="form-input" placeholder="Nombre del autor">
            </div>
            <div class="form-group">
              <label class="form-label">Editorial</label>
              <input type="text" id="bookEditorial" class="form-input" placeholder="Editorial">
            </div>
            <div class="form-group">
              <label class="form-label">Precio (L) *</label>
              <input type="number" id="bookPrecio" class="form-input" step="0.01" min="0" placeholder="0.00">
            </div>
            <div class="form-group">
              <label class="form-label">Año de publicación</label>
              <input type="number" id="bookAnio" class="form-input" min="1000" max="2100" placeholder="2024">
            </div>
            <div class="form-group">
              <label class="form-label">Stock inicial *</label>
              <input type="number" id="bookStock" class="form-input" min="0" placeholder="0">
            </div>
            <div class="form-group">
              <label class="form-label">Stock mínimo</label>
              <input type="number" id="bookStockMin" class="form-input" min="0" value="5">
            </div>
            <div class="form-group" style="grid-column:1/-1">
              <label class="form-label">Categoría *</label>
              <select id="bookCategoria" class="form-input">
                <option value="1">Ficción</option>
                <option value="2">No Ficción</option>
                <option value="3">Ciencia</option>
                <option value="4">Tecnología</option>
                <option value="5">Historia</option>
                <option value="6">Arte</option>
                <option value="7">Literatura</option>
                <option value="8">Infantil</option>
                <option value="9">Académico</option>
                <option value="10">Filosofía</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Descripción</label>
            <textarea id="bookDescripcion" class="form-input" rows="3" placeholder="Breve descripción del libro…"></textarea>
          </div>

        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" id="cancelBookBtn">Cancelar</button>
          <button type="button" class="btn btn-primary" id="saveBookBtn">
            <span id="saveBtnText">💾 Guardar libro</span>
          </button>
        </div>
      </div>
    </div>
  )}
</DashboardLayout>

<script is:inline define:vars={{ isAdmin }}>
  const API_URL = (typeof window !== 'undefined' && window.__ENV_API_URL) || 'http://localhost:8000/api/v1';
  const token = localStorage.getItem('token');
  let allBooks = [];

  // ============================================================
  // CATEGORY CONFIG (colores e iconos por categoría)
  // ============================================================
  const CAT_CONFIG = {
    'FICCION':     { color: '#7c3aed', bg: '#f5f3ff', icon: '🌙' },
    'NO_FICCION':  { color: '#0891b2', bg: '#ecfeff', icon: '📰' },
    'CIENCIA':     { color: '#16a34a', bg: '#f0fdf4', icon: '🔬' },
    'TECNOLOGIA':  { color: '#2563eb', bg: '#eff6ff', icon: '💻' },
    'HISTORIA':    { color: '#b45309', bg: '#fffbeb', icon: '🏛️' },
    'ARTE':        { color: '#db2777', bg: '#fdf2f8', icon: '🎨' },
    'LITERATURA':  { color: '#ea580c', bg: '#fff7ed', icon: '✒️' },
    'INFANTIL':    { color: '#e11d48', bg: '#fff1f2', icon: '🦄' },
    'ACADEMICO':   { color: '#4338ca', bg: '#eef2ff', icon: '🎓' },
    'FILOSOFIA':   { color: '#475569', bg: '#f8fafc', icon: '🧠' },
  };

  function getCatConfig(catName) {
    const key = (catName || '').toUpperCase().replace(/\s/g,'_').replace(/Ó/g,'O').replace(/Í/g,'I');
    return CAT_CONFIG[key] || { color: '#1d4ed8', bg: '#eff6ff', icon: '📖' };
  }

  // ============================================================
  // LOAD INVENTORY
  // ============================================================
  window.loadInventory = async function() {
    showTableState('loading');
    try {
      const r = await fetch(`${API_URL}/books/inventory/all?limit=500`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!r.ok) throw new Error(`HTTP ${r.status}`);
      allBooks = await r.json();
      updateStats();
      renderTable();
    } catch(e) {
      console.error('Error cargando inventario:', e);
      showTableState('error');
    }
  };

  function updateStats() {
    document.getElementById('statTotal').textContent = allBooks.length;
    document.getElementById('statLow').textContent = allBooks.filter(b => b.stock > 0 && b.stock <= b.stock_minimo).length;
    document.getElementById('statOut').textContent = allBooks.filter(b => b.stock === 0).length;
    document.getElementById('statBest').textContent = allBooks.filter(b => b.es_bestseller).length;
  }

  function renderTable(books) {
    books = books || allBooks;
    const tbody = document.getElementById('invTableBody');
    if (books.length === 0) { showTableState('empty'); return; }
    showTableState('table');
    tbody.innerHTML = books.map(book => {
      const cat = book.categoria?.name || '';
      const cfg = getCatConfig(cat);
      const stockClass = book.stock === 0 ? 'stock-out' : book.stock <= book.stock_minimo ? 'stock-low' : 'stock-ok';
      const thumb = book.imagen_url
        ? `<img src="http://localhost:8000${book.imagen_url}" class="inv-thumb" loading="lazy" onerror="this.style.display='none';this.nextSibling.style.display='flex'">`
        : '';
      const thumbDefault = `<div class="inv-thumb-default" style="background:${cfg.bg};color:${cfg.color};${book.imagen_url?'display:none':''}">
        <span style="font-size:1.5rem">${cfg.icon}</span>
      </div>`;
      const actionsHTML = isAdmin ? `
        <td>
          <div class="inv-actions">
            <button class="action-btn edit-btn" onclick="editBook(${book.id})" title="Editar">✏️</button>
            <button class="action-btn del-btn" onclick="deleteBook(${book.id}, '${book.nombre.replace(/'/g,"\\'")}')" title="Eliminar">🗑️</button>
          </div>
        </td>` : '';
      const tagHtml = cat ? `<span class="cat-tag" style="background:${cfg.bg};color:${cfg.color}">${cfg.icon} ${cat}</span>` : '—';
      let statusHtml = '';
      if (book.es_bestseller) statusHtml += `<span class="badge-bs">⭐ Bestseller</span> `;
      if (book.stock === 0) statusHtml += `<span class="badge-out-of-stock">Sin stock</span>`;
      else if (!book.es_bestseller) statusHtml += `<span class="badge-ok">Activo</span>`;
      return `<tr data-search="${(book.nombre+' '+book.autor+' '+book.isbn).toLowerCase()}">
        <td><div class="inv-thumb-wrap">${thumb}${thumbDefault}</div></td>
        <td>
          <div class="inv-book-name">${book.nombre}</div>
          <div class="inv-book-author">✍️ ${book.autor}</div>
        </td>
        <td><span class="inv-isbn">${book.isbn}</span></td>
        <td>${tagHtml}</td>
        <td><span class="stock-badge ${stockClass}">${book.stock}</span></td>
        <td><strong class="inv-price">L ${parseFloat(book.precio).toFixed(2)}</strong></td>
        <td>${statusHtml}</td>
        ${actionsHTML}
      </tr>`;
    }).join('');
  }

  function showTableState(state) {
    document.getElementById('tableSkeleton').style.display = state === 'loading' ? 'flex' : 'none';
    document.getElementById('tableWrap').style.display = state === 'table' ? 'block' : 'none';
    document.getElementById('tableEmpty').style.display = state === 'empty' ? 'flex' : 'none';
    document.getElementById('tableError').style.display = state === 'error' ? 'flex' : 'none';
  }

  // ---- SEARCH ----
  document.getElementById('invSearch')?.addEventListener('input', e => {
    const q = e.target.value.toLowerCase().trim();
    if (!q) { renderTable(allBooks); return; }
    renderTable(allBooks.filter(b =>
      (b.nombre + ' ' + b.autor + ' ' + b.isbn).toLowerCase().includes(q)
    ));
  });

  // ---- MODAL ----
  const modal = document.getElementById('bookModal');
  const openModal = () => { if (modal) modal.classList.add('show'); };
  const closeModal = () => { if (modal) { modal.classList.remove('show'); resetForm(); } };

  document.getElementById('addBookBtn')?.addEventListener('click', () => {
    document.getElementById('modalTitle').textContent = 'Nuevo Libro';
    document.getElementById('modalSubtitle').textContent = 'Completa los datos del libro';
    openModal();
  });
  document.getElementById('closeBookModal')?.addEventListener('click', closeModal);
  document.getElementById('cancelBookBtn')?.addEventListener('click', closeModal);
  modal?.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  function resetForm() {
    ['bookId','bookNombre','bookIsbn','bookAutor','bookEditorial','bookPrecio','bookAnio',
     'bookStock','bookDescripcion','bookImagenUrl','provNombre','provContacto','provTelefono','costoCompra'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = '';
    });
    const sm = document.getElementById('bookStockMin'); if (sm) sm.value = '5';
    const pp = document.getElementById('bookPdfPages'); if (pp) pp.value = '3';
    document.getElementById('imgPreview').style.display = 'none';
    document.getElementById('imgDefault').style.display = 'flex';
    // Reset PDF section
    document.getElementById('pdfIcon').textContent = '📄';
    document.getElementById('pdfUploadDesc').textContent = 'PDF · Máx. 50 MB · Los clientes podrán leerlo en línea';
    document.getElementById('pdfUploadLabel').textContent = '📤 Subir PDF';
    document.getElementById('pdfStatusMsg').style.display = 'none';
    document.getElementById('pdfStatusMsg').textContent = '';
    if (document.getElementById('bookPdf')) document.getElementById('bookPdf').value = '';
  }

  // ---- IMAGE UPLOAD ----
  document.getElementById('bookImagen')?.addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      document.getElementById('imgPreview').src = ev.target.result;
      document.getElementById('imgPreview').style.display = 'block';
      document.getElementById('imgDefault').style.display = 'none';
    };
    reader.readAsDataURL(file);
    const formData = new FormData();
    formData.append('file', file);
    try {
      const r = await fetch(`${API_URL}/books/upload-image`, {
        method: 'POST', headers: { 'Authorization': `Bearer ${token}` }, body: formData
      });
      if (!r.ok) throw new Error('Error al subir imagen');
      const data = await r.json();
      document.getElementById('bookImagenUrl').value = data.url;
    } catch(err) {
      Modal.error('Error de imagen', 'No se pudo subir la imagen. El libro se guardará sin portada.');
    }
  });

  // ---- PDF UPLOAD (se puede hacer al crear O al editar) ----
  document.getElementById('bookPdf')?.addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const bookId = document.getElementById('bookId').value;
    // If editing an existing book, upload immediately
    if (bookId) {
      const statusEl = document.getElementById('pdfStatusMsg');
      const labelEl = document.getElementById('pdfUploadLabel');
      statusEl.style.display = 'block';
      statusEl.style.color = '#2563eb';
      statusEl.textContent = '⏳ Subiendo PDF…';
      labelEl.textContent = '⏳ Subiendo…';
      const formData = new FormData();
      formData.append('file', file);
      try {
        const r = await fetch(`${API_URL}/books/upload-pdf/${bookId}`, {
          method: 'POST', headers: { 'Authorization': `Bearer ${token}` }, body: formData
        });
        if (!r.ok) { const d = await r.json(); throw new Error(d.detail || 'Error al subir PDF'); }
        statusEl.style.color = '#16a34a';
        statusEl.textContent = '✅ PDF subido correctamente';
        document.getElementById('pdfIcon').textContent = '✅';
        labelEl.textContent = '📤 Cambiar PDF';
        const pages = parseInt(document.getElementById('bookPdfPages').value) || 3;
        await fetch(`${API_URL}/books/${bookId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ pdf_preview_pages: pages })
        });
      } catch(err) {
        statusEl.style.color = '#dc2626';
        statusEl.textContent = '❌ ' + err.message;
        labelEl.textContent = '📤 Subir PDF';
        e.target.value = '';
      }
    } else {
      // New book — just show file name, will be uploaded on save
      const statusEl = document.getElementById('pdfStatusMsg');
      statusEl.style.display = 'block';
      statusEl.style.color = '#2563eb';
      statusEl.textContent = `📄 "${file.name}" listo — se subirá al guardar el libro`;
      document.getElementById('pdfIcon').textContent = '📄';
      document.getElementById('pdfUploadLabel').textContent = '📄 ' + file.name.substring(0,22) + (file.name.length>22?'…':'');
    }
  });

  // ---- SAVE ----
  document.getElementById('saveBookBtn')?.addEventListener('click', async () => {
    const bookId = document.getElementById('bookId').value;
    const isNewBook = !bookId;
    const nombre = document.getElementById('bookNombre').value.trim();
    const isbn = document.getElementById('bookIsbn').value.trim();
    const autor = document.getElementById('bookAutor').value.trim();
    const precio = parseFloat(document.getElementById('bookPrecio').value);
    const stock = parseInt(document.getElementById('bookStock').value);
    if (!nombre || !isbn || !autor || isNaN(precio)) {
      Modal.error('Campos incompletos', 'Completa todos los campos obligatorios marcados con (*).');
      return;
    }
    if (isNaN(stock)) {
      Modal.error('Campos incompletos', 'El campo Stock es obligatorio.');
      return;
    }
    const pdfPages = parseInt(document.getElementById('bookPdfPages').value) || 3;
    const bookData = {
      nombre, isbn, autor, precio,
      stock: stock || 0,
      stock_minimo: parseInt(document.getElementById('bookStockMin').value) || 5,
      categoria_id: parseInt(document.getElementById('bookCategoria').value),
      editorial: document.getElementById('bookEditorial').value.trim() || null,
      anio_publicacion: parseInt(document.getElementById('bookAnio').value) || null,
      descripcion: document.getElementById('bookDescripcion').value.trim() || null,
      imagen_url: document.getElementById('bookImagenUrl').value || null,
      pdf_preview_pages: pdfPages,
    };
    const btn = document.getElementById('saveBookBtn');
    btn.disabled = true;
    document.getElementById('saveBtnText').textContent = 'Guardando…';
    try {
      const url = bookId ? `${API_URL}/books/${bookId}` : `${API_URL}/books/`;
      const method = bookId ? 'PUT' : 'POST';
      const r = await fetch(url, {
        method, headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify(bookData),
      });
      if (!r.ok) { const d = await r.json(); throw new Error(d.detail || 'Error al guardar'); }
      const savedBook = await r.json();
      const newBookId = savedBook.id || bookId;

      // ── Upload PDF if one was selected ──────────────────────────────
      const pdfFile = document.getElementById('bookPdf')?.files?.[0];
      if (pdfFile && newBookId) {
        document.getElementById('saveBtnText').textContent = 'Subiendo PDF…';
        const formData = new FormData();
        formData.append('file', pdfFile);
        const pdfR = await fetch(`${API_URL}/books/upload-pdf/${newBookId}`, {
          method: 'POST', headers: { 'Authorization': `Bearer ${token}` }, body: formData
        });
        if (!pdfR.ok) {
          const pd = await pdfR.json();
          // Book saved OK but PDF failed — warn but don't block
          closeModal();
          Modal.warning('Libro guardado, PDF falló', `El libro fue guardado pero no se pudo subir el PDF: ${pd.detail || 'Error desconocido'}. Puedes subirlo editando el libro.`, () => loadInventory());
          return;
        }
      }

      closeModal();
      const msg = isNewBook
        ? `<strong>${nombre}</strong> fue agregado correctamente.${pdfFile ? ' El PDF también fue cargado.' : ''}`
        : `<strong>${nombre}</strong> fue actualizado correctamente.`;
      Modal.success(bookId ? '¡Libro actualizado!' : '¡Libro creado!', msg, () => loadInventory());
    } catch(err) {
      Modal.error('Error al guardar', err.message);
    } finally {
      btn.disabled = false;
      document.getElementById('saveBtnText').textContent = '💾 Guardar libro';
    }
  });

  // ---- EDIT ----
  window.editBook = async (id) => {
    try {
      const r = await fetch(`${API_URL}/books/${id}`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (!r.ok) throw new Error();
      const book = await r.json();
      document.getElementById('bookId').value = book.id;
      document.getElementById('bookNombre').value = book.nombre;
      document.getElementById('bookIsbn').value = book.isbn;
      document.getElementById('bookAutor').value = book.autor;
      document.getElementById('bookEditorial').value = book.editorial || '';
      document.getElementById('bookPrecio').value = book.precio;
      document.getElementById('bookAnio').value = book.anio_publicacion || '';
      document.getElementById('bookStock').value = book.stock;
      document.getElementById('bookStockMin').value = book.stock_minimo;
      document.getElementById('bookCategoria').value = book.categoria_id;
      document.getElementById('bookDescripcion').value = book.descripcion || '';
      document.getElementById('bookImagenUrl').value = book.imagen_url || '';
      document.getElementById('bookPdfPages').value = book.pdf_preview_pages || 3;
      if (book.imagen_url) {
        document.getElementById('imgPreview').src = `http://localhost:8000${book.imagen_url}`;
        document.getElementById('imgPreview').style.display = 'block';
        document.getElementById('imgDefault').style.display = 'none';
      } else {
        document.getElementById('imgPreview').style.display = 'none';
        document.getElementById('imgDefault').style.display = 'flex';
      }
      // Show PDF status
      const statusEl = document.getElementById('pdfStatusMsg');
      if (book.has_pdf) {
        document.getElementById('pdfIcon').textContent = '✅';
        document.getElementById('pdfUploadDesc').textContent = 'PDF cargado — los clientes pueden leerlo en línea';
        document.getElementById('pdfUploadLabel').textContent = '📤 Reemplazar PDF';
        statusEl.style.display = 'block';
        statusEl.style.color = '#16a34a';
        statusEl.textContent = '✅ Este libro ya tiene PDF disponible';
      } else {
        document.getElementById('pdfIcon').textContent = '📄';
        document.getElementById('pdfUploadDesc').textContent = 'PDF · Máx. 50 MB · Los clientes podrán leerlo en línea';
        document.getElementById('pdfUploadLabel').textContent = '📤 Subir PDF';
        statusEl.style.display = 'none';
      }
      document.getElementById('modalTitle').textContent = 'Editar Libro';
      document.getElementById('modalSubtitle').textContent = book.nombre;
      openModal();
    } catch(e) {
      Modal.error('Error', 'No se pudo cargar el libro.');
    }
  };

  // ---- DELETE ----
  window.deleteBook = (id, nombre) => {
    Modal.confirm('¿Eliminar libro?',
      `¿Deseas eliminar <strong>${nombre}</strong>? Esta acción no se puede deshacer.`,
      async () => {
        try {
          const r = await fetch(`${API_URL}/books/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` } });
          if (!r.ok) throw new Error('Error al eliminar');
          Modal.success('Libro eliminado', `<strong>${nombre}</strong> fue eliminado del inventario.`, () => loadInventory());
        } catch(e) {
          Modal.error('Error al eliminar', e.message);
        }
      }
    );
  };

  // ---- INIT: cargar al abrir la página ----
  loadInventory();
  setInterval(loadInventory, 30000);
</script>

