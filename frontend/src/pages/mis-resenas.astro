---
import DashboardLayout from '../layouts/DashboardLayout.astro';
const userStr = Astro.cookies.get('user')?.value;
let user = null;
try { user = userStr ? JSON.parse(userStr) : null; } catch (e) {}
if (!user || user.role_name !== 'CLIENTE') return Astro.redirect('/login');
---
<DashboardLayout title="Mis Reseñas" userRole="CLIENTE">
<style>
  .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem}
  .page-title{font-family:var(--font-display);font-size:1.75rem;color:var(--navy)}
  .reviews-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem}
  .review-card{background:var(--bg-card);border:1px solid var(--gray-200);border-radius:var(--radius);padding:1.25rem;display:flex;flex-direction:column;gap:.75rem;transition:box-shadow .2s}
  .review-card:hover{box-shadow:var(--shadow)}
  .rc-book{font-weight:700;color:var(--navy);font-size:.95rem;line-height:1.3}
  .rc-stars{display:flex;gap:2px;font-size:1.15rem}
  .rc-titulo{font-weight:600;font-size:.9rem;color:var(--gray-800)}
  .rc-body{font-size:.88rem;color:var(--gray-600);line-height:1.55}
  .rc-date{font-size:.78rem;color:var(--gray-400)}
  .rc-actions{display:flex;gap:.5rem;margin-top:.25rem}
  .empty-state{text-align:center;padding:4rem 2rem;color:var(--gray-600)}
  .empty-icon{font-size:3.5rem;margin-bottom:1rem}
  /* MODAL */
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(13,27,46,.6);z-index:9999;align-items:center;justify-content:center;padding:1rem}
  .modal-overlay.show{display:flex}
  .modal-box{background:var(--bg-card);border-radius:var(--radius-lg);padding:2rem;width:100%;max-width:500px;animation:slideUp .25s ease}
  @keyframes slideUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
  /* Stars picker */
  .stars-picker{display:flex;gap:6px;font-size:1.75rem;cursor:pointer;margin:.5rem 0}
  .stars-picker span{transition:transform .1s}
  .stars-picker span:hover,.stars-picker span.sel{transform:scale(1.2)}

  /* ══ PAGE-LEVEL DARK MODE + LIQUID GLASS + RESPONSIVE ══════════════════ */

  /* -- Liquid Glass base (claro y oscuro) -- */
  .glass-card {
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(18px) saturate(180%);
    -webkit-backdrop-filter: blur(18px) saturate(180%);
    border: 1px solid rgba(255,255,255,0.55);
    box-shadow: 0 4px 24px rgba(13,27,46,0.10), inset 0 1px 0 rgba(255,255,255,0.8);
    border-radius: var(--radius);
  }
  html.dark .glass-card {
    background: rgba(30,41,59,0.55);
    border-color: rgba(255,255,255,0.08);
    box-shadow: 0 4px 24px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.06);
  }

  /* -- Stat cards glass -- */
  html.dark .inv-stat-card,
  html.dark .stat-card {
    background: rgba(30,41,59,0.6) !important;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: rgba(255,255,255,0.07) !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.05) !important;
  }

  /* -- Table card glass -- */
  html.dark .inv-table-card,
  html.dark .card {
    background: rgba(20,30,50,0.7) !important;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-color: rgba(255,255,255,0.07) !important;
  }
  html.dark .inv-table-card { box-shadow: 0 4px 24px rgba(0,0,0,0.4) !important; }

  /* -- Table internals -- */
  html.dark .inv-table, html.dark table { background: transparent !important; }
  html.dark .inv-table th, html.dark th {
    background: rgba(10,15,30,0.6) !important;
    color: #64748b !important;
    border-color: rgba(255,255,255,0.06) !important;
  }
  html.dark .inv-table td, html.dark td {
    border-color: rgba(255,255,255,0.05) !important;
    color: #cbd5e1 !important;
  }
  html.dark .inv-table tbody tr:hover td,
  html.dark tr:hover td { background: rgba(37,99,235,0.08) !important; }

  /* -- Supplier cards glass -- */
  html.dark .supplier-card {
    background: rgba(20,30,50,0.65) !important;
    backdrop-filter: blur(14px);
    border-color: rgba(255,255,255,0.07) !important;
    box-shadow: 0 2px 16px rgba(0,0,0,0.3) !important;
  }
  html.dark .supplier-card:hover {
    background: rgba(30,50,80,0.8) !important;
    border-color: rgba(99,179,237,0.25) !important;
  }

  /* -- Page modal glass -- */
  html.dark .page-modal-overlay {
    background: rgba(5,10,20,0.8) !important;
    backdrop-filter: blur(8px) !important;
  }
  html.dark .page-modal-box {
    background: rgba(15,23,42,0.92) !important;
    backdrop-filter: blur(24px) saturate(160%) !important;
    -webkit-backdrop-filter: blur(24px) saturate(160%) !important;
    border: 1px solid rgba(255,255,255,0.09) !important;
    box-shadow: 0 20px 60px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.06) !important;
    color: #e2e8f0 !important;
  }
  html.dark .page-modal-box .sale-modal-header,
  html.dark .page-modal-box .modal-close-btn { border-color: rgba(255,255,255,0.07) !important; }
  html.dark .page-modal-box .sale-modal-title { color: #f1f5f9 !important; }
  html.dark .page-modal-box .sale-modal-sub   { color: #64748b !important; }
  html.dark .page-modal-box .modal-close-btn  { background: rgba(255,255,255,0.07) !important; color: #94a3b8 !important; }

  /* -- Forms inside modals & pages -- */
  html.dark .form-input,
  html.dark .inv-search,
  html.dark .adv-input,
  html.dark .fi,
  html.dark select,
  html.dark input[type="text"],
  html.dark input[type="email"],
  html.dark input[type="number"],
  html.dark input[type="password"],
  html.dark input[type="tel"],
  html.dark input[type="date"],
  html.dark textarea {
    background: rgba(10,15,30,0.6) !important;
    color: #e2e8f0 !important;
    border-color: rgba(255,255,255,0.1) !important;
  }
  html.dark input::placeholder,
  html.dark textarea::placeholder { color: #475569 !important; }
  html.dark input:focus,
  html.dark textarea:focus,
  html.dark select:focus {
    border-color: var(--blue-mid) !important;
    box-shadow: 0 0 0 3px rgba(37,99,235,0.2) !important;
  }
  html.dark select option { background: #0f172a !important; color: #e2e8f0 !important; }

  /* -- Badges dark -- */
  html.dark .badge-success { background: rgba(22,163,74,0.15) !important; color: #4ade80 !important; border: 1px solid rgba(74,222,128,0.2); }
  html.dark .badge-warning { background: rgba(217,119,6,0.15) !important;  color: #fcd34d !important; border: 1px solid rgba(252,211,77,0.2); }
  html.dark .badge-danger  { background: rgba(220,38,38,0.15) !important;  color: #f87171 !important; border: 1px solid rgba(248,113,113,0.2); }
  html.dark .badge-info    { background: rgba(37,99,235,0.15) !important;  color: #93c5fd !important; border: 1px solid rgba(147,197,253,0.2); }

  /* -- Sale/purchase ID chips -- */
  html.dark .sale-id { background: rgba(255,255,255,0.06) !important; color: #94a3b8 !important; }

  /* -- State boxes (empty states) -- */
  html.dark .state-box {
    background: rgba(20,30,50,0.6) !important;
    border-color: rgba(255,255,255,0.08) !important;
    color: #64748b !important;
  }

  /* -- Action buttons -- */
  html.dark .action-btn.edit-btn { background: rgba(37,99,235,0.15) !important; }
  html.dark .action-btn.edit-btn:hover { background: rgba(37,99,235,0.28) !important; }
  html.dark .action-btn.del-btn  { background: rgba(220,38,38,0.12) !important; }
  html.dark .action-btn.del-btn:hover  { background: rgba(220,38,38,0.25) !important; }

  /* -- Search bars -- */
  html.dark .inv-search { background: rgba(10,15,30,0.6) !important; }
  html.dark .inv-search::placeholder { color: #475569 !important; }

  /* -- Page toolbar bg -- */
  html.dark .v-toolbar .btn-secondary,
  html.dark .sort-select,
  html.dark .adv-toggle-btn {
    background: rgba(30,41,59,0.7) !important;
    border-color: rgba(255,255,255,0.1) !important;
    color: #94a3b8 !important;
  }

  /* ══ RESPONSIVE — todas las páginas del dashboard ════════════════════════ */
  @media (max-width: 1024px) {
    .content-area { padding: 1.25rem !important; }
    .grid-4 { grid-template-columns: repeat(2,1fr) !important; }
    .grid-3 { grid-template-columns: repeat(2,1fr) !important; }
    .quick-grid { grid-template-columns: repeat(4,1fr) !important; }
    .inv-stats { grid-template-columns: repeat(2,1fr) !important; }
    .form-grid-2 { grid-template-columns: 1fr 1fr !important; }
  }
  @media (max-width: 768px) {
    .content-area { padding: 1rem !important; }
    .grid-4, .grid-3, .grid-2 { grid-template-columns: 1fr !important; }
    .quick-grid { grid-template-columns: repeat(3,1fr) !important; }
    .inv-stats { grid-template-columns: repeat(2,1fr) !important; }
    .v-toolbar { flex-direction: column !important; align-items: stretch !important; }
    .inv-search-wrap { max-width: 100% !important; }
    .form-grid-2 { grid-template-columns: 1fr !important; }
    .chart-wrap { height: 200px !important; }
    .page-modal-box { max-width: 100% !important; margin: 0 !important; border-radius: var(--radius) !important; }
    .top-bar { padding: 0 1rem !important; }
    .top-bar .page-title { font-size: 1rem !important; }
    .user-chip-role { display: none !important; }
  }
  @media (max-width: 480px) {
    .content-area { padding: 0.75rem !important; }
    .grid-4, .grid-3, .grid-2 { grid-template-columns: 1fr !important; }
    .quick-grid { grid-template-columns: repeat(2,1fr) !important; }
    .inv-stats { grid-template-columns: 1fr 1fr !important; }
    .inv-stat-card { padding: 0.875rem 1rem !important; }
    .stat-value { font-size: 1.5rem !important; }
    .stat-value.stat-sm { font-size: 1.1rem !important; }
    .card { padding: 1rem !important; }
    .inv-table td, .inv-table th { padding: 0.5rem 0.625rem !important; font-size: 0.8rem !important; }
    .sale-id { font-size: 0.7rem !important; }
    .btn { padding: 0.5rem 0.875rem !important; font-size: 0.8rem !important; }
    .page-title { font-size: 0.95rem !important; }
    .dark-toggle { display: none !important; }
    .top-bar { padding: 0 0.75rem !important; }
  }

  /* ── MIS-RESEÑAS DARK MODE ──────────────────────────────────────────────── */
  html.dark .page-title   { color:#f1f5f9; }
  html.dark .review-card  { background:rgba(255,255,255,.05) !important; border-color:rgba(255,255,255,.08) !important; }
  html.dark .review-card:hover { box-shadow:0 8px 24px rgba(0,0,0,.4); }
  html.dark .rc-book      { color:#e2e8f0; }
  html.dark .rc-titulo    { color:#cbd5e1; }
  html.dark .rc-body      { color:#94a3b8; }
  html.dark .rc-date      { color:#475569; }
  html.dark .empty-state  { color:#64748b; }
  html.dark .modal-box    { background:#0f172a !important; border:1px solid rgba(255,255,255,.1); }
  html.dark .modal-box h2 { color:#f1f5f9; }
  html.dark .modal-box label { color:#94a3b8; }
  html.dark .modal-box input,
  html.dark .modal-box textarea { background:rgba(255,255,255,.06) !important; border-color:rgba(255,255,255,.12) !important; color:#e2e8f0 !important; }

</style>

<div class="page-header">
  <h1 class="page-title">⭐ Mis Reseñas</h1>
</div>

<div id="alertBox" style="margin-bottom:1rem"></div>
<div id="loadingEl" style="color:var(--gray-600);padding:2rem">Cargando reseñas…</div>
<div class="reviews-grid" id="reviewsGrid"></div>

<!-- MODAL EDITAR -->
<div class="page-modal-overlay" id="editModal">
  <div class="page-modal-box">
    <h2 style="font-family:var(--font-display);color:var(--navy);margin-bottom:1.25rem">Editar reseña</h2>
    <input type="hidden" id="editId">
    <div class="form-group">
      <label class="form-label">Calificación</label>
      <div class="stars-picker" id="starsPicker">
        <span data-v="1">★</span><span data-v="2">★</span><span data-v="3">★</span>
        <span data-v="4">★</span><span data-v="5">★</span>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Título</label>
      <input type="text" class="form-input" id="editTitulo" placeholder="Resume tu opinión">
    </div>
    <div class="form-group">
      <label class="form-label">Comentario</label>
      <textarea class="form-input" id="editComentario" rows="4" placeholder="Cuéntanos más…"></textarea>
    </div>
    <div style="display:flex;gap:.75rem;margin-top:1.25rem">
      <button class="btn btn-secondary" style="flex:1" onclick="closeModal()">Cancelar</button>
      <button class="btn btn-primary" style="flex:1" id="saveEditBtn" onclick="saveEdit()">Guardar cambios</button>
    </div>
  </div>
</div>

<script>
import { getMyReviews, updateReview, deleteReview } from '../services/api.js';

let reviews = [];
let editCal = 5;

const stars = (n, size='1rem') => '★'.repeat(n) + '☆'.repeat(5-n);
const fmt   = d => new Date(d).toLocaleDateString('es-HN',{day:'2-digit',month:'short',year:'numeric'});
const alert = (msg, type='success') => {
  const el = document.getElementById('alertBox');
  el.innerHTML = `<div class="alert alert-${type}">${msg}</div>`;
  setTimeout(() => el.innerHTML = '', 3500);
};

function render() {
  document.getElementById('loadingEl').style.display = 'none';
  const grid = document.getElementById('reviewsGrid');
  if (!reviews.length) {
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
      <div class="empty-icon">⭐</div>
      <h3>Todavía no tienes reseñas</h3>
      <p style="margin:.5rem 0 1.5rem">Compra un libro y comparte tu opinión</p>
      <a href="/catalogo" class="btn btn-primary">Ver catálogo</a>
    </div>`;
    return;
  }
  grid.innerHTML = reviews.map(r => `
    <div class="review-card" id="rc-${r.id}">
      <div class="rc-book">📖 ${r.libro_nombre || 'Libro #' + r.libro_id}</div>
      <div class="rc-stars" style="color:#f59e0b" title="${r.calificacion}/5">${stars(r.calificacion)}</div>
      ${r.titulo    ? `<div class="rc-titulo">${r.titulo}</div>` : ''}
      ${r.comentario ? `<div class="rc-body">${r.comentario}</div>` : ''}
      <div class="rc-date">${fmt(r.created_at)}</div>
      <div class="rc-actions">
        <button class="btn btn-secondary btn-sm" onclick="openEdit(${r.id})">✏️ Editar</button>
        <button class="btn btn-danger btn-sm" onclick="confirmDelete(${r.id})">🗑 Eliminar</button>
      </div>
    </div>`).join('');
}

window.openEdit = (id) => {
  const r = reviews.find(x => x.id === id);
  if (!r) return;
  document.getElementById('editId').value = id;
  document.getElementById('editTitulo').value = r.titulo || '';
  document.getElementById('editComentario').value = r.comentario || '';
  setStars(r.calificacion);
  document.getElementById('editModal').classList.add('show');
};

window.closeModal = () => document.getElementById('editModal').classList.remove('show');

function setStars(val) {
  editCal = val;
  document.querySelectorAll('#starsPicker span').forEach(s => {
    const v = parseInt(s.dataset.v);
    s.classList.toggle('sel', v <= val);
    s.style.color = v <= val ? '#f59e0b' : '#d1d5db';
  });
}

document.querySelectorAll('#starsPicker span').forEach(s => {
  s.addEventListener('click', () => setStars(parseInt(s.dataset.v)));
  s.addEventListener('mouseenter', () => {
    const v = parseInt(s.dataset.v);
    document.querySelectorAll('#starsPicker span').forEach(x => {
      x.style.color = parseInt(x.dataset.v) <= v ? '#f59e0b' : '#d1d5db';
    });
  });
});
document.getElementById('starsPicker').addEventListener('mouseleave', () => setStars(editCal));
setStars(5);

window.saveEdit = async () => {
  const id   = parseInt(document.getElementById('editId').value);
  const data = {
    calificacion: editCal,
    titulo:       document.getElementById('editTitulo').value.trim() || null,
    comentario:   document.getElementById('editComentario').value.trim() || null,
  };
  const btn = document.getElementById('saveEditBtn');
  btn.disabled = true; btn.textContent = 'Guardando…';
  try {
    const updated = await updateReview(id, data);
    reviews = reviews.map(r => r.id === id
      ? { ...r, calificacion: updated.calificacion, titulo: updated.titulo, comentario: updated.comentario }
      : r
    );
    render();
    closeModal();
    Modal.success('Reseña actualizada', 'Tu reseña ha sido guardada correctamente.');
  } catch(e) {
    Modal.error('Error', e.message || 'No se pudo actualizar la reseña');
  } finally {
    btn.disabled = false; btn.textContent = 'Guardar cambios';
  }
};

window.confirmDelete = async (id) => {
  Modal.confirm('Eliminar reseña', '¿Estás seguro? Esta acción no se puede deshacer.', async () => {
    try {
      await deleteReview(id);
      reviews = reviews.filter(r => r.id !== id);
      render();
      Modal.success('Reseña eliminada', 'Tu reseña ha sido eliminada.');
    } catch(e) { Modal.error('Error', e.message || 'No se pudo eliminar la reseña'); }
  });
};

async function init() {
  try {
    reviews = await getMyReviews();
    render();
  } catch(e) {
    document.getElementById('loadingEl').textContent = 'Error al cargar reseñas: ' + e.message;
  }
}
init();
</script>
</DashboardLayout>