---
import DashboardLayout from '../layouts/DashboardLayout.astro';
const userStr = Astro.cookies.get('user')?.value;
let user = null;
try { user = userStr ? JSON.parse(userStr) : null; } catch (e) {}
if (!user || (user.role_name !== 'ADMIN' && user.role_name !== 'EMPLEADO')) return Astro.redirect('/login');
const isAdmin = user.role_name === 'ADMIN';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';
---

<DashboardLayout title="Proveedores" userRole={user.role_name}>

<!-- PAGE HEADER -->
<div class="page-header">
  <div>
    <h1 class="page-title">🏭 Proveedores</h1>
    <p class="page-sub">Gestiona los proveedores y realiza pedidos de reabastecimiento</p>
  </div>
  {isAdmin && <button id="newSupplierBtn" class="btn btn-primary">+ Nuevo proveedor</button>}
</div>

<!-- STATS ROW -->
<div class="sup-stats-row" id="statsRow" style="display:none">
  <div class="sup-stat-card">
    <div class="sup-stat-icon">🏭</div>
    <div class="sup-stat-num" id="statTotal">—</div>
    <div class="sup-stat-lbl">Proveedores</div>
  </div>
  <div class="sup-stat-card">
    <div class="sup-stat-icon">✅</div>
    <div class="sup-stat-num" id="statActivos">—</div>
    <div class="sup-stat-lbl">Activos</div>
  </div>
  <div class="sup-stat-card">
    <div class="sup-stat-icon">📚</div>
    <div class="sup-stat-num" id="statLibros">—</div>
    <div class="sup-stat-lbl">Libros en catálogos</div>
  </div>
</div>

<!-- STATES -->
<div id="loadingState" class="state-box">
  <div class="state-spinner"></div><p>Cargando proveedores…</p>
</div>
<div id="emptyState" class="state-box" style="display:none">
  <div style="font-size:3rem;margin-bottom:.75rem">🏭</div>
  <h3>No hay proveedores registrados</h3>
  <p>Agrega el primer proveedor para comenzar.</p>
  {isAdmin && <button onclick="openNewSupplier()" class="btn btn-primary" style="margin-top:1rem">+ Agregar proveedor</button>}
</div>

<!-- SUPPLIERS GRID -->
<div id="suppliersGrid" class="suppliers-grid" style="display:none"></div>

<!-- ═══ MODAL: CREAR / EDITAR PROVEEDOR ═══════════════════════════════════ -->
<div id="supplierModal" class="modal-overlay" style="display:none">
  <div class="modal-box modal-lg">
    <div class="modal-header">
      <h2 id="modalTitle" class="modal-title">Nuevo proveedor</h2>
      <button onclick="closeModal('supplierModal')" class="modal-close">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-grid">
        <div class="form-group span2">
          <label class="form-label">Nombre del proveedor *</label>
          <input type="text" id="supNombre" class="form-input" placeholder="Distribuidora XYZ">
        </div>
        <div class="form-group">
          <label class="form-label">Contacto</label>
          <input type="text" id="supContacto" class="form-input" placeholder="Nombre del representante">
        </div>
        <div class="form-group">
          <label class="form-label">Teléfono</label>
          <input type="text" id="supTelefono" class="form-input" placeholder="+504 9999-9999">
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" id="supEmail" class="form-input" placeholder="contacto@proveedor.com">
        </div>
        <div class="form-group">
          <label class="form-label">Dirección</label>
          <input type="text" id="supDireccion" class="form-input" placeholder="Ciudad, País">
        </div>
        <div class="form-group span2">
          <label class="form-label">Notas</label>
          <textarea id="supNotas" class="form-input" rows="2" placeholder="Condiciones, plazos de entrega…"></textarea>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button onclick="closeModal('supplierModal')" class="btn btn-secondary">Cancelar</button>
      <button id="saveSupplierBtn" class="btn btn-primary" onclick="saveSupplier()">
        <span id="saveBtnText">Guardar proveedor</span>
        <span id="saveBtnSpinner" class="spinner" style="display:none"></span>
      </button>
    </div>
  </div>
</div>

<!-- ═══ MODAL: DETALLE DEL PROVEEDOR ═════════════════════════════════════ -->
<div id="detailModal" class="modal-overlay" style="display:none">
  <div class="modal-box modal-xl">
    <div class="modal-header">
      <div>
        <h2 id="detailName" class="modal-title">Proveedor</h2>
        <p id="detailMeta" class="modal-meta"></p>
      </div>
      <div style="display:flex;gap:.5rem;align-items:center">
        <button id="makeOrderBtn" class="btn btn-primary btn-sm">📦 Realizar pedido</button>
        <button onclick="closeModal('detailModal')" class="modal-close">✕</button>
      </div>
    </div>
    <div class="tab-bar">
      <button class="tab active" data-tab="catalog">📚 Catálogo</button>
      <button class="tab" data-tab="history">🧾 Historial</button>
      {isAdmin && <button class="tab" data-tab="edit">✏️ Editar info</button>}
    </div>

    <!-- TAB: CATALOG -->
    <div id="tabCatalog" class="tab-content">
      {isAdmin && (
        <div class="catalog-actions">
          <h4 class="section-sub">Agregar libro al catálogo</h4>
          <div class="catalog-add-row">
            <select id="addBookSelect" class="form-input" style="flex:1">
              <option value="">Cargando libros…</option>
            </select>
            <input type="number" id="addBookCosto" class="form-input" placeholder="Costo (L)" min="0" step="0.01" style="width:130px">
            <button onclick="addBookToCatalog()" class="btn btn-primary btn-sm">+ Agregar</button>
          </div>
          <p id="catalogAddMsg" style="font-size:.8rem;margin-top:.4rem;display:none"></p>
        </div>
      )}
      <div id="catalogList" class="catalog-list"></div>
    </div>

    <!-- TAB: HISTORY -->
    <div id="tabHistory" class="tab-content" style="display:none">
      <div id="historyList" class="history-list"></div>
    </div>

    <!-- TAB: EDIT -->
    <div id="tabEdit" class="tab-content" style="display:none">
      <div class="form-grid">
        <div class="form-group span2">
          <label class="form-label">Nombre</label>
          <input type="text" id="editNombre" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label">Contacto</label>
          <input type="text" id="editContacto" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label">Teléfono</label>
          <input type="text" id="editTelefono" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" id="editEmail" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label">Dirección</label>
          <input type="text" id="editDireccion" class="form-input">
        </div>
        <div class="form-group span2">
          <label class="form-label">Notas</label>
          <textarea id="editNotas" class="form-input" rows="2"></textarea>
        </div>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:1rem">
        <button onclick="deleteSupplier()" class="btn btn-danger btn-sm">Desactivar proveedor</button>
        <button onclick="updateSupplier()" class="btn btn-primary btn-sm">Guardar cambios</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══ MODAL: REALIZAR PEDIDO ════════════════════════════════════════════ -->
<div id="orderModal" class="modal-overlay" style="display:none">
  <div class="modal-box modal-lg">
    <div class="modal-header">
      <h2 class="modal-title">📦 Realizar pedido</h2>
      <button onclick="closeModal('orderModal')" class="modal-close">✕</button>
    </div>
    <div class="modal-body">
      <p class="modal-meta" id="orderSupplierName" style="margin-bottom:1rem"></p>
      <div id="orderItemsList" class="order-items"></div>
      <div id="orderEmpty" class="order-empty" style="display:none">
        <p>El catálogo de este proveedor está vacío. Agrega libros primero.</p>
      </div>
      <div class="form-group" style="margin-top:1rem">
        <label class="form-label">Notas del pedido</label>
        <textarea id="orderNotas" class="form-input" rows="2" placeholder="Condiciones especiales…"></textarea>
      </div>
      <div class="order-total-row" id="orderTotalRow" style="display:none">
        <span>Total estimado:</span>
        <strong id="orderTotal">L 0.00</strong>
      </div>
    </div>
    <div class="modal-footer">
      <button onclick="closeModal('orderModal')" class="btn btn-secondary">Cancelar</button>
      <button id="confirmOrderBtn" class="btn btn-primary" onclick="confirmOrder()">
        <span id="orderBtnText">Confirmar pedido</span>
        <span id="orderBtnSpinner" class="spinner" style="display:none"></span>
      </button>
    </div>
  </div>
</div>

</DashboardLayout>

<script is:inline define:vars={{ API_URL, isAdmin }}>
  const BACKEND = API_URL || 'http://localhost:8000/api/v1';
  const token = () => localStorage.getItem('token');
  const headers = () => ({ 'Content-Type': 'application/json', 'Authorization': `Bearer ${token()}` });

  let suppliers = [];
  let allBooks  = [];
  let currentSupplier = null;

  // ── INIT ──────────────────────────────────────────────────────────────────
  async function init() {
    await Promise.all([loadSuppliers(), loadAllBooks()]);
  }

  // ── LOAD ALL BOOKS for select ─────────────────────────────────────────────
  async function loadAllBooks() {
    try {
      // Try authenticated first, fallback to public catalog
      let r = await fetch(`${BACKEND}/books/inventory/all`, { headers: headers() });
      if (!r.ok) r = await fetch(`${BACKEND}/books/catalog?limit=500&solo_disponibles=false`, { headers: headers() });
      if (r.ok) {
        allBooks = await r.json();
        populateBookSelect();
      }
    } catch(e) { console.warn('loadAllBooks:', e); }
  }

  function populateBookSelect() {
    const sel = document.getElementById('addBookSelect');
    if (!sel) return;
    if (!allBooks.length) {
      sel.innerHTML = '<option value="">No hay libros disponibles</option>';
      return;
    }
    sel.innerHTML = '<option value="">Selecciona un libro…</option>' +
      allBooks.map(b =>
        `<option value="${b.id}" data-nombre="${b.nombre}">${b.nombre} — ${b.autor} (Stock: ${b.stock})</option>`
      ).join('');
  }

  // ── LOAD SUPPLIERS ────────────────────────────────────────────────────────
  async function loadSuppliers() {
    try {
      const r = await fetch(`${BACKEND}/suppliers/`, { headers: headers() });
      if (!r.ok) throw new Error();
      suppliers = await r.json();
      renderSuppliers();
    } catch(e) {
      document.getElementById('loadingState').innerHTML = '<p style="color:#dc2626">Error al cargar proveedores.</p>';
    }
  }

  // ── RENDER SUPPLIER CARDS ─────────────────────────────────────────────────
  function renderSuppliers() {
    const grid    = document.getElementById('suppliersGrid');
    const empty   = document.getElementById('emptyState');
    const loading = document.getElementById('loadingState');
    const stats   = document.getElementById('statsRow');
    loading.style.display = 'none';

    if (!suppliers.length) {
      empty.style.display = 'flex';
      grid.style.display  = 'none';
      stats.style.display = 'none';
      return;
    }

    empty.style.display = 'none';
    grid.style.display  = 'grid';
    stats.style.display = 'grid';

    // Update stats
    const activos = suppliers.filter(s => s.activo !== false).length;
    const totalLibros = suppliers.reduce((acc, s) => acc + ((s.catalogo||[]).length), 0);
    document.getElementById('statTotal').textContent   = suppliers.length;
    document.getElementById('statActivos').textContent = activos;
    document.getElementById('statLibros').textContent  = totalLibros;

    grid.innerHTML = suppliers.map(s => {
      const catCount = (s.catalogo || []).length;
      const isActive = s.activo !== false;
      const initials = s.nombre.split(' ').slice(0,2).map(w => w[0]).join('').toUpperCase();
      const colorIdx = s.id % 6;
      const avatarColors = [
        ['#1e3a8a','#3b82f6'], ['#14532d','#22c55e'], ['#7c2d12','#f97316'],
        ['#4c1d95','#a855f7'], ['#831843','#ec4899'], ['#1e3a5f','#0ea5e9']
      ];
      const [avatarBg, avatarAccent] = avatarColors[colorIdx];

      return `
      <div class="supplier-card" onclick="openDetail(${s.id})">
        <!-- TOP: avatar + nombre + estado -->
        <div class="sc-top">
          <div class="sc-avatar" style="background:linear-gradient(135deg,${avatarBg},${avatarAccent})">${initials}</div>
          <div class="sc-info">
            <div class="sc-name">${s.nombre}</div>
            <div class="sc-status ${isActive ? 'active' : 'inactive'}">${isActive ? '● Activo' : '● Inactivo'}</div>
          </div>
        </div>

        <!-- CONTACT ROW -->
        <div class="sc-contact-row">
          ${s.contacto ? `<span class="sc-meta">👤 ${s.contacto}</span>` : ''}
          ${s.telefono ? `<span class="sc-meta">📞 ${s.telefono}</span>` : ''}
          ${s.email    ? `<span class="sc-meta sc-meta-full">✉️ ${s.email}</span>` : ''}
        </div>

        <!-- STATS -->
        <div class="sc-stats">
          <div class="sc-stat">
            <div class="sc-stat-val">${catCount}</div>
            <div class="sc-stat-lbl">libros en catálogo</div>
          </div>
          <div class="sc-stat-sep"></div>
          <div class="sc-stat">
            <div class="sc-stat-val">${s.total_pedidos || 0}</div>
            <div class="sc-stat-lbl">pedidos realizados</div>
          </div>
        </div>

        <!-- FOOTER -->
        <div class="sc-footer">
          ${s.notas ? `<p class="sc-notes">"${s.notas.substring(0,60)}${s.notas.length>60?'…':''}"</p>` : ''}
          <button class="sc-btn sc-btn-order" onclick="event.stopPropagation();openDetailThenOrder(${s.id})">📦 Realizar pedido →</button>
        </div>
      </div>`;
    }).join('');
  }

  // ── DETAIL MODAL ──────────────────────────────────────────────────────────
  async function openDetail(id) {
    try {
      const r = await fetch(`${BACKEND}/suppliers/${id}`, { headers: headers() });
      if (!r.ok) throw new Error();
      currentSupplier = await r.json();
    } catch(e) { alert('Error al cargar proveedor'); return; }

    document.getElementById('detailName').textContent = currentSupplier.nombre;
    document.getElementById('detailMeta').textContent =
      [currentSupplier.contacto, currentSupplier.email, currentSupplier.telefono].filter(Boolean).join(' · ') || 'Sin info de contacto';

    if (isAdmin) {
      document.getElementById('editNombre').value    = currentSupplier.nombre    || '';
      document.getElementById('editContacto').value  = currentSupplier.contacto  || '';
      document.getElementById('editTelefono').value  = currentSupplier.telefono  || '';
      document.getElementById('editEmail').value     = currentSupplier.email     || '';
      document.getElementById('editDireccion').value = currentSupplier.direccion || '';
      document.getElementById('editNotas').value     = currentSupplier.notas     || '';
    }

    // Re-populate select every time in case books loaded late
    populateBookSelect();
    renderCatalog();
    renderHistory();
    activateTab('catalog');
    document.getElementById('detailModal').style.display = 'flex';
  }

  function renderCatalog() {
    const list = document.getElementById('catalogList');
    const cat  = currentSupplier.catalogo || [];
    if (!cat.length) {
      list.innerHTML = '<p class="empty-catalog">Este proveedor no tiene libros en su catálogo aún.</p>';
      return;
    }
    list.innerHTML = `
      <table class="catalog-table">
        <thead><tr>
          <th>Libro</th><th>Autor</th><th>Stock actual</th><th>Costo unitario</th>
          ${isAdmin ? '<th></th>' : ''}
        </tr></thead>
        <tbody>${cat.map(item => `
          <tr>
            <td><strong>${item.libro_nombre || '—'}</strong><br><span class="isbn-small">${item.libro_isbn || ''}</span></td>
            <td>${item.libro_autor || '—'}</td>
            <td><span class="stock-badge ${item.libro_stock <= 5 ? 'low' : 'ok'}">${item.libro_stock ?? '—'}</span></td>
            <td><strong>L ${parseFloat(item.costo_unitario).toFixed(2)}</strong></td>
            ${isAdmin ? `<td><button class="btn-icon-del" onclick="removeFromCatalog(${currentSupplier.id},${item.libro_id})" title="Eliminar del catálogo">🗑</button></td>` : ''}
          </tr>`).join('')}
        </tbody>
      </table>`;
  }

  function renderHistory() {
    document.getElementById('historyList').innerHTML =
      `<p class="empty-catalog">El historial completo se registra en el módulo de Compras.</p>
       <a href="/compras" class="btn btn-secondary btn-sm" style="margin-top:.75rem;display:inline-flex">Ver compras →</a>`;
  }

  // ── CATALOG ACTIONS ───────────────────────────────────────────────────────
  window.addBookToCatalog = async function() {
    const sel    = document.getElementById('addBookSelect');
    const costoEl = document.getElementById('addBookCosto');
    const msg    = document.getElementById('catalogAddMsg');
    const libroId = parseInt(sel.value);
    const costo   = parseFloat(costoEl.value);

    if (!libroId)       { showMsg(msg, 'Selecciona un libro', 'err'); return; }
    if (!costo || costo <= 0) { showMsg(msg, 'Ingresa un costo válido', 'err'); return; }

    try {
      const r = await fetch(`${BACKEND}/suppliers/${currentSupplier.id}/catalog`, {
        method: 'POST', headers: headers(),
        body: JSON.stringify({ libro_id: libroId, costo_unitario: costo })
      });
      if (!r.ok) { const d = await r.json(); throw new Error(d.detail); }
      currentSupplier = await r.json();
      sel.value = '';
      costoEl.value = '';
      renderCatalog();
      showMsg(msg, '✅ Libro agregado al catálogo', 'ok');
      await loadSuppliers(); // refresh stats
    } catch(e) { showMsg(msg, '❌ ' + e.message, 'err'); }
  };

  window.removeFromCatalog = async function(supplierId, libroId) {
    if (!confirm('¿Quitar este libro del catálogo del proveedor?')) return;
    try {
      const r = await fetch(`${BACKEND}/suppliers/${supplierId}/catalog/${libroId}`, {
        method: 'DELETE', headers: headers()
      });
      if (!r.ok) throw new Error();
      currentSupplier = await r.json();
      renderCatalog();
    } catch(e) { alert('Error al eliminar del catálogo'); }
  };

  function showMsg(el, text, type) {
    el.textContent = text;
    el.style.color = type === 'ok' ? 'var(--success,#16a34a)' : 'var(--danger,#dc2626)';
    el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 3000);
  }

  // ── ORDER MODAL ───────────────────────────────────────────────────────────
  document.getElementById('makeOrderBtn').addEventListener('click', openOrderModal);

  function openOrderModal() {
    const cat = currentSupplier?.catalogo || [];
    document.getElementById('orderSupplierName').textContent = `Proveedor: ${currentSupplier?.nombre}`;
    document.getElementById('orderNotas').value = '';
    const list    = document.getElementById('orderItemsList');
    const emptyEl = document.getElementById('orderEmpty');

    if (!cat.length) {
      list.innerHTML = '';
      emptyEl.style.display = 'block';
      document.getElementById('orderTotalRow').style.display = 'none';
    } else {
      emptyEl.style.display = 'none';
      document.getElementById('orderTotalRow').style.display = 'flex';
      list.innerHTML = cat.map(item => `
        <div class="order-item">
          <div class="order-item-info">
            <strong>${item.libro_nombre || '—'}</strong>
            <span class="order-item-meta">Stock: ${item.libro_stock ?? '—'} · Costo: L ${parseFloat(item.costo_unitario).toFixed(2)}</span>
          </div>
          <div class="order-item-qty">
            <label class="form-label" style="font-size:.7rem">Cantidad</label>
            <input type="number" class="form-input qty-order-input" min="0" value="0"
              data-libro-id="${item.libro_id}" data-costo="${item.costo_unitario}"
              oninput="recalcOrderTotal()" style="width:80px;text-align:center">
          </div>
        </div>`).join('');
    }
    recalcOrderTotal();
    document.getElementById('orderModal').style.display = 'flex';
  }

  function recalcOrderTotal() {
    let total = 0;
    document.querySelectorAll('.qty-order-input').forEach(inp => {
      total += (parseInt(inp.value) || 0) * (parseFloat(inp.dataset.costo) || 0);
    });
    document.getElementById('orderTotal').textContent = `L ${total.toFixed(2)}`;
  }

  window.confirmOrder = async function() {
    const items = [];
    document.querySelectorAll('.qty-order-input').forEach(inp => {
      const qty = parseInt(inp.value) || 0;
      if (qty > 0) items.push({ libro_id: parseInt(inp.dataset.libroId), cantidad: qty, costo_unitario: parseFloat(inp.dataset.costo) });
    });
    if (!items.length) { alert('Agrega al menos un libro con cantidad > 0.'); return; }

    const btn = document.getElementById('confirmOrderBtn');
    btn.disabled = true;
    document.getElementById('orderBtnText').style.display  = 'none';
    document.getElementById('orderBtnSpinner').style.display = 'inline-block';

    try {
      const r = await fetch(`${BACKEND}/suppliers/${currentSupplier.id}/order`, {
        method: 'POST', headers: headers(),
        body: JSON.stringify({ items, notas: document.getElementById('orderNotas').value.trim() || null })
      });
      if (!r.ok) { const d = await r.json(); throw new Error(d.detail || 'Error'); }
      closeModal('orderModal');
      closeModal('detailModal');
      alert('✅ Pedido realizado. El stock ha sido actualizado.');
      loadSuppliers();
    } catch(e) { alert('Error: ' + e.message); }
    finally {
      btn.disabled = false;
      document.getElementById('orderBtnText').style.display    = 'inline';
      document.getElementById('orderBtnSpinner').style.display = 'none';
    }
  };

  // ── CREATE / UPDATE / DELETE ──────────────────────────────────────────────
  window.openNewSupplier = function() {
    document.getElementById('modalTitle').textContent = 'Nuevo proveedor';
    ['Nombre','Contacto','Telefono','Email','Direccion','Notas'].forEach(f => {
      const el = document.getElementById('sup' + f);
      if (el) el.value = '';
    });
    document.getElementById('supplierModal').style.display = 'flex';
  };
  document.getElementById('newSupplierBtn')?.addEventListener('click', openNewSupplier);

  window.saveSupplier = async function() {
    const nombre = document.getElementById('supNombre').value.trim();
    if (!nombre) { alert('El nombre es requerido.'); return; }
    const btn = document.getElementById('saveSupplierBtn');
    btn.disabled = true;
    document.getElementById('saveBtnText').style.display   = 'none';
    document.getElementById('saveBtnSpinner').style.display = 'inline-block';
    try {
      const r = await fetch(`${BACKEND}/suppliers/`, {
        method: 'POST', headers: headers(),
        body: JSON.stringify({
          nombre,
          contacto: document.getElementById('supContacto').value.trim() || null,
          telefono: document.getElementById('supTelefono').value.trim() || null,
          email:    document.getElementById('supEmail').value.trim()    || null,
          direccion:document.getElementById('supDireccion').value.trim()|| null,
          notas:    document.getElementById('supNotas').value.trim()    || null,
        })
      });
      if (!r.ok) { const d = await r.json(); throw new Error(d.detail || 'Error'); }
      closeModal('supplierModal');
      await loadSuppliers();
    } catch(e) { alert('Error: ' + e.message); }
    finally {
      btn.disabled = false;
      document.getElementById('saveBtnText').style.display    = 'inline';
      document.getElementById('saveBtnSpinner').style.display = 'none';
    }
  };

  window.updateSupplier = async function() {
    if (!currentSupplier) return;
    try {
      const r = await fetch(`${BACKEND}/suppliers/${currentSupplier.id}`, {
        method: 'PUT', headers: headers(),
        body: JSON.stringify({
          nombre:    document.getElementById('editNombre').value.trim(),
          contacto:  document.getElementById('editContacto').value.trim()  || null,
          telefono:  document.getElementById('editTelefono').value.trim()  || null,
          email:     document.getElementById('editEmail').value.trim()     || null,
          direccion: document.getElementById('editDireccion').value.trim() || null,
          notas:     document.getElementById('editNotas').value.trim()     || null,
        })
      });
      if (!r.ok) throw new Error((await r.json()).detail);
      currentSupplier = await r.json();
      document.getElementById('detailName').textContent = currentSupplier.nombre;
      await loadSuppliers();
      alert('✅ Proveedor actualizado.');
    } catch(e) { alert('Error: ' + e.message); }
  };

  window.deleteSupplier = async function() {
    if (!confirm(`¿Desactivar a ${currentSupplier?.nombre}?`)) return;
    try {
      await fetch(`${BACKEND}/suppliers/${currentSupplier.id}`, { method: 'DELETE', headers: headers() });
      closeModal('detailModal');
      await loadSuppliers();
    } catch(e) { alert('Error al desactivar'); }
  };

  // ── TABS ──────────────────────────────────────────────────────────────────
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => activateTab(tab.dataset.tab));
  });

  function activateTab(name) {
    document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name));
    document.getElementById('tabCatalog').style.display = name === 'catalog' ? 'block' : 'none';
    document.getElementById('tabHistory').style.display = name === 'history' ? 'block' : 'none';
    const te = document.getElementById('tabEdit');
    if (te) te.style.display = name === 'edit' ? 'block' : 'none';
  }

  window.openDetail  = openDetail;
  window.closeModal  = id => document.getElementById(id).style.display = 'none';

  // Opens detail silently then immediately opens the order modal
  window.openDetailThenOrder = async function(id) {
    await openDetail(id);
    document.getElementById('detailModal').style.display = 'none';
    openOrderModal();
  };

  init();
</script>

