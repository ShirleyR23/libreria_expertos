---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout title="Registro de Cliente">
<div class="auth-layout">
  <div class="auth-left">
    <div class="auth-left-inner">
      <div class="auth-brand">
        <span class="auth-brand-icon">📚</span>
        <span class="auth-brand-name">Librería</span>
      </div>
      <h2 class="auth-left-title">Únete a nuestra <em>comunidad de lectores.</em></h2>
      <p class="auth-left-desc">Crea tu cuenta y accede a un catálogo completo, historial de compras y recomendaciones personalizadas.</p>
      <div class="auth-features">
        <div class="auth-feature"><span>✓</span> Acceso al catálogo completo</div>
        <div class="auth-feature"><span>✓</span> Historial de compras</div>
        <div class="auth-feature"><span>✓</span> Recomendaciones personalizadas</div>
      </div>
    </div>
  </div>

  <div class="auth-right">
    <div class="register-card">
      <div class="login-header">
        <h1 class="login-title">Crear cuenta</h1>
        <p class="login-subtitle">Completa tus datos para registrarte</p>
      </div>

      <div id="errorAlert" class="auth-alert auth-alert-error" style="display:none"></div>

      <div class="form-grid-2">
        <div class="form-group">
          <label class="form-label">Nombre completo *</label>
          <input type="text" id="nombre" class="form-input" placeholder="Tu nombre">
        </div>
        <div class="form-group">
          <label class="form-label">Correo electrónico *</label>
          <input type="email" id="email" class="form-input" placeholder="tu@email.com">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Contraseña *</label>
        <div class="input-wrap">
          <input type="password" id="password" class="form-input" placeholder="Mínimo 6 caracteres">
          <button type="button" id="togglePwd" class="toggle-pwd">👁</button>
        </div>
        <div class="pwd-strength" id="pwdStrength" style="display:none">
          <div class="pwd-bar"><div id="pwdBar" class="pwd-bar-fill"></div></div>
          <span id="pwdLabel" class="pwd-label"></span>
        </div>
      </div>

      <div class="form-grid-2">
        <div class="form-group">
          <label class="form-label">Teléfono</label>
          <input type="tel" id="telefono" class="form-input" placeholder="5555-1234">
        </div>
        <div class="form-group">
          <label class="form-label">Ciudad</label>
          <input type="text" id="ciudad" class="form-input" placeholder="Tu ciudad">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Dirección</label>
        <input type="text" id="direccion" class="form-input" placeholder="Tu dirección completa">
      </div>

      <button id="registerBtn" class="btn btn-primary btn-full">
        <span id="regBtnText">Crear cuenta</span>
        <span id="regSpinner" class="spinner" style="display:none"></span>
      </button>

      <p class="auth-footer-link" style="margin-top:1.25rem">¿Ya tienes cuenta? <a href="/login">Inicia sesión aquí</a></p>
    </div>
  </div>
</div>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';

  document.getElementById('togglePwd')?.addEventListener('click', () => {
    const inp = document.getElementById('password') as HTMLInputElement;
    inp.type = inp.type === 'password' ? 'text' : 'password';
  });

  document.getElementById('password')?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value;
    const strengthEl = document.getElementById('pwdStrength')!;
    const bar = document.getElementById('pwdBar')!;
    const lbl = document.getElementById('pwdLabel')!;
    if (!val) { strengthEl.style.display = 'none'; return; }
    strengthEl.style.display = 'flex';
    let score = 0;
    if (val.length >= 6) score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    const levels = [
      { pct: 20, color: '#dc2626', label: 'Muy débil' },
      { pct: 40, color: '#f59e0b', label: 'Débil' },
      { pct: 60, color: '#eab308', label: 'Regular' },
      { pct: 80, color: '#22c55e', label: 'Fuerte' },
      { pct: 100, color: '#16a34a', label: 'Muy fuerte' },
    ];
    const lvl = levels[Math.min(score-1, 4)] || levels[0];
    bar.style.width = lvl.pct + '%';
    bar.style.background = lvl.color;
    lbl.textContent = lvl.label;
    lbl.style.color = lvl.color;
  });

  document.getElementById('registerBtn')?.addEventListener('click', async () => {
    const nombre = (document.getElementById('nombre') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const telefono = (document.getElementById('telefono') as HTMLInputElement).value.trim();
    const ciudad = (document.getElementById('ciudad') as HTMLInputElement).value.trim();
    const direccion = (document.getElementById('direccion') as HTMLInputElement).value.trim();
    const err = document.getElementById('errorAlert')!;
    err.style.display = 'none';

    if (!nombre || !email || !password) {
      err.textContent = 'Por favor completa los campos obligatorios (*)';
      err.style.display = 'block'; return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      err.textContent = 'El correo electrónico no es válido (debe contener @ y un dominio).';
      err.style.display = 'block'; return;
    }
    if (nombre.length < 2) {
      err.textContent = 'El nombre debe tener al menos 2 caracteres.';
      err.style.display = 'block'; return;
    }
    if (password.length < 6) {
      err.textContent = 'La contraseña debe tener al menos 6 caracteres.';
      err.style.display = 'block'; return;
    }

    const btn = document.getElementById('registerBtn') as HTMLButtonElement;
    btn.disabled = true;
    document.getElementById('regBtnText')!.textContent = 'Creando cuenta...';
    document.getElementById('regSpinner')!.style.display = 'inline-block';

    try {
      const res = await fetch(`${API_URL}/auth/register-client`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, email, password, telefono: telefono || null, ciudad: ciudad || null, direccion: direccion || null }),
      });
      const data = await res.json();
      if (!res.ok) {
        let msg = 'Error al registrarse. Intenta de nuevo.';
        if (data.detail) {
          const raw = typeof data.detail === 'string' ? data.detail : JSON.stringify(data.detail);
          if (/not a valid email/i.test(raw) || /must have an @/i.test(raw)) msg = 'El correo electrónico no es válido.';
          else if (/already exists|already registered|duplicat/i.test(raw)) msg = 'Ya existe una cuenta con ese correo electrónico.';
          else if (/field required/i.test(raw)) msg = 'Todos los campos obligatorios deben completarse.';
          else if (/string_too_short|at least/i.test(raw)) msg = 'Uno de los campos ingresados es demasiado corto.';
          else if (raw.length < 200) msg = raw;
        }
        throw new Error(msg);
      }
      window.location.href = '/login?registered=1';
    } catch(e: any) {
      err.textContent = e.message;
      err.style.display = 'block';
      btn.disabled = false;
      document.getElementById('regBtnText')!.textContent = 'Crear cuenta';
      document.getElementById('regSpinner')!.style.display = 'none';
    }
  });
</script>

<style>
  .auth-layout { display: flex; min-height: 100vh; }
  .auth-left { flex: 1; background: linear-gradient(145deg, var(--navy) 0%, var(--blue-dark) 60%, #1e3a6e 100%); display: flex; align-items: center; justify-content: center; padding: 3rem; position: relative; overflow: hidden; }
  .auth-left::before { content: ''; position: absolute; width: 500px; height: 500px; border-radius: 50%; background: rgba(200,169,126,0.05); top: -150px; right: -150px; }
  .auth-left-inner { position: relative; z-index: 2; max-width: 420px; }
  .auth-brand { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 3rem; }
  .auth-brand-icon { font-size: 2.5rem; }
  .auth-brand-name { font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; color: white; }
  .auth-left-title { font-family: var(--font-display); font-size: 2.25rem; font-weight: 700; color: white; line-height: 1.25; margin-bottom: 1rem; }
  .auth-left-title em { color: var(--beige); font-style: normal; }
  .auth-left-desc { color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 2rem; }
  .auth-features { display: flex; flex-direction: column; gap: 0.75rem; }
  .auth-feature { display: flex; align-items: center; gap: 0.75rem; color: rgba(255,255,255,0.75); font-size: 0.9rem; }
  .auth-feature span { color: var(--beige); font-weight: 700; }

  .auth-right { width: 520px; display: flex; align-items: center; justify-content: center; padding: 2rem; background: var(--gray-50); }
  .register-card { width: 100%; max-width: 460px; }
  .login-header { margin-bottom: 1.75rem; }
  .login-title { font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--navy); margin-bottom: 0.4rem; }
  .login-subtitle { color: var(--gray-400); font-size: 0.9rem; }
  .auth-alert { padding: 0.875rem 1rem; border-radius: var(--radius-sm); margin-bottom: 1.25rem; font-size: 0.875rem; }
  .auth-alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
  .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0 1rem; }
  @media (max-width: 500px) { .form-grid-2 { grid-template-columns: 1fr; } }
  .input-wrap { position: relative; }
  .toggle-pwd { position: absolute; right: 0.875rem; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; font-size: 1rem; opacity: 0.5; }
  .pwd-strength { display: flex; align-items: center; gap: 0.75rem; margin-top: 0.5rem; }
  .pwd-bar { flex: 1; height: 4px; background: var(--gray-200); border-radius: 999px; overflow: hidden; }
  .pwd-bar-fill { height: 100%; border-radius: 999px; transition: all 0.3s; width: 0; }
  .pwd-label { font-size: 0.75rem; font-weight: 600; white-space: nowrap; }
  .btn-full { width: 100%; padding: 0.875rem; font-size: 1rem; }
  .auth-footer-link { text-align: center; font-size: 0.875rem; color: var(--gray-400); }
  .auth-footer-link a { color: var(--blue-mid); font-weight: 600; text-decoration: none; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: middle; }
  @media (max-width: 900px) { .auth-left { display: none; } .auth-right { width: 100%; } }
</style>
</PublicLayout>