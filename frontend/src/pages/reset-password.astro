---
import PublicLayout from '../layouts/PublicLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api/v1';
---
<PublicLayout title="Nueva contraseña">
<div class="auth-layout">
  <div class="auth-left">
    <div class="auth-left-inner">
      <div class="auth-brand"><span class="auth-brand-icon">📚</span><span class="auth-brand-name">Librería</span></div>
      <h2 class="auth-left-title">Crea tu nueva contraseña</h2>
      <p class="auth-left-desc">Elige una contraseña segura para proteger tu cuenta.</p>
      <div class="auth-features">
        <div class="auth-feature"><span>🔒</span> Mínimo 6 caracteres</div>
        <div class="auth-feature"><span>✅</span> Usa letras y números</div>
        <div class="auth-feature"><span>🚫</span> No la compartas con nadie</div>
      </div>
    </div>
  </div>
  <div class="auth-right">
    <div class="login-card">
      <div id="loadingSection" style="text-align:center;padding:2rem 0">
        <div class="big-spinner"></div>
        <p style="color:#94a3b8;margin-top:1rem">Verificando enlace…</p>
      </div>

      <div id="invalidSection" style="display:none;text-align:center;padding:1rem 0">
        <div style="font-size:3rem;margin-bottom:1rem">⛔</div>
        <h2 style="font-family:'Playfair Display',serif;color:#0d1b2e;margin-bottom:0.5rem">Enlace inválido</h2>
        <p style="color:#94a3b8;margin-bottom:1.5rem">El enlace ha expirado o ya fue utilizado.</p>
        <a href="/forgot-password" class="btn btn-primary">Solicitar nuevo enlace</a>
      </div>

      <div id="formSection" style="display:none">
        <div class="login-header">
          <h1 class="login-title">Nueva contraseña</h1>
          <p class="login-subtitle" id="tokenEmail">Actualizando tu cuenta…</p>
        </div>
        <div id="errorAlert" class="auth-alert auth-alert-error" style="display:none"></div>
        <div class="form-group">
          <label class="form-label">Nueva contraseña</label>
          <div class="input-wrap">
            <input type="password" id="pwd1" class="form-input" placeholder="Mínimo 6 caracteres">
            <button type="button" id="togglePwd1" class="toggle-pwd">👁</button>
          </div>
        </div>
        <div class="form-group" style="margin-top:0.75rem">
          <label class="form-label">Confirmar contraseña</label>
          <div class="input-wrap">
            <input type="password" id="pwd2" class="form-input" placeholder="Repite la contraseña">
            <button type="button" id="togglePwd2" class="toggle-pwd">👁</button>
          </div>
        </div>
        <button id="submitBtn" class="btn btn-primary btn-full" style="margin-top:1.25rem">
          <span id="btnText">Guardar nueva contraseña</span>
          <span id="btnSpinner" class="spinner" style="display:none"></span>
        </button>
      </div>

      <div id="successSection" style="display:none;text-align:center;padding:1rem 0">
        <div style="font-size:3rem;margin-bottom:1rem">✅</div>
        <h2 style="font-family:'Playfair Display',serif;color:#0d1b2e;margin-bottom:0.5rem">¡Contraseña actualizada!</h2>
        <p style="color:#94a3b8;margin-bottom:1.5rem">Ya puedes iniciar sesión con tu nueva contraseña.</p>
        <a href="/login" class="btn btn-primary">Ir a iniciar sesión</a>
      </div>
    </div>
  </div>
</div>
</PublicLayout>

<script is:inline define:vars={{ API_URL }}>
  const BACKEND = API_URL || 'http://localhost:8000/api/v1';
  let resetToken = '';

  async function init() {
    const params = new URLSearchParams(window.location.search);
    resetToken = params.get('token') || '';
    if (!resetToken) { showSection('invalid'); return; }

    try {
      const r = await fetch(`${BACKEND}/auth/validate-reset-token?token=${encodeURIComponent(resetToken)}`);
      if (!r.ok) { showSection('invalid'); return; }
      const data = await r.json();
      document.getElementById('tokenEmail').textContent = `Actualizando contraseña para: ${data.email}`;
      showSection('form');
    } catch(e) {
      showSection('invalid');
    }
  }

  function showSection(name) {
    document.getElementById('loadingSection').style.display = name === 'loading' ? 'block' : 'none';
    document.getElementById('invalidSection').style.display = name === 'invalid' ? 'block' : 'none';
    document.getElementById('formSection').style.display = name === 'form' ? 'block' : 'none';
    document.getElementById('successSection').style.display = name === 'success' ? 'block' : 'none';
  }

  document.getElementById('submitBtn').addEventListener('click', async () => {
    const pwd1 = document.getElementById('pwd1').value;
    const pwd2 = document.getElementById('pwd2').value;
    const errEl = document.getElementById('errorAlert');
    errEl.style.display = 'none';

    if (pwd1.length < 6) { errEl.textContent = 'La contraseña debe tener al menos 6 caracteres.'; errEl.style.display = 'block'; return; }
    if (pwd1 !== pwd2) { errEl.textContent = 'Las contraseñas no coinciden.'; errEl.style.display = 'block'; return; }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    document.getElementById('btnText').style.display = 'none';
    document.getElementById('btnSpinner').style.display = 'inline-block';

    try {
      const r = await fetch(`${BACKEND}/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: resetToken, new_password: pwd1 }),
      });
      if (!r.ok) {
        const d = await r.json();
        errEl.textContent = d.detail || 'Error al actualizar contraseña.';
        errEl.style.display = 'block';
        return;
      }
      showSection('success');
    } catch(e) {
      errEl.textContent = 'Error al conectar con el servidor.';
      errEl.style.display = 'block';
    } finally {
      btn.disabled = false;
      document.getElementById('btnText').style.display = 'inline';
      document.getElementById('btnSpinner').style.display = 'none';
    }
  });

  // Toggle password visibility
  ['1','2'].forEach(n => {
    document.getElementById(`togglePwd${n}`).addEventListener('click', () => {
      const inp = document.getElementById(`pwd${n}`);
      inp.type = inp.type === 'password' ? 'text' : 'password';
    });
  });

  init();
</script>

<style is:global>
  body { margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:#f8fafc; }
  .auth-layout { display:flex; min-height:100vh; }
  .auth-left { width:42%; background:linear-gradient(135deg,#0d1b2e 0%,#1a3560 100%); padding:3rem; display:flex; align-items:center; justify-content:center; }
  .auth-left-inner { max-width:360px; }
  .auth-brand { display:flex; align-items:center; gap:0.75rem; margin-bottom:2.5rem; }
  .auth-brand-icon { font-size:2rem; }
  .auth-brand-name { font-size:1.5rem; font-weight:700; color:white; font-family:'Playfair Display',Georgia,serif; }
  .auth-left-title { font-size:1.75rem; font-weight:700; color:white; line-height:1.3; margin-bottom:1rem; font-family:'Playfair Display',Georgia,serif; }
  .auth-left-desc { color:rgba(255,255,255,0.65); line-height:1.7; font-size:0.95rem; margin-bottom:2rem; }
  .auth-features { display:flex; flex-direction:column; gap:0.875rem; }
  .auth-feature { display:flex; align-items:center; gap:0.75rem; color:rgba(255,255,255,0.8); font-size:0.875rem; }
  .auth-right { flex:1; display:flex; align-items:center; justify-content:center; padding:2rem; }
  .login-card { background:white; border-radius:20px; padding:2.5rem; width:100%; max-width:420px; box-shadow:0 4px 24px rgba(0,0,0,0.08); }
  .login-header { margin-bottom:1.75rem; }
  .login-title { font-family:'Playfair Display',Georgia,serif; font-size:1.75rem; font-weight:700; color:#0d1b2e; margin-bottom:0.35rem; }
  .login-subtitle { color:#94a3b8; font-size:0.85rem; }
  .form-group { display:flex; flex-direction:column; gap:0.35rem; }
  .form-label { font-size:0.8rem; font-weight:600; color:#475569; }
  .input-wrap { position:relative; }
  .form-input { width:100%; padding:0.75rem 2.5rem 0.75rem 1rem; border:1.5px solid #e2e8f0; border-radius:10px; font-size:0.95rem; font-family:inherit; color:#0d1b2e; transition:border-color 0.15s; box-sizing:border-box; }
  .form-input:focus { outline:none; border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,0.1); }
  .toggle-pwd { position:absolute; right:0.75rem; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; font-size:0.9rem; }
  .btn { display:inline-flex; align-items:center; justify-content:center; gap:0.5rem; padding:0.75rem 1.5rem; border-radius:10px; font-weight:600; font-size:0.95rem; cursor:pointer; border:none; transition:all 0.2s; font-family:inherit; text-decoration:none; }
  .btn-primary { background:#2563eb; color:white; }
  .btn-primary:hover:not(:disabled) { background:#1d4ed8; }
  .btn-primary:disabled { opacity:0.6; cursor:not-allowed; }
  .btn-full { width:100%; }
  .auth-alert { padding:0.875rem 1rem; border-radius:10px; font-size:0.875rem; line-height:1.5; }
  .auth-alert-error { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; margin-bottom:1rem; }
  .spinner { width:16px; height:16px; border:2px solid rgba(255,255,255,0.3); border-top-color:white; border-radius:50%; animation:spin 0.7s linear infinite; }
  .big-spinner { width:40px; height:40px; border:3px solid #e2e8f0; border-top-color:#2563eb; border-radius:50%; animation:spin 0.8s linear infinite; margin:0 auto; }
  @keyframes spin { to { transform:rotate(360deg); } }
  @media(max-width:768px) { .auth-left { display:none; } .auth-right { padding:1.5rem; } }
</style>
